---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import ChatWidget from "../components/ChatWidget.astro";
import { SITE_URL } from "../lib/site.js";

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  showHero?: boolean;
}

const {
  title,
  description = "Info Ayuda Venezuela — Directorio de ayuda humanitaria. Centros de acopio, necesidades urgentes y números de emergencia para los afectados por el sismo del 24 de junio de 2026.",
  canonical,
  ogType = "website",
  showHero = true,
} = Astro.props;

const siteUrl = SITE_URL;
const normalizedPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const canonicalUrl = canonical || `${siteUrl}${normalizedPath}`;
const fullTitle = title === "Inicio"
  ? "Info Ayuda Venezuela — Directorio de ayuda humanitaria"
  : `${title} | Info Ayuda Venezuela`;
---

<!DOCTYPE html>
<html lang="es-VE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="centros de acopio, donaciones Venezuela, sismo Venezuela, ayuda humanitaria, recolección donativos, damnificados, emergencia nacional, insumos médicos, alimentos no perecederos" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Info Ayuda Venezuela" />
    <meta name="theme-color" content="#00247D" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_VE" />
    <meta property="og:site_name" content="Info Ayuda Venezuela" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/img/vnzl.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/img/vnzl.png`} />

    <!-- Datos estructurados (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Info Ayuda Venezuela",
      "url": siteUrl,
      "description": description,
      "inLanguage": "es-VE",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Info Ayuda Venezuela",
      "url": siteUrl,
      "logo": `${siteUrl}/img/vnzl.png`,
      "description": "Plataforma ciudadana que centraliza centros de acopio, refugios, necesidades urgentes y números de emergencia para los afectados por el sismo del 24 de junio de 2026 en Venezuela.",
      "areaServed": {
        "@type": "Country",
        "name": "Venezuela",
      },
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <Navbar />
    {showHero && <Hero />}
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <ChatWidget />

    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>
