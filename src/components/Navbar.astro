<SugerirCentroModal />
<SugerirEnlaceModal />
<ReportarNecesidadModal />

<script>
  import { getSupabase } from "../lib/supabase";

  const navRefreshBtn = document.getElementById('navRefreshBtn');
  if (navRefreshBtn) {
    navRefreshBtn.addEventListener('click', () => {
      const svg = navRefreshBtn.querySelector('svg');
      if (svg) svg.classList.add('animate-spin');
      window.location.reload();
    });
  }

  const sugerirDialog = document.getElementById('sugerirDialog') as HTMLDialogElement;
  const closeDialogBtn = document.getElementById('closeDialogBtn') as HTMLButtonElement;
  const cancelFormBtn = document.getElementById('cancelFormBtn') as HTMLButtonElement;
  const sugerirForm = document.getElementById('sugerirForm') as HTMLFormElement;
  const formSuccessMessage = document.getElementById('formSuccessMessage') as HTMLElement;
  const successCloseBtn = document.getElementById('successCloseBtn') as HTMLButtonElement;

  function openSugerirForm() {
    sugerirForm.style.display = 'flex';
    formSuccessMessage.style.display = 'none';
    sugerirForm.reset();
    document.getElementById('formPaisGroup')!.style.display = 'none';
    (document.getElementById('formPais') as HTMLInputElement).required = false;
    sugerirDialog.showModal();
  }

  const formEstado = document.getElementById('formEstado') as HTMLSelectElement;
  if (formEstado) {
    formEstado.addEventListener('change', () => {
      const formPaisGroup = document.getElementById('formPaisGroup') as HTMLElement;
      const formPais = document.getElementById('formPais') as HTMLInputElement;
      if (formEstado.value === 'Internacional') {
        formPaisGroup.style.display = 'flex';
        formPais.required = true;
      } else {
        formPaisGroup.style.display = 'none';
        formPais.required = false;
        formPais.value = '';
      }
    });
  }

  const homeSugerirBtn = document.getElementById('homeSugerirBtn') as HTMLButtonElement | null;
  if (homeSugerirBtn) {
    homeSugerirBtn.addEventListener('click', openSugerirForm);
  }

  const btnReportarCentro = document.getElementById('btnReportarCentro') as HTMLButtonElement | null;
  if (btnReportarCentro) {
    btnReportarCentro.addEventListener('click', openSugerirForm);
  }

  const homeReportarBtn = document.getElementById('homeReportarBtn') as HTMLButtonElement | null;
  if (homeReportarBtn) {
    homeReportarBtn.addEventListener('click', () => {
      const dialog = document.getElementById('reportarNecesidadDialog') as HTMLDialogElement;
      const form = document.getElementById('reportarNecesidadForm') as HTMLFormElement;
      const successMsg = document.getElementById('necFormSuccessMessage') as HTMLElement;
      if (dialog && form) {
        form.style.display = 'flex';
        successMsg.style.display = 'none';
        form.reset();
        if (typeof clearNecErrors === 'function') clearNecErrors();
        dialog.showModal();
      }
    });
  }

  const closeForm = () => { sugerirDialog.close(); };
  if (closeDialogBtn) closeDialogBtn.addEventListener('click', closeForm);
  if (cancelFormBtn) cancelFormBtn.addEventListener('click', closeForm);
  if (successCloseBtn) successCloseBtn.addEventListener('click', closeForm);

  sugerirDialog.addEventListener('click', (e) => {
    if (e.target === sugerirDialog) {
      sugerirDialog.close();
    }
  });

  if (sugerirForm) {
    sugerirForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const estado = (document.getElementById('formEstado') as HTMLSelectElement).value;
      let ciudad = (document.getElementById('formCiudad') as HTMLInputElement).value.trim();
      const pais = (document.getElementById('formPais') as HTMLInputElement).value.trim();
      if (estado === 'Internacional' && pais) {
        ciudad = ciudad + ', ' + pais;
      }
      const nombre = (document.getElementById('formNombre') as HTMLInputElement).value.trim();
      const direccion = (document.getElementById('formDireccion') as HTMLTextAreaElement).value.trim() || null;
      const contacto = (document.getElementById('formContacto') as HTMLInputElement).value.trim() || null;
      const hora = (document.getElementById('formHora') as HTMLInputElement).value.trim() || null;
      const acepta = (document.getElementById('formAcepta') as HTMLInputElement).value.trim().split(',').map(i => i.trim()).filter(Boolean);
      const necesitan = (document.getElementById('formNecesitan') as HTMLInputElement).value.trim().split(',').map(i => i.trim()).filter(Boolean);
      const pago_movil = (document.getElementById('formPagoMovil') as HTMLInputElement).value.trim() || null;
      const zelle = (document.getElementById('formZelle') as HTMLInputElement).value.trim() || null;

      const htmlPattern = /<[^>]*>/;
      const campos = [ciudad, nombre, direccion, contacto, hora, pago_movil, zelle, ...acepta, ...necesitan];
      if (campos.some((v) => v && htmlPattern.test(v))) {
        alert('No se permite HTML en los campos del formulario.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }
      if (ciudad.length < 2 || ciudad.length > 60) {
        alert('La ciudad debe tener entre 2 y 60 caracteres.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }
      if (nombre.length < 2 || nombre.length > 120) {
        alert('El nombre debe tener entre 2 y 120 caracteres.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      const supabase = await getSupabase();
      if (!supabase) {
        alert('El sistema está operando en modo local/sin conexión.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      try {
        const { error } = await supabase.from('centros_acopio').insert({
          estado, ciudad, nombre, direccion, contacto, hora,
          acepta, necesitan, pago_movil, zelle, verificado: false
        });
        if (error) throw error;
        sugerirForm.style.display = 'none';
        formSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando en Supabase:', err);
        alert('Hubo un error al enviar tu sugerencia.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }

  const sugerirEnlaceDialog = document.getElementById('sugerirEnlaceDialog') as HTMLDialogElement;
  const closeEnlaceDialogBtn = document.getElementById('closeEnlaceDialogBtn') as HTMLButtonElement;
  const cancelEnlaceFormBtn = document.getElementById('cancelEnlaceFormBtn') as HTMLButtonElement;
  const sugerirEnlaceForm = document.getElementById('sugerirEnlaceForm') as HTMLFormElement;
  const enlaceFormSuccessMessage = document.getElementById('enlaceFormSuccessMessage') as HTMLElement;
  const enlaceSuccessCloseBtn = document.getElementById('enlaceSuccessCloseBtn') as HTMLButtonElement;

  const btnSugerirEnlace = document.getElementById('btnSugerirEnlace') as HTMLButtonElement | null;
  if (btnSugerirEnlace) {
    btnSugerirEnlace.addEventListener('click', () => {
      sugerirEnlaceForm.style.display = 'flex';
      enlaceFormSuccessMessage.style.display = 'none';
      sugerirEnlaceForm.reset();
      sugerirEnlaceDialog.showModal();
    });
  }

  const closeEnlaceForm = () => { sugerirEnlaceDialog.close(); };
  if (closeEnlaceDialogBtn) closeEnlaceDialogBtn.addEventListener('click', closeEnlaceForm);
  if (cancelEnlaceFormBtn) cancelEnlaceFormBtn.addEventListener('click', closeEnlaceForm);
  if (enlaceSuccessCloseBtn) enlaceSuccessCloseBtn.addEventListener('click', closeEnlaceForm);

  sugerirEnlaceDialog.addEventListener('click', (e) => {
    if (e.target === sugerirEnlaceDialog) {
      sugerirEnlaceDialog.close();
    }
  });

  if (sugerirEnlaceForm) {
    sugerirEnlaceForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitEnlaceFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const titulo = (document.getElementById('formEnlaceTitulo') as HTMLInputElement).value.trim();
      const categoria = (document.getElementById('formEnlaceCategoria') as HTMLSelectElement).value;
      const descripcion = (document.getElementById('formEnlaceDescripcion') as HTMLTextAreaElement).value.trim();
      let url = (document.getElementById('formEnlaceUrl') as HTMLInputElement).value.trim();
      if (url && !/^https?:\/\//i.test(url)) url = 'https://' + url;

      const htmlPattern = /<[^>]*>/;
      const campos = [titulo, descripcion, categoria];
      if (campos.some((v) => v && htmlPattern.test(v))) {
        alert('No se permite HTML en los campos del formulario.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }
      if (titulo.length < 2 || titulo.length > 120) {
        alert('El título debe tener entre 2 y 120 caracteres.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }
      if (descripcion.length < 2 || descripcion.length > 300) {
        alert('La descripción debe tener entre 2 y 300 caracteres.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }
      if (!url || !/^https?:\/\//i.test(url)) {
        alert('La URL debe empezar con http:// o https://');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }
      if (url.length > 300) {
        alert('La URL es demasiado larga (máximo 300 caracteres).');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      const supabase = await getSupabase();
      if (!supabase) {
        alert('El sistema está operando en modo local/sin conexión.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      try {
        const { error } = await supabase.from('enlaces_ayuda').insert({
          titulo, categoria, descripcion, url, verificado: false
        });
        if (error) throw error;
        sugerirEnlaceForm.style.display = 'none';
        enlaceFormSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando enlace en Supabase:', err);
        alert('Hubo un error al enviar tu sugerencia.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }

  const reportarNecesidadDialog = document.getElementById('reportarNecesidadDialog') as HTMLDialogElement;
  const navNecesidadBtn = document.getElementById('navNecesidadBtn') as HTMLButtonElement;
  const closeNecesidadDialogBtn = document.getElementById('closeNecesidadDialogBtn') as HTMLButtonElement;
  const cancelNecFormBtn = document.getElementById('cancelNecFormBtn') as HTMLButtonElement;
  const reportarNecesidadForm = document.getElementById('reportarNecesidadForm') as HTMLFormElement;
  const necFormSuccessMessage = document.getElementById('necFormSuccessMessage') as HTMLElement;
  const necSuccessCloseBtn = document.getElementById('necSuccessCloseBtn') as HTMLButtonElement;

  function showNecError(id: string, msg: string) {
    const el = document.getElementById(id) as HTMLElement;
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
  }
  function clearNecErrors() {
    document.querySelectorAll('#reportarNecesidadForm [data-error]').forEach(el => {
      el.textContent = ''; el.classList.add('hidden');
    });
  }

  if (navNecesidadBtn) {
    navNecesidadBtn.addEventListener('click', () => {
      reportarNecesidadForm.style.display = 'flex';
      necFormSuccessMessage.style.display = 'none';
      reportarNecesidadForm.reset();
      clearNecErrors();
      reportarNecesidadDialog.showModal();
    });
  }

  const closeNecForm = () => { reportarNecesidadDialog.close(); };
  if (closeNecesidadDialogBtn) closeNecesidadDialogBtn.addEventListener('click', closeNecForm);
  if (cancelNecFormBtn) cancelNecFormBtn.addEventListener('click', closeNecForm);
  if (necSuccessCloseBtn) necSuccessCloseBtn.addEventListener('click', closeNecForm);

  reportarNecesidadDialog.addEventListener('click', (e) => {
    if (e.target === reportarNecesidadDialog) {
      reportarNecesidadDialog.close();
    }
  });

  if (reportarNecesidadForm) {
    reportarNecesidadForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearNecErrors();

      const estado = (document.getElementById('necFormEstado') as HTMLSelectElement).value;
      let ciudad = (document.getElementById('necFormCiudad') as HTMLInputElement).value.trim();
      const lugar = (document.getElementById('necFormLugar') as HTMLInputElement).value.trim();
      const direccion = (document.getElementById('necFormDireccion') as HTMLTextAreaElement).value.trim() || null;
      const que_necesitan = (document.getElementById('necFormNecesitan') as HTMLTextAreaElement).value.trim();
      const contacto = (document.getElementById('necFormContacto') as HTMLInputElement).value.trim() || null;

      const catChecked = document.querySelectorAll('#necCategorias input:checked');
      const categorias = Array.from(catChecked).map(el => (el as HTMLInputElement).value);

      let hasError = false;

      if (!estado) { showNecError('necErrorEstado', 'Selecciona un estado'); hasError = true; }
      if (ciudad.length < 2) { showNecError('necErrorCiudad', 'Mínimo 2 caracteres'); hasError = true; }
      if (lugar.length < 2) { showNecError('necErrorLugar', 'Mínimo 2 caracteres'); hasError = true; }
      if (categorias.length === 0) { showNecError('necErrorCategoria', 'Selecciona al menos una categoría'); hasError = true; }
      if (que_necesitan.length < 5) { showNecError('necErrorNecesitan', 'Describe qué necesitan (mín. 5 caracteres)'); hasError = true; }

      const htmlPattern = /<[^>]*>/;
      const campos = [ciudad, lugar, direccion, que_necesitan, contacto];
      if (campos.some((v) => v && htmlPattern.test(v))) {
        showNecError('necErrorNecesitan', 'No se permite HTML');
        hasError = true;
      }

      if (hasError) return;

      const supabase = await getSupabase();
      if (!supabase) {
        showNecError('necErrorNecesitan', 'El sistema está en modo local/sin conexión.');
        return;
      }

      const submitBtn = document.getElementById('submitNecFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      try {
        const categoriasStr = categorias.length > 0 ? `[Categorías: ${categorias.join(', ')}]\n\n` : '';
        const finalQueNecesitan = categoriasStr + que_necesitan;
        
        const { error } = await supabase.from('necesidades_urgentes').insert({
          estado, ciudad, lugar, direccion, que_necesitan: finalQueNecesitan, contacto, verificado: false
        });
        if (error) throw error;
        reportarNecesidadForm.style.display = 'none';
        necFormSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando necesidad urgente en Supabase:', err);
        showNecError('necErrorNecesitan', 'Hubo un error al enviar tu reporte.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }

  const navMoreOverlay = document.getElementById('navMoreOverlay') as HTMLElement;
  const navMoreSheet = document.getElementById('navMoreSheet') as HTMLElement;
  const navMoreBtn = document.getElementById('navMoreBtn') as HTMLButtonElement;

  function openMoreSheet() {
    navMoreOverlay.classList.add('opacity-100');
    navMoreOverlay.classList.remove('invisible');
    navMoreSheet.classList.add('translate-y-0');
    navMoreSheet.classList.remove('translate-y-full');
  }
  function closeMoreSheet() {
    navMoreOverlay.classList.remove('opacity-100');
    navMoreOverlay.classList.add('invisible');
    navMoreSheet.classList.remove('translate-y-0');
    navMoreSheet.classList.add('translate-y-full');
  }

  const navMoreCloseBtn = document.getElementById('navMoreCloseBtn') as HTMLButtonElement;

  if (navMoreBtn && navMoreOverlay && navMoreSheet) {
    navMoreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openMoreSheet();
    });
    navMoreOverlay.addEventListener('click', closeMoreSheet);
    navMoreSheet.querySelectorAll('.nav-more-item').forEach(el => {
      el.addEventListener('click', closeMoreSheet);
    });
    if (navMoreCloseBtn) {
      navMoreCloseBtn.addEventListener('click', closeMoreSheet);
    }
  }

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const openSheet = document.querySelector('.nav-more-sheet.open');
    if (openSheet) { closeMoreSheet(); return; }
    const openDialog = document.querySelector('dialog[open]');
    if (openDialog) { (openDialog as HTMLDialogElement).close(); }
  });
</script>