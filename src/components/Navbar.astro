---
import "../styles/navbar.css";
import "../styles/modal.css";
import SugerirCentroModal from "./SugerirCentroModal.astro";
import SugerirEnlaceModal from "./SugerirEnlaceModal.astro";
---

<div class="flag-bar"><span class="y"></span><span class="b"></span><span class="r"></span></div>
<nav class="navbar">
  <div class="brand-section">
    <div class="brand">
      Centros de Acopio
      <span class="sub">Venezuela</span>
    </div>
  </div>
  <div class="nav-actions">
    <button id="navRefreshBtn" class="nav-refresh" title="Actualizar Datos">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline-block; vertical-align:middle; margin-right:4px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
      Actualizar
    </button>
    <button id="navSugerirBtn" class="nav-sugerir">+ Sugerir Centro</button>
    <a href="/emergencia" class="nav-emergencia">&#128222; Emergencia</a>
  </div>
</nav>

<SugerirCentroModal />
<SugerirEnlaceModal />

<script>
  import { supabase } from "../lib/supabase";

  // --- Actualizar Datos ---
  const navRefreshBtn = document.getElementById('navRefreshBtn');
  if (navRefreshBtn) {
    navRefreshBtn.addEventListener('click', () => {
      const svg = navRefreshBtn.querySelector('svg');
      if (svg) svg.classList.add('animate-spin');
      window.location.reload();
    });
  }

  // --- Sugerir Centro de Acopio ---
  const sugerirDialog = document.getElementById('sugerirDialog') as HTMLDialogElement;
  const navSugerirBtn = document.getElementById('navSugerirBtn') as HTMLButtonElement;
  const closeDialogBtn = document.getElementById('closeDialogBtn') as HTMLButtonElement;
  const cancelFormBtn = document.getElementById('cancelFormBtn') as HTMLButtonElement;
  const sugerirForm = document.getElementById('sugerirForm') as HTMLFormElement;
  const formSuccessMessage = document.getElementById('formSuccessMessage') as HTMLElement;
  const successCloseBtn = document.getElementById('successCloseBtn') as HTMLButtonElement;

  if (navSugerirBtn) {
    navSugerirBtn.addEventListener('click', () => {
      sugerirForm.style.display = 'flex';
      formSuccessMessage.style.display = 'none';
      sugerirForm.reset();
      sugerirDialog.showModal();
    });
  }

  const closeForm = () => { sugerirDialog.close(); };
  if (closeDialogBtn) closeDialogBtn.addEventListener('click', closeForm);
  if (cancelFormBtn) cancelFormBtn.addEventListener('click', closeForm);
  if (successCloseBtn) successCloseBtn.addEventListener('click', closeForm);

  sugerirDialog.addEventListener('click', (e) => {
    const r = sugerirDialog.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
      sugerirDialog.close();
    }
  });

  if (sugerirForm) {
    sugerirForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const estado = (document.getElementById('formEstado') as HTMLSelectElement).value;
      const ciudad = (document.getElementById('formCiudad') as HTMLInputElement).value.trim();
      const nombre = (document.getElementById('formNombre') as HTMLInputElement).value.trim();
      const direccion = (document.getElementById('formDireccion') as HTMLTextAreaElement).value.trim() || null;
      const contacto = (document.getElementById('formContacto') as HTMLInputElement).value.trim() || null;
      const hora = (document.getElementById('formHora') as HTMLInputElement).value.trim() || null;
      const acepta = (document.getElementById('formAcepta') as HTMLInputElement).value.trim().split(',').map(i => i.trim()).filter(Boolean);
      const necesitan = (document.getElementById('formNecesitan') as HTMLInputElement).value.trim().split(',').map(i => i.trim()).filter(Boolean);
      const pago_movil = (document.getElementById('formPagoMovil') as HTMLInputElement).value.trim() || null;
      const zelle = (document.getElementById('formZelle') as HTMLInputElement).value.trim() || null;

      if (!supabase) {
        alert('El sistema está operando en modo local/sin conexión. No se pueden procesar sugerencias de nuevos centros en este momento.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      try {
        const { error } = await supabase.from('centros_acopio').insert({
          estado, ciudad, nombre, direccion, contacto, hora,
          acepta, necesitan, pago_movil, zelle, verificado: false
        });
        if (error) throw error;
        sugerirForm.style.display = 'none';
        formSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando en Supabase:', err);
        alert('Hubo un error al enviar tu sugerencia. Por favor verifica tu conexión e intenta de nuevo.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }

  // --- Sugerir Enlaces de Ayuda ---
  const sugerirEnlaceDialog = document.getElementById('sugerirEnlaceDialog') as HTMLDialogElement;
  const closeEnlaceDialogBtn = document.getElementById('closeEnlaceDialogBtn') as HTMLButtonElement;
  const cancelEnlaceFormBtn = document.getElementById('cancelEnlaceFormBtn') as HTMLButtonElement;
  const sugerirEnlaceForm = document.getElementById('sugerirEnlaceForm') as HTMLFormElement;
  const enlaceFormSuccessMessage = document.getElementById('enlaceFormSuccessMessage') as HTMLElement;
  const enlaceSuccessCloseBtn = document.getElementById('enlaceSuccessCloseBtn') as HTMLButtonElement;

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target && target.id === 'btnSugerirEnlace') {
      sugerirEnlaceForm.style.display = 'flex';
      enlaceFormSuccessMessage.style.display = 'none';
      sugerirEnlaceForm.reset();
      sugerirEnlaceDialog.showModal();
    }
  });

  const closeEnlaceForm = () => { sugerirEnlaceDialog.close(); };
  if (closeEnlaceDialogBtn) closeEnlaceDialogBtn.addEventListener('click', closeEnlaceForm);
  if (cancelEnlaceFormBtn) cancelEnlaceFormBtn.addEventListener('click', closeEnlaceForm);
  if (enlaceSuccessCloseBtn) enlaceSuccessCloseBtn.addEventListener('click', closeEnlaceForm);

  sugerirEnlaceDialog.addEventListener('click', (e) => {
    const r = sugerirEnlaceDialog.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
      sugerirEnlaceDialog.close();
    }
  });

  if (sugerirEnlaceForm) {
    sugerirEnlaceForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitEnlaceFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const titulo = (document.getElementById('formEnlaceTitulo') as HTMLInputElement).value.trim();
      const categoria = (document.getElementById('formEnlaceCategoria') as HTMLSelectElement).value;
      const descripcion = (document.getElementById('formEnlaceDescripcion') as HTMLTextAreaElement).value.trim();
      let url = (document.getElementById('formEnlaceUrl') as HTMLInputElement).value.trim();
      if (url && !/^https?:\/\//i.test(url)) url = 'https://' + url;

      if (!supabase) {
        alert('El sistema está operando en modo local/sin conexión. No se pueden procesar sugerencias de nuevos enlaces en este momento.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      try {
        const { error } = await supabase.from('enlaces_ayuda').insert({
          titulo, categoria, descripcion, url, verificado: false
        });
        if (error) throw error;
        sugerirEnlaceForm.style.display = 'none';
        enlaceFormSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando enlace en Supabase:', err);
        alert('Hubo un error al enviar tu sugerencia. Por favor verifica tu conexión e intenta de nuevo.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }
</script>
