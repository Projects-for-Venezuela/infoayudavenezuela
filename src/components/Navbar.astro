---
import SugerirCentroModal from "./SugerirCentroModal.astro";
import SugerirEnlaceModal from "./SugerirEnlaceModal.astro";
import ReportarNecesidadModal from "./ReportarNecesidadModal.astro";
---

<div class="flex h-2" aria-hidden="true">
  <span class="flex-1 bg-yellow"></span>
  <span class="flex-1 bg-blue"></span>
  <span class="flex-1 bg-red"></span>
</div>

<nav class="sticky top-0 z-100 bg-blue text-white shadow-[0_2px_10px_rgba(0,0,0,0.15)]">
  <div class="flex items-center px-5 h-14">
    <a href="/" class="flex-1 text-[0.95rem] font-extrabold no-underline tracking-tight whitespace-nowrap text-white transition-opacity duration-150 hover:opacity-85">Info <span class="text-yellow">Ayuda</span> Venezuela</a>
    <div class="hidden lg:flex items-center justify-center gap-1.5 flex-none">
      <a href="/" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold text-white/80 no-underline whitespace-nowrap transition-colors duration-150 hover:bg-white/10 hover:text-white">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Inicio
      </a>
      <a href="/insumos" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold text-white/80 no-underline whitespace-nowrap transition-colors duration-150 hover:bg-white/10 hover:text-white">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        Insumos
      </a>
      <a href="/donaciones" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold text-white/80 no-underline whitespace-nowrap transition-colors duration-150 hover:bg-white/10 hover:text-white">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M11 14h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"/><path d="m7 20 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"/><path d="m2 15 6 6"/><path d="M19.5 8.5c.7-.7 1.5-1.6 1.5-2.7A2.73 2.73 0 0 0 16 4a2.78 2.78 0 0 0-5 1.8c0 1.2.8 2 1.5 2.8L16 12Z"/></svg>
