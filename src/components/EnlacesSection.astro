---
import "../styles/enlaces.css";

export interface Props {
  enlaces: any[];
}

const { enlaces } = Astro.props;
---

<div class="section-card" style="margin-top: 1.5rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem;">
    <h3 class="section-title" style="margin-bottom: 0;">🔗 Sitios Web y Enlaces de Ayuda</h3>
    <button id="btnSugerirEnlace" class="btn-sugerir-enlace" aria-label="Sugerir nuevo enlace de ayuda">+ Sugerir Sitio Web</button>
  </div>
  <div class="enlaces-grid" id="enlacesGrid">
    {enlaces.map((enlace) => (
      <div class="enlace-card">
        <div class="enlace-header">
          <span class="enlace-cat">{enlace.categoria}</span>
        </div>
        <h4>{enlace.titulo}</h4>
        <p>{enlace.descripcion}</p>
        <a href={enlace.url} target="_blank" rel="noopener noreferrer" class="enlace-btn">
          Visitar Sitio Web &rarr;
        </a>
      </div>
    ))}
  </div>
  <button id="btnVerMasEnlaces" class="btn-ver-mas" style="display: none;">Ver más &darr;</button>
</div>

<div id="enlacesFallbackData" data-enlaces={JSON.stringify(enlaces)} style="display: none;"></div>

<script>
  import { supabase } from "../lib/supabase";

  const fallbackEl = document.getElementById('enlacesFallbackData') as HTMLElement;
  const fallbackData = JSON.parse(fallbackEl?.dataset?.enlaces || '[]');

  let enlaces: any[] = [...fallbackData];
  const enlacesGrid = document.getElementById('enlacesGrid') as HTMLElement;

  function renderEnlaces() {
    if (!enlacesGrid) return;
    const total = enlaces.length;
    enlacesGrid.innerHTML = enlaces.map((e: any) => `
      <div class="enlace-card">
        <div class="enlace-header">
          <span class="enlace-cat">${e.categoria}</span>
        </div>
        <h4>${e.titulo}</h4>
        <p>${e.descripcion}</p>
        <a href="${e.url}" target="_blank" rel="noopener noreferrer" class="enlace-btn">
          Visitar Sitio Web &rarr;
        </a>
      </div>
    `).join("");

    const btnVerMas = document.getElementById('btnVerMasEnlaces') as HTMLButtonElement;
    if (total <= 4) {
      btnVerMas.style.display = 'none';
      return;
    }

    void enlacesGrid.offsetWidth;
    const cols = getComputedStyle(enlacesGrid).gridTemplateColumns.split(' ').length;
    const maxVisible = cols * 2;

    const cards = enlacesGrid.querySelectorAll('.enlace-card');
    cards.forEach((card, i) => {
      if (i >= maxVisible) card.classList.add('hidden');
    });

    enlacesGrid.dataset.maxVisible = String(maxVisible);
    btnVerMas.style.display = '';
    btnVerMas.textContent = 'Ver más ↓';
  }

  const btnVerMas = document.getElementById('btnVerMasEnlaces') as HTMLButtonElement;
  if (btnVerMas) {
    btnVerMas.addEventListener('click', () => {
      const hiddenCards = enlacesGrid.querySelectorAll('.enlace-card.hidden');
      if (hiddenCards.length > 0) {
        hiddenCards.forEach(c => c.classList.remove('hidden'));
        btnVerMas.textContent = 'Ver menos ↑';
      } else {
        const maxVisible = parseInt(enlacesGrid.dataset.maxVisible || '4');
        const cards = enlacesGrid.querySelectorAll('.enlace-card');
        cards.forEach((card, i) => {
          if (i >= maxVisible) card.classList.add('hidden');
        });
        btnVerMas.textContent = 'Ver más ↓';
      }
    });
  }

  async function loadEnlaces() {
    try {
      if (!supabase) throw new Error("Supabase client not initialized");
      const { data, error } = await supabase
        .from('enlaces_ayuda')
        .select('*')
        .eq('verificado', true);
      if (error) throw error;
      if (data && data.length > 0) {
        enlaces = data;
        renderEnlaces();
      }
    } catch (err) {
      console.error("No se pudieron cargar los enlaces de ayuda de Supabase:", err);
    }
  }

  renderEnlaces();
  loadEnlaces();
</script>
