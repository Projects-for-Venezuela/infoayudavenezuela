<div class="flex gap-3 mb-5 w-full">
  <div class="relative flex-[2] min-w-0">
    <label for="searchInput" class="sr-only">Buscar por estado, ciudad, centro o insumos</label>
    <svg class="absolute top-1/2 left-4 -translate-y-1/2 pointer-events-none z-10" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input type="text" id="searchInput" placeholder="Buscar por estado, ciudad, centro o insumos..." aria-label="Buscar por estado, ciudad, centro o insumos"
      class="w-full h-[46px] box-border border-[1.5px] border-border rounded-card font-sans text-sm bg-white outline-none transition-colors duration-200 block px-4 pl-[2.6rem] focus:border-blue focus:shadow-[0_0_0_3px_rgba(0,36,125,0.08)]" />
  </div>
  <div class="flex gap-2 flex-wrap" style="flex:1; min-width:0;">
    <label for="typeSelect" class="sr-only">Filtrar por tipo</label>
    <select id="typeSelect" aria-label="Filtrar por tipo" class="flex-1 min-w-[150px] h-[46px] px-4 cursor-pointer border-[1.5px] border-border rounded-card font-sans text-sm bg-white outline-none transition-colors duration-200 focus:border-blue focus:shadow-[0_0_0_3px_rgba(0,36,125,0.08)]">
      <option value="">Todos los tipos</option>
      <option value="oficial">Refugio Oficial</option>
      <option value="privado">Casa Particular</option>
    </select>
    <label for="citySelect" class="sr-only">Filtrar por ciudad</label>
    <select id="citySelect" aria-label="Filtrar por ciudad" class="flex-1 min-w-[150px] h-[46px] px-4 cursor-pointer border-[1.5px] border-border rounded-card font-sans text-sm bg-white outline-none transition-colors duration-200 focus:border-blue focus:shadow-[0_0_0_3px_rgba(0,36,125,0.08)]">
      <option value="">Todas las ciudades</option>
    </select>
  </div>
</div>