<div class="search-filters">
  <div class="search-box">
    <label for="searchInput" class="sr-only">Buscar por estado, ciudad, centro o insumos</label>
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input type="text" id="searchInput" placeholder="Buscar por estado, ciudad, centro o insumos..." aria-label="Buscar por estado, ciudad, centro o insumos" />
  </div>
<div class="filter-box" style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
    <label for="typeSelect" class="sr-only">Filtrar por tipo</label>
    <select id="typeSelect" aria-label="Filtrar por tipo" style="flex: 1; min-width: 150px;">
      <option value="">Todos los tipos</option>
      <option value="oficial">Refugio Oficial</option>
      <option value="privado">Casa Particular</option>
    </select>
    <label for="citySelect" class="sr-only">Filtrar por ciudad</label>
    <select id="citySelect" aria-label="Filtrar por ciudad" style="flex: 1; min-width: 150px;">
      <option value="">Todas las ciudades</option>
    </select>
  </div>
</div>
