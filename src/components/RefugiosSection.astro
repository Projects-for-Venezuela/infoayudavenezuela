---
import SugerirRefugioModal from "./SugerirRefugioModal.astro";
---
<section class="bg-white border border-border rounded-xl p-4 sm:p-5 mb-4 mt-6 shadow-sm">
  <div class="flex justify-between items-center mb-4 flex-wrap gap-2">
    <h3 class="flex items-center gap-2 text-[0.95rem] font-bold tracking-tight text-text">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue" aria-hidden="true" focusable="false"><path d="M3 21h18"/><path d="M4 21V5a2 2 0 012-2h12a2 2 0 012 2v16"/><path d="M9 21v-4h6v4"/><path d="M9 9h1"/><path d="M14 9h1"/><path d="M9 13h1"/><path d="M14 13h1"/></svg>
      Refugios Disponibles
    </h3>
    <button id="btnSugerirRefugio" type="button" aria-label="Sugerir nuevo refugio" class="inline-flex items-center gap-1 bg-white text-blue border border-border px-3 py-2 rounded-lg text-xs font-semibold cursor-pointer min-h-11 transition-colors duration-150 hover:bg-[#F8F9FB] hover:border-blue">+ Sugerir Refugio</button>
  </div>

  <div id="refugiosSectionGrid" class="grid gap-3 grid-cols-[repeat(auto-fill,minmax(240px,1fr))]">
    <div class="bg-[#F8F9FB] border border-border rounded-lg p-4">
      <p class="text-sm text-muted">Cargando refugios...</p>
    </div>
  </div>

  <a href="/refugios" class="inline-flex items-center justify-center gap-1.5 w-full mt-4 p-2 rounded-lg text-sm font-semibold text-blue no-underline min-h-11 transition-colors duration-150 hover:bg-[#F8F9FB] hover:text-blue-dark">Ver más Refugios &rarr;</a>
</section>

<SugerirRefugioModal />

<script>
  import { getSupabase } from "../lib/supabase";
  import { escapeHtml } from "../lib/escape";

  const grid = document.getElementById('refugiosSectionGrid');

  async function loadRefugiosPreview() {
    if (!grid) return;
    const supabase = await getSupabase();
    if (!supabase) return;
    try {
      const { data, error } = await supabase
        .from('refugios')
        .select('*')
        .eq('verificado', true)
        .order('created_at', { ascending: false })
        .limit(4);

      if (error) throw error;

      if (data && data.length > 0) {
        grid.innerHTML = data.map((r: any) => `
          <div class="flex flex-col gap-2 bg-[#F8F9FB] border border-border rounded-lg p-4">
            <div class="flex justify-between items-start gap-2">
              <span class="text-[0.65rem] font-bold text-blue bg-blue/10 px-1.5 py-0.5 rounded uppercase">${escapeHtml(r.estado)} - ${escapeHtml(r.ciudad)}</span>
              ${r.tipo === 'privado' ? '<span class="shrink-0 text-[0.65rem] font-semibold px-1.5 py-0.5 rounded bg-[#DBEAFE] text-[#1E40AF] border border-[#BFDBFE]">Casa Particular</span>' : ''}
            </div>
            <h4 class="text-sm font-semibold text-text">${escapeHtml(r.nombre)}</h4>
            <p class="text-xs text-muted leading-relaxed">${escapeHtml(r.direccion || 'Sin dirección específica')}</p>
            <p class="text-xs text-blue mt-1"><strong class="font-semibold">Capacidad:</strong> ${escapeHtml(r.capacidad || 'No especificada')}</p>
          </div>
        `).join("");
      } else {
        grid.innerHTML = '<p class="text-sm text-muted p-4">No hay refugios registrados por el momento.</p>';
      }
    } catch (e) {
      console.error(e);
      grid.innerHTML = '<p class="text-sm text-red p-4">No se pudieron cargar los refugios.</p>';
    }
  }

  ("requestIdleCallback" in window
    ? (window as any).requestIdleCallback(loadRefugiosPreview, { timeout: 2000 })
    : setTimeout(loadRefugiosPreview, 200));
</script>
