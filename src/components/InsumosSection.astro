---
import { insumos } from "../data/centros";
---

<div class="section-card" style="margin-top: 1.5rem;">
  <h3 class="section-title">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: sub; margin-right: 4px;" aria-hidden="true" focusable="false"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
    Insumos que se están recibiendo</h3>
  <div class="tags">
    {insumos.map((i) => <span class="tag">{i}</span>)}
  </div>
  <a href="/insumos" class="necesidad-cta" style="margin-top: 0.75rem;">Ver guía completa de insumos &rarr;</a>
</div>
