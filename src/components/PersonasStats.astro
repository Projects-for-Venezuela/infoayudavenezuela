---
---

<section
  class="mb-6 rounded-card border border-border bg-white p-5 sm:p-6 shadow-[0_1px_2px_rgba(16,24,40,0.04)]"
  aria-labelledby="personasStatsTitle"
>
  <h2 id="personasStatsTitle" class="sr-only">Estado de las personas reportadas</h2>

  <div class="flex items-baseline gap-2 flex-wrap">
    <span class="text-[2.5rem] sm:text-5xl font-extrabold text-red leading-none tabular-nums" id="psMissing">—</span>
    <span class="text-sm sm:text-[0.95rem] font-semibold text-text text-balance">personas aún sin localizar</span>
  </div>

  <div class="mt-5">
    <div class="h-2.5 w-full rounded-pill bg-[#F1F5F9] overflow-hidden" aria-hidden="true">
      <div class="h-full rounded-pill bg-green" id="psBar" style="width: 0%"></div>
    </div>
    <p class="mt-2.5 text-[0.82rem] text-muted text-pretty">
      <strong class="font-semibold text-green tabular-nums" id="psFound">—</strong> encontradas de
      {" "}
      <span class="tabular-nums font-medium text-text" id="psTotal">—</span> reportadas
      {" "}
      <span>(<span class="tabular-nums" id="psPct">—</span>% localizadas)</span>
    </p>
  </div>
</section>

<script>
  import { getSupabase } from "../lib/supabase";

  async function loadPersonasStats() {
    const elMissing = document.getElementById("psMissing");
    const elFound = document.getElementById("psFound");
    const elTotal = document.getElementById("psTotal");
    const elPct = document.getElementById("psPct");
    const elBar = document.getElementById("psBar") as HTMLElement | null;
    if (!elMissing || !elFound || !elTotal || !elPct || !elBar) return;

    const supabase = await getSupabase();
    if (!supabase) return;

    try {
      const [totalRes, missingRes, foundRes] = await Promise.all([
        supabase.from("desaparecidos").select("*", { count: "exact", head: true }),
        supabase.from("desaparecidos").select("*", { count: "exact", head: true }).eq("status", "missing"),
        supabase.from("desaparecidos").select("*", { count: "exact", head: true }).eq("status", "found"),
      ]);
      if (totalRes.error || missingRes.error || foundRes.error) {
        throw (totalRes.error || missingRes.error || foundRes.error);
      }

      const total = totalRes.count || 0;
      const missing = missingRes.count || 0;
      const found = foundRes.count || 0;
      const pct = total > 0 ? Math.round((found / total) * 100) : 0;
      const fmt = (n: number) => n.toLocaleString("es-VE");

      elMissing.textContent = fmt(missing);
      elFound.textContent = fmt(found);
      elTotal.textContent = fmt(total);
      elPct.textContent = String(pct);
      elBar.style.width = pct + "%";
    } catch (err) {
      console.error("Error cargando estadísticas de personas:", err);
    }
  }

  ("requestIdleCallback" in window
    ? (window as any).requestIdleCallback(loadPersonasStats, { timeout: 2000 })
    : setTimeout(loadPersonasStats, 200));
</script>
