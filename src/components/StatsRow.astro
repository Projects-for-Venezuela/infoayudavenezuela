---
export interface Props {
  totalCentros: number;
  totalEstados: number;
  totalCiudades: number;
}

const { totalCentros, totalEstados, totalCiudades } = Astro.props;
---

<div class="grid grid-cols-3 gap-3 mb-5">
  <div class="bg-blue/4 border border-blue/20 rounded-card px-2 py-4 text-center transition-colors duration-200 hover:border-blue/40">
    <span class="block text-[1.7rem] font-extrabold text-blue leading-none mb-1.5 tabular-nums" id="statCentros">{totalCentros}</span>
    <span class="text-[0.68rem] font-semibold uppercase tracking-wide text-blue-dark/70">Centros de Acopio</span>
  </div>
  <div class="bg-white border border-border rounded-card px-2 py-4 text-center transition-colors duration-200 hover:border-[#C7CDD8]">
    <span class="block text-2xl font-bold text-text leading-none mb-1.5 tabular-nums" id="statEstados">{totalEstados}</span>
    <span class="text-[0.68rem] font-semibold uppercase tracking-wide text-muted">Estados</span>
  </div>
  <div class="bg-white border border-border rounded-card px-2 py-4 text-center transition-colors duration-200 hover:border-[#C7CDD8]">
    <span class="block text-2xl font-bold text-text leading-none mb-1.5 tabular-nums" id="statCiudades">{totalCiudades}</span>
    <span class="text-[0.68rem] font-semibold uppercase tracking-wide text-muted">Ciudades</span>
  </div>
</div>