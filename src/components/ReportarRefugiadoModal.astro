<dialog id="reportarRefugiadoDialog" aria-labelledby="reportarRefugiadoDialogTitle" class="m-auto w-[90%] max-w-[550px] p-0 border-0 rounded-card bg-white overflow-hidden outline-none shadow-[0_20px_25px_-5px_rgba(0,0,0,0.1),0_10px_10px_-5px_rgba(0,0,0,0.04)] backdrop:bg-[rgba(15,23,42,0.65)] backdrop:backdrop-blur-xs backdrop:animate-[fadeIn_0.2s_ease-out]">
  <div class="p-5 sm:p-6 max-h-[90vh] overflow-y-auto">
    <div class="flex justify-between items-center mb-4 pb-3 border-b border-border">
      <h2 id="reportarRefugiadoDialogTitle" class="text-[1.2rem] font-bold text-blue-dark tracking-tight">Registrar Persona en Refugio</h2>
      <button id="closeRefugiadoDialogBtn" type="button" aria-label="Cerrar modal" class="flex items-center justify-center min-w-11 min-h-11 -mr-2 bg-transparent border-0 text-2xl leading-none text-muted cursor-pointer transition-colors duration-150 hover:text-red">&times;</button>
    </div>

    <form id="reportarRefugiadoForm" class="flex flex-col gap-3">
      <p class="text-[0.78rem] text-muted -mb-0.5 text-pretty">Registra a una persona que se encuentra en un refugio para que sus familiares puedan saber que está a salvo. El registro será verificado antes de publicarse.</p>

      <div class="flex flex-col gap-1">
        <label for="formRefugiadoNombre" class="text-[0.78rem] font-semibold text-text">Nombre Completo *</label>
        <input type="text" id="formRefugiadoNombre" placeholder="Ej. Juan Pérez" required class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 focus:border-blue" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="flex flex-col gap-1">
          <label for="formRefugiadoCedula" class="text-[0.78rem] font-semibold text-text">Cédula de Identidad</label>
          <input type="text" id="formRefugiadoCedula" placeholder="Ej. 12345678" class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 focus:border-blue" />
        </div>
        <div class="flex flex-col gap-1">
          <label for="formRefugiadoTelefono" class="text-[0.78rem] font-semibold text-text">Número de Teléfono</label>
          <input type="text" id="formRefugiadoTelefono" placeholder="Ej. 0424-1234567" class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 focus:border-blue" />
        </div>
      </div>

      <div class="flex flex-col gap-1">
        <label for="formRefugiadoRefugio" class="text-[0.78rem] font-semibold text-text">Refugio en el que se encuentra *</label>
        <select id="formRefugiadoRefugio" required class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none cursor-pointer transition-colors duration-200 focus:border-blue">
          <option value="">Cargando refugios...</option>
        </select>
        <p class="text-[0.78rem] text-muted mt-0.5">Si el refugio no está en la lista, asegúrate de <a href="/refugios" class="text-blue underline">sugerirlo primero</a>.</p>
      </div>

      <div class="flex flex-col gap-1">
        <label for="formRefugiadoSalud" class="text-[0.78rem] font-semibold text-text">Estado de Salud</label>
        <input type="text" id="formRefugiadoSalud" placeholder="Ej. Ileso, Estable, Herido Leve" class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 focus:border-blue" />
      </div>

      <div class="flex justify-end gap-2 mt-2 pt-4 border-t border-border">
        <button type="button" id="cancelRefugiadoFormBtn" class="min-h-11 px-5 py-2 rounded-lg text-[0.85rem] font-semibold cursor-pointer bg-white text-text border border-border transition-colors duration-150 hover:bg-[#F1F5F9] hover:border-[#CBD5E1]">Cancelar</button>
        <button type="submit" id="submitRefugiadoFormBtn" class="min-h-11 px-5 py-2 rounded-lg text-[0.85rem] font-semibold cursor-pointer bg-blue text-white border border-transparent transition-colors duration-150 hover:bg-blue-dark">Registrar Persona</button>
      </div>
    </form>

    <div id="formRefugiadoSuccessMessage" class="flex-col items-center text-center py-8 px-4 gap-3" style="display: none;">
      <div class="w-12 h-12 rounded-full bg-[#DCFCE7] text-[#15803D] flex items-center justify-center text-2xl font-bold">✓</div>
      <h3 class="text-[1.2rem] font-bold text-[#15803D] tracking-tight">¡Registro Enviado!</h3>
      <p class="text-[0.86rem] text-muted leading-relaxed mb-2 text-pretty">Muchas gracias. Los datos de la persona han sido registrados y, tras ser verificados por un moderador, sus familiares podrán encontrarla en nuestro buscador.</p>
      <button id="successRefugiadoCloseBtn" class="min-h-11 px-5 py-2 rounded-lg text-[0.85rem] font-semibold cursor-pointer bg-blue text-white border border-transparent transition-colors duration-150 hover:bg-blue-dark">Entendido</button>
    </div>
  </div>
</dialog>

<script>
  import { getSupabase } from "../lib/supabase";
  import { escapeHtml } from "../lib/escape";

  const reportarRefugiadoDialog = document.getElementById('reportarRefugiadoDialog') as HTMLDialogElement;
  const btnReportarRefugiado = document.getElementById('btnReportarRefugiado') as HTMLButtonElement;
  const closeRefugiadoDialogBtn = document.getElementById('closeRefugiadoDialogBtn') as HTMLButtonElement;
  const cancelRefugiadoFormBtn = document.getElementById('cancelRefugiadoFormBtn') as HTMLButtonElement;
  const reportarRefugiadoForm = document.getElementById('reportarRefugiadoForm') as HTMLFormElement;
  const formRefugiadoSuccessMessage = document.getElementById('formRefugiadoSuccessMessage') as HTMLElement;
  const successRefugiadoCloseBtn = document.getElementById('successRefugiadoCloseBtn') as HTMLButtonElement;
  const formRefugiadoRefugioSelect = document.getElementById('formRefugiadoRefugio') as HTMLSelectElement;

  async function loadRefugiosForSelect() {
    const supabase = await getSupabase();
    if (!supabase) return;
    const { data, error } = await supabase.from('refugios').select('id, nombre, ciudad, estado').eq('verificado', true).order('nombre');

    if (!error && data) {
      if (data.length === 0) {
          formRefugiadoRefugioSelect.innerHTML = '<option value="">No hay refugios verificados aún</option>';
          return;
      }
      let optionsHtml = '<option value="">Selecciona un refugio...</option>';
      data.forEach((refugio: any) => {
        optionsHtml += `<option value="${escapeHtml(refugio.id)}">${escapeHtml(refugio.nombre)} (${escapeHtml(refugio.ciudad)}, ${escapeHtml(refugio.estado)})</option>`;
      });
      formRefugiadoRefugioSelect.innerHTML = optionsHtml;
    } else {
      formRefugiadoRefugioSelect.innerHTML = '<option value="">Error cargando refugios</option>';
    }
  }

  if (btnReportarRefugiado) {
    btnReportarRefugiado.addEventListener('click', () => {
      reportarRefugiadoForm.style.display = 'flex';
      formRefugiadoSuccessMessage.style.display = 'none';
      reportarRefugiadoForm.reset();
      loadRefugiosForSelect();
      reportarRefugiadoDialog.showModal();
    });
  }

  const closeRefugiadoForm = () => { reportarRefugiadoDialog.close(); };
  if (closeRefugiadoDialogBtn) closeRefugiadoDialogBtn.addEventListener('click', closeRefugiadoForm);
  if (cancelRefugiadoFormBtn) cancelRefugiadoFormBtn.addEventListener('click', closeRefugiadoForm);
  if (successRefugiadoCloseBtn) successRefugiadoCloseBtn.addEventListener('click', closeRefugiadoForm);

  reportarRefugiadoDialog.addEventListener('click', (e) => {
    const r = reportarRefugiadoDialog.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
      reportarRefugiadoDialog.close();
    }
  });

  if (reportarRefugiadoForm) {
    reportarRefugiadoForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitRefugiadoFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const nombre_completo = (document.getElementById('formRefugiadoNombre') as HTMLInputElement).value.trim();
      const cedula = (document.getElementById('formRefugiadoCedula') as HTMLInputElement).value.trim() || null;
      const telefono = (document.getElementById('formRefugiadoTelefono') as HTMLInputElement).value.trim() || null;
      const refugio_id = formRefugiadoRefugioSelect.value;
      const estado_salud = (document.getElementById('formRefugiadoSalud') as HTMLInputElement).value.trim() || null;

      const supabase = await getSupabase();
      if (!supabase) {
        alert('El sistema está operando en modo local/sin conexión.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      try {
        const { error } = await supabase.from('refugiados').insert({
          nombre_completo, cedula, telefono, refugio_id, estado_salud, verificado: false
        });
        if (error) throw error;
        reportarRefugiadoForm.style.display = 'none';
        formRefugiadoSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando refugiado en Supabase:', err);
        alert('Hubo un error al enviar el registro.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }
</script>
