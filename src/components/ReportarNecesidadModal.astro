<dialog id="reportarNecesidadDialog" class="modal-dialog modal-dialog--alerta" aria-labelledby="reportarDialogTitle">
  <div class="modal-content">
    <div class="modal-header">
<div class="modal-header-left">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <h2 id="reportarDialogTitle">Reportar Necesidad Urgente</h2>
      </div>
      <button id="closeNecesidadDialogBtn" class="close-btn" type="button" aria-label="Cerrar modal">&times;</button>
    </div>

    <form id="reportarNecesidadForm" class="modal-form">
      <p class="form-help">Reporta un lugar, refugio o comunidad que necesite ayuda urgente. Los datos se publicarán tras ser verificados por un moderador.</p>

      <div class="alert-box alert-box--info">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span>Para reportar fuera de Venezuela, selecciona <strong>"Internacional"</strong> como estado.</span>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="necFormEstado">Estado *</label>
          <select id="necFormEstado" required>
            <option value="">Selecciona</option>
            <option value="Internacional">🌎 Internacional</option>
            <optgroup label="Venezuela">
              <option value="Distrito Capital">Distrito Capital</option>
              <option value="Amazonas">Amazonas</option>
              <option value="Anzoátegui">Anzoátegui</option>
              <option value="Apure">Apure</option>
              <option value="Aragua">Aragua</option>
              <option value="Barinas">Barinas</option>
              <option value="Bolívar">Bolívar</option>
              <option value="Carabobo">Carabobo</option>
              <option value="Cojedes">Cojedes</option>
              <option value="Delta Amacuro">Delta Amacuro</option>
              <option value="Falcón">Falcón</option>
              <option value="Guárico">Guárico</option>
              <option value="La Guaira">La Guaira</option>
              <option value="Lara">Lara</option>
              <option value="Mérida">Mérida</option>
              <option value="Miranda">Miranda</option>
              <option value="Monagas">Monagas</option>
              <option value="Nueva Esparta">Nueva Esparta</option>
              <option value="Portuguesa">Portuguesa</option>
              <option value="Sucre">Sucre</option>
              <option value="Táchira">Táchira</option>
              <option value="Trujillo">Trujillo</option>
              <option value="Yaracuy">Yaracuy</option>
              <option value="Zulia">Zulia</option>
            </optgroup>
          </select>
          <span class="form-error" id="necErrorEstado"></span>
        </div>
        <div class="form-group" id="necFormPaisGroup" style="display: none;">
          <label for="necFormPais">País *</label>
          <input type="text" id="necFormPais" list="paises-list" placeholder="Ej. Colombia, Perú..." maxlength="60" autocomplete="off" />
          <datalist id="paises-list">
            <option value="Argentina"></option><option value="Brasil"></option><option value="Chile"></option><option value="Colombia"></option><option value="Ecuador"></option><option value="México"></option><option value="Panamá"></option><option value="Perú"></option><option value="República Dominicana"></option><option value="Estados Unidos"></option><option value="España"></option><option value="Otro"></option>
          </datalist>
          <span class="form-error" id="necErrorPais"></span>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="necFormCiudad">Ciudad / Municipio *</label>
          <input type="text" id="necFormCiudad" placeholder="Ej. Barquisimeto, Macuto" required />
          <span class="form-error" id="necErrorCiudad"></span>
        </div>
        <div class="form-group">
          <label for="necFormLugar">Lugar / Refugio *</label>
          <input type="text" id="necFormLugar" placeholder="Ej. Refugio La Paz, Centro Comunitario" required />
          <span class="form-error" id="necErrorLugar"></span>
        </div>
      </div>

      <div class="form-group">
        <label for="necFormDireccion">Dirección</label>
        <textarea id="necFormDireccion" rows="2" placeholder="Dirección exacta o punto de referencia del lugar..."></textarea>
      </div>

      <div class="form-group">
        <label>Categoría de la necesidad *</label>
        <div class="nec-categorias" id="necCategorias">
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Agua/Alimentos" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            Agua/Alimentos
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Medicinas" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            Medicinas
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Ropa/Cobijas" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18"/><path d="M12 6v4"/></svg>
            Ropa/Cobijas
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Higiene" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><line x1="3.6" y1="7.2" x2="20.4" y2="7.2"/><line x1="3.6" y1="16.8" x2="20.4" y2="16.8"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
            Higiene
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Herramientas" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
            Herramientas
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Rescate" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            Rescate
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Albergue" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M3 21h18"/><path d="M4 21V5a2 2 0 012-2h12a2 2 0 012 2v16"/><path d="M9 21v-4h6v4"/></svg>
            Albergue
          </label>
          <label class="nec-cat-item">
            <input type="checkbox" name="necCat" value="Otro" />
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
            Otro
          </label>
        </div>
        <span class="form-error" id="necErrorCategoria"></span>
      </div>

      <div class="form-group">
        <label for="necFormNecesitan">¿Qué necesitan URGENTE? *</label>
        <textarea id="necFormNecesitan" rows="3" placeholder="Describe detalladamente lo que más necesitan: medicinas específicas, agua potable, alimentos no perecederos, carpas, frazadas, etc..." required></textarea>
        <span class="form-error" id="necErrorNecesitan"></span>
      </div>

      <div class="form-group">
        <label for="necFormContacto">Contacto</label>
        <input type="text" id="necFormContacto" placeholder="Teléfono, Instagram, email..." />
      </div>

      <div class="form-actions">
        <button type="button" id="cancelNecFormBtn" class="btn btn-secondary">Cancelar</button>
        <button type="submit" id="submitNecFormBtn" class="btn btn-primary btn-danger">Enviar Reporte</button>
      </div>
    </form>

    <div id="necFormSuccessMessage" class="form-success-msg" style="display: none;">
      <div class="success-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <h3>¡Reporte Enviado!</h3>
      <p>Gracias por reportar. Los datos han sido registrados de forma segura y se publicarán tan pronto sean verificados por nuestro equipo.</p>
      <button id="necSuccessCloseBtn" class="btn btn-primary">Entendido</button>
    </div>
  </div>
</dialog>