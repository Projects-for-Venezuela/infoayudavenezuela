---

<header class="relative overflow-hidden bg-linear-to-br from-blue via-blue-dark to-[#001030] text-white px-5 py-12 sm:px-6 sm:py-16 md:py-20">
  <div class="pointer-events-none absolute -top-6 right-2 sm:right-8 flex gap-1.5 text-yellow/15 select-none" aria-hidden="true">
    <span class="text-2xl">&#9733;</span><span class="text-3xl">&#9733;</span><span class="text-4xl">&#9733;</span><span class="text-3xl">&#9733;</span><span class="text-2xl">&#9733;</span>
  </div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1 bg-linear-to-r from-yellow via-blue to-red" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto flex max-w-2xl flex-col items-center text-center">
    <span class="inline-flex items-center gap-2 text-[0.68rem] sm:text-[0.7rem] font-bold uppercase tracking-[0.14em] text-yellow mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-yellow"></span>
      Directorio de ayuda humanitaria
    </span>
    <h1 class="text-[1.85rem] sm:text-4xl md:text-[2.85rem] font-extrabold tracking-tight leading-[1.08] text-balance mb-4">
      Info <span class="text-yellow">Ayuda</span> Venezuela
    </h1>
    <p class="text-sm sm:text-[0.95rem] text-white/75 max-w-[480px] mx-auto mb-8 leading-relaxed text-balance">
      Centros de acopio, refugios y números de emergencia para los afectados por el sismo del <strong class="text-yellow font-semibold whitespace-nowrap">24 de junio de 2026</strong>.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto justify-center">
      <a href="#gridTitle" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-sm font-bold bg-yellow text-blue-dark border-2 border-gold transition-[background-color,transform,box-shadow] duration-150 hover:bg-[#F5C200] hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(255,204,0,0.3)] min-h-12 select-none">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        Buscar centros de acopio
      </a>
      <a href="/emergencia" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-sm font-bold bg-white/10 text-white border-2 border-white/25 transition-[background-color,border-color,transform] duration-150 hover:bg-white/20 hover:border-white/40 hover:-translate-y-0.5 min-h-12 select-none">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        Números de emergencia
      </a>
    </div>
  </div>
</header>
