<dialog id="sugerirEnlaceDialog" aria-labelledby="sugerirEnlaceTitle" class="m-auto w-[90%] max-w-[550px] p-0 border-0 rounded-card bg-white overflow-hidden outline-none shadow-[0_20px_25px_-5px_rgba(0,0,0,0.1),0_10px_10px_-5px_rgba(0,0,0,0.04)] backdrop:bg-[rgba(15,23,42,0.65)] backdrop:backdrop-blur-xs backdrop:animate-[fadeIn_0.2s_ease-out]">
  <div class="p-5 sm:p-6 max-h-[90vh] overflow-y-auto">
    <div class="flex justify-between items-center mb-4 pb-3 border-b border-border">
      <h2 id="sugerirEnlaceTitle" class="text-[1.2rem] font-bold text-blue-dark tracking-tight">Sugerir Sitio de Ayuda</h2>
      <button id="closeEnlaceDialogBtn" type="button" aria-label="Cerrar modal" class="flex items-center justify-center min-w-11 min-h-11 -mr-2 bg-transparent border-0 text-2xl leading-none text-muted cursor-pointer transition-colors duration-150 hover:text-red">&times;</button>
    </div>

    <form id="sugerirEnlaceForm" class="flex flex-col gap-3">
      <p class="text-[0.78rem] text-muted -mb-0.5 text-pretty">Sugiere un sitio web, portal o recurso de ayuda. Se publicará una vez sea verificado.</p>

      <div class="flex flex-col gap-1">
        <label for="formEnlaceTitulo" class="text-[0.78rem] font-semibold text-text">Nombre del Sitio / Organización *</label>
        <input type="text" id="formEnlaceTitulo" placeholder="Ej. Cruz Roja Venezolana o Psicólogos sin Fronteras" required maxlength="120" class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 focus:border-blue" />
      </div>

      <div class="flex flex-col gap-1">
        <label for="formEnlaceCategoria" class="text-[0.78rem] font-semibold text-text">Categoría *</label>
        <select id="formEnlaceCategoria" required class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none cursor-pointer transition-colors duration-200 focus:border-blue">
          <option value="">Selecciona una categoría</option>
          <option value="Salud / Asistencia">Salud / Asistencia</option>
          <option value="Salud Mental">Salud Mental</option>
          <option value="Donaciones">Donaciones</option>
          <option value="Oficial">Oficial</option>
          <option value="Otros">Otros</option>
        </select>
      </div>

      <div class="flex flex-col gap-1">
        <label for="formEnlaceDescripcion" class="text-[0.78rem] font-semibold text-text">Descripción del Servicio / Ayuda *</label>
        <textarea id="formEnlaceDescripcion" rows="3" maxlength="300" placeholder="Describe brevemente qué ayuda ofrece este sitio..." required class="w-full px-3 py-2 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 resize-y focus:border-blue"></textarea>
      </div>

      <div class="flex flex-col gap-1">
        <label for="formEnlaceUrl" class="text-[0.78rem] font-semibold text-text">Dirección Web (URL) *</label>
        <input type="url" id="formEnlaceUrl" placeholder="Ej. https://cruzrojavenezolana.org" required maxlength="300" pattern="^https?://.+" title="La URL debe empezar con http:// o https://" class="w-full px-3 py-2.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-lg outline-none transition-colors duration-200 focus:border-blue" />
      </div>

      <div class="flex justify-end gap-2 mt-2 pt-4 border-t border-border">
        <button type="button" id="cancelEnlaceFormBtn" class="min-h-11 px-5 py-2 rounded-lg text-[0.85rem] font-semibold cursor-pointer bg-white text-text border border-border transition-colors duration-150 hover:bg-[#F1F5F9] hover:border-[#CBD5E1]">Cancelar</button>
        <button type="submit" id="submitEnlaceFormBtn" class="min-h-11 px-5 py-2 rounded-lg text-[0.85rem] font-semibold cursor-pointer bg-blue text-white border border-transparent transition-colors duration-150 hover:bg-blue-dark">Enviar Sugerencia</button>
      </div>
    </form>

    <div id="enlaceFormSuccessMessage" class="flex-col items-center text-center py-8 px-4 gap-3" style="display: none;">
      <div class="w-12 h-12 rounded-full bg-[#DCFCE7] text-[#15803D] flex items-center justify-center text-2xl font-bold">✓</div>
      <h3 class="text-[1.2rem] font-bold text-[#15803D] tracking-tight">¡Sugerencia de Enlace Enviada!</h3>
      <p class="text-[0.86rem] text-muted leading-relaxed mb-2 text-pretty">Gracias por registrar este recurso de ayuda. Será publicado tras ser verificado por el equipo de moderación.</p>
      <button id="enlaceSuccessCloseBtn" class="min-h-11 px-5 py-2 rounded-lg text-[0.85rem] font-semibold cursor-pointer bg-blue text-white border border-transparent transition-colors duration-150 hover:bg-blue-dark">Entendido</button>
    </div>
  </div>
</dialog>
