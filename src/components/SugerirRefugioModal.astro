<dialog id="sugerirRefugioDialog" class="modal-dialog" aria-labelledby="sugerirRefugioDialogTitle">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="sugerirRefugioDialogTitle">Sugerir Refugio</h2>
      <button id="closeRefugioDialogBtn" class="close-btn" aria-label="Cerrar modal">&times;</button>
    </div>
    <form id="sugerirRefugioForm" class="modal-form">
      <p class="form-help">Ingresa los datos del refugio. Se publicará en vivo una vez sea verificado.</p>

      <div class="alert-box" style="margin-bottom: 1rem; padding: 0.6rem; border-radius: 6px; font-size: 0.8rem;">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink: 0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>Para agregar refugios en <strong>otros países</strong>, selecciona <strong>"Internacional"</strong> en la lista de Estados.</span>
      </div>

      <div class="form-group">
        <label for="formRefugioEstado">Estado *</label>
        <select id="formRefugioEstado" required>
          <option value="">Selecciona un estado</option>
          <option value="Internacional">Internacional</option>
          <option value="Distrito Capital">Distrito Capital</option>
          <option value="Miranda">Miranda</option>
          <option value="La Guaira">La Guaira</option>
          <option value="Aragua">Aragua</option>
          <option value="Carabobo">Carabobo</option>
          <option value="Lara">Lara</option>
          <option value="Sucre">Sucre</option>
          <option value="Nueva Esparta">Nueva Esparta</option>
          <option value="Anzoátegui">Anzoátegui</option>
          <option value="Bolívar">Bolívar</option>
          <option value="Barinas">Barinas</option>
          <option value="Monagas">Monagas</option>
          <option value="Yaracuy">Yaracuy</option>
          <option value="Zulia">Zulia</option>
          <option value="Mérida">Mérida</option>
          <option value="Táchira">Táchira</option>
          <option value="Trujillo">Trujillo</option>
          <option value="Falcón">Falcón</option>
          <option value="Cojedes">Cojedes</option>
          <option value="Portuguesa">Portuguesa</option>
          <option value="Guárico">Guárico</option>
          <option value="Apure">Apure</option>
          <option value="Delta Amacuro">Delta Amacuro</option>
          <option value="Amazonas">Amazonas</option>
        </select>
      </div>

      <div class="form-group" id="formRefugioPaisGroup" style="display: none;">
        <label for="formRefugioPais">País *</label>
        <input type="text" id="formRefugioPais" list="paises-list" placeholder="Selecciona o escribe un país" maxlength="60" autocomplete="off" />
        <datalist id="paises-list">
          <option value="Afganistán"></option><option value="Albania"></option><option value="Alemania"></option><option value="Andorra"></option><option value="Angola"></option><option value="Antigua y Barbuda"></option><option value="Arabia Saudita"></option><option value="Argelia"></option><option value="Argentina"></option><option value="Armenia"></option><option value="Australia"></option><option value="Austria"></option><option value="Azerbaiyán"></option><option value="Bahamas"></option><option value="Bangladés"></option><option value="Barbados"></option><option value="Baréin"></option><option value="Bélgica"></option><option value="Belice"></option><option value="Benín"></option><option value="Bielorrusia"></option><option value="Birmania"></option><option value="Bolivia"></option><option value="Bosnia y Herzegovina"></option><option value="Botsuana"></option><option value="Brasil"></option><option value="Brunéi"></option><option value="Bulgaria"></option><option value="Burkina Faso"></option><option value="Burundi"></option><option value="Bután"></option><option value="Cabo Verde"></option><option value="Camboya"></option><option value="Camerún"></option><option value="Canadá"></option><option value="Catar"></option><option value="Chad"></option><option value="Chile"></option><option value="China"></option><option value="Chipre"></option><option value="Ciudad del Vaticano"></option><option value="Colombia"></option><option value="Comoras"></option><option value="Corea del Norte"></option><option value="Corea del Sur"></option><option value="Costa de Marfil"></option><option value="Costa Rica"></option><option value="Croacia"></option><option value="Cuba"></option><option value="Dinamarca"></option><option value="Dominica"></option><option value="Ecuador"></option><option value="Egipto"></option><option value="El Salvador"></option><option value="Emiratos Árabes Unidos"></option><option value="Eritrea"></option><option value="Eslovaquia"></option><option value="Eslovenia"></option><option value="España"></option><option value="Estados Unidos"></option><option value="Estonia"></option><option value="Etiopía"></option><option value="Filipinas"></option><option value="Finlandia"></option><option value="Fiyi"></option><option value="Francia"></option><option value="Gabón"></option><option value="Gambia"></option><option value="Georgia"></option><option value="Ghana"></option><option value="Granada"></option><option value="Grecia"></option><option value="Guatemala"></option><option value="Guyana"></option><option value="Guinea"></option><option value="Guinea Ecuatorial"></option><option value="Guinea-Bisáu"></option><option value="Haití"></option><option value="Honduras"></option><option value="Hungría"></option><option value="India"></option><option value="Indonesia"></option><option value="Irak"></option><option value="Irán"></option><option value="Irlanda"></option><option value="Islandia"></option><option value="Islas Marshall"></option><option value="Islas Salomón"></option><option value="Israel"></option><option value="Italia"></option><option value="Jamaica"></option><option value="Japón"></option><option value="Jordania"></option><option value="Kazajistán"></option><option value="Kenia"></option><option value="Kirguistán"></option><option value="Kiribati"></option><option value="Kuwait"></option><option value="Laos"></option><option value="Lesoto"></option><option value="Letonia"></option><option value="Líbano"></option><option value="Liberia"></option><option value="Libia"></option><option value="Liechtenstein"></option><option value="Lituania"></option><option value="Luxemburgo"></option><option value="Macedonia del Norte"></option><option value="Madagascar"></option><option value="Malasia"></option><option value="Malaui"></option><option value="Maldivas"></option><option value="Malí"></option><option value="Malta"></option><option value="Marruecos"></option><option value="Mauricio"></option><option value="Mauritania"></option><option value="México"></option><option value="Micronesia"></option><option value="Moldavia"></option><option value="Mónaco"></option><option value="Mongolia"></option><option value="Montenegro"></option><option value="Mozambique"></option><option value="Namibia"></option><option value="Nauru"></option><option value="Nepal"></option><option value="Nicaragua"></option><option value="Níger"></option><option value="Nigeria"></option><option value="Noruega"></option><option value="Nueva Zelanda"></option><option value="Omán"></option><option value="Países Bajos"></option><option value="Pakistán"></option><option value="Palaos"></option><option value="Panamá"></option><option value="Papúa Nueva Guinea"></option><option value="Paraguay"></option><option value="Perú"></option><option value="Polonia"></option><option value="Portugal"></option><option value="Reino Unido"></option><option value="República Centroafricana"></option><option value="República Checa"></option><option value="República del Congo"></option><option value="República Democrática del Congo"></option><option value="República Dominicana"></option><option value="Ruanda"></option><option value="Rumania"></option><option value="Rusia"></option><option value="Samoa"></option><option value="San Cristóbal y Nieves"></option><option value="San Marino"></option><option value="San Vicente y las Granadinas"></option><option value="Santa Lucía"></option><option value="Santo Tomé y Príncipe"></option><option value="Senegal"></option><option value="Serbia"></option><option value="Seychelles"></option><option value="Sierra Leona"></option><option value="Singapur"></option><option value="Siria"></option><option value="Somalia"></option><option value="Sri Lanka"></option><option value="Suazilandia"></option><option value="Sudáfrica"></option><option value="Sudán"></option><option value="Sudán del Sur"></option><option value="Suecia"></option><option value="Suiza"></option><option value="Surinam"></option><option value="Tailandia"></option><option value="Tanzania"></option><option value="Tayikistán"></option><option value="Timor Oriental"></option><option value="Togo"></option><option value="Tonga"></option><option value="Trinidad y Tobago"></option><option value="Túnez"></option><option value="Turkmenistán"></option><option value="Turquía"></option><option value="Tuvalu"></option><option value="Ucrania"></option><option value="Uganda"></option><option value="Uruguay"></option><option value="Uzbekistán"></option><option value="Vanuatu"></option><option value="Vietnam"></option><option value="Yemen"></option><option value="Yibuti"></option><option value="Zambia"></option><option value="Zimbabue"></option>
        </datalist>
      </div>

      <div class="form-group">
        <label for="formRefugioTipo">Tipo de Ayuda / Refugio *</label>
        <select id="formRefugioTipo" required>
          <option value="oficial">Refugio Masivo / Centro Oficial</option>
          <option value="privado">Casa Particular / Privada</option>
        </select>
      </div>

      <div class="form-group">
        <label for="formRefugioCiudad">Ciudad *</label>
        <input type="text" id="formRefugioCiudad" placeholder="Ej. Barquisimeto, Altamira" required maxlength="60" />
      </div>

      <div class="form-group">
        <label for="formRefugioNombre">Nombre del Refugio *</label>
        <input type="text" id="formRefugioNombre" placeholder="Ej. Polideportivo o Escuela Municipal" required />
      </div>

      <div class="form-group">
        <label for="formRefugioDireccion">Dirección Completa</label>
        <textarea id="formRefugioDireccion" rows="2" placeholder="Dirección exacta del refugio..."></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="formRefugioContacto">Contacto / Teléfono</label>
          <input type="text" id="formRefugioContacto" placeholder="Ej. 0424-1234567" />
        </div>
        <div class="form-group">
          <label for="formRefugioCapacidad">Capacidad Aproximada</label>
          <input type="text" id="formRefugioCapacidad" placeholder="Ej. 50 personas, 20 familias" />
        </div>
      </div>

      <div class="form-group">
        <label for="formRefugioAcepta">¿Qué insumos / donaciones aceptan? (Opcional)</label>
        <input type="text" id="formRefugioAcepta" placeholder="Ej. Colchones, Agua, Ropa" />
      </div>

      <div class="form-group">
        <label for="formRefugioNecesitan">¿Qué necesitan URGENTE? (Opcional)</label>
        <input type="text" id="formRefugioNecesitan" placeholder="Ej. Fórmulas, Pañales, Medicinas" />
      </div>

      <div class="form-actions">
        <button type="button" id="cancelRefugioFormBtn" class="btn btn-secondary">Cancelar</button>
        <button type="submit" id="submitRefugioFormBtn" class="btn btn-primary">Enviar Sugerencia</button>
      </div>
    </form>

    <div id="formRefugioSuccessMessage" class="form-success-msg" style="display: none;">
      <div class="success-icon">✓</div>
      <h3>¡Sugerencia Enviada!</h3>
      <p>Muchas gracias por tu valioso aporte para ayudar a los afectados. Los datos han sido registrados de forma segura y se publicarán tan pronto sean verificados por un moderador.</p>
      <button id="successRefugioCloseBtn" class="btn btn-primary">Entendido</button>
    </div>
  </div>
</dialog>
<script>
  import { supabase } from "../lib/supabase";

  const sugerirRefugioDialog = document.getElementById('sugerirRefugioDialog') as HTMLDialogElement;
  const btnSugerirRefugio = document.getElementById('btnSugerirRefugio') as HTMLButtonElement;
  const closeRefugioDialogBtn = document.getElementById('closeRefugioDialogBtn') as HTMLButtonElement;
  const cancelRefugioFormBtn = document.getElementById('cancelRefugioFormBtn') as HTMLButtonElement;
  const sugerirRefugioForm = document.getElementById('sugerirRefugioForm') as HTMLFormElement;
  const formRefugioSuccessMessage = document.getElementById('formRefugioSuccessMessage') as HTMLElement;
  const successRefugioCloseBtn = document.getElementById('successRefugioCloseBtn') as HTMLButtonElement;

  if (btnSugerirRefugio) {
    btnSugerirRefugio.addEventListener('click', () => {
      sugerirRefugioForm.style.display = 'flex';
      formRefugioSuccessMessage.style.display = 'none';
      sugerirRefugioForm.reset();
      document.getElementById('formRefugioPaisGroup')!.style.display = 'none';
      (document.getElementById('formRefugioPais') as HTMLInputElement).required = false;
      sugerirRefugioDialog.showModal();
    });
  }

  const formRefugioEstado = document.getElementById('formRefugioEstado') as HTMLSelectElement;
  if (formRefugioEstado) {
    formRefugioEstado.addEventListener('change', () => {
      const formPaisGroup = document.getElementById('formRefugioPaisGroup') as HTMLElement;
      const formPais = document.getElementById('formRefugioPais') as HTMLInputElement;
      if (formRefugioEstado.value === 'Internacional') {
        formPaisGroup.style.display = 'flex';
        formPais.required = true;
      } else {
        formPaisGroup.style.display = 'none';
        formPais.required = false;
        formPais.value = '';
      }
    });
  }

  const closeRefugioForm = () => { sugerirRefugioDialog.close(); };
  if (closeRefugioDialogBtn) closeRefugioDialogBtn.addEventListener('click', closeRefugioForm);
  if (cancelRefugioFormBtn) cancelRefugioFormBtn.addEventListener('click', closeRefugioForm);
  if (successRefugioCloseBtn) successRefugioCloseBtn.addEventListener('click', closeRefugioForm);

  sugerirRefugioDialog.addEventListener('click', (e) => {
    const r = sugerirRefugioDialog.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
      sugerirRefugioDialog.close();
    }
  });

  if (sugerirRefugioForm) {
    sugerirRefugioForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitRefugioFormBtn') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const estado = (document.getElementById('formRefugioEstado') as HTMLSelectElement).value;
      const tipo = (document.getElementById('formRefugioTipo') as HTMLSelectElement).value;
      let ciudad = (document.getElementById('formRefugioCiudad') as HTMLInputElement).value.trim();
      const pais = (document.getElementById('formRefugioPais') as HTMLInputElement).value.trim();
      if (estado === 'Internacional' && pais) {
        ciudad = ciudad + ', ' + pais;
      }
      const nombre = (document.getElementById('formRefugioNombre') as HTMLInputElement).value.trim();
      const direccion = (document.getElementById('formRefugioDireccion') as HTMLTextAreaElement).value.trim() || null;
      const contacto = (document.getElementById('formRefugioContacto') as HTMLInputElement).value.trim() || null;
      const capacidad = (document.getElementById('formRefugioCapacidad') as HTMLInputElement).value.trim() || null;
      const acepta_raw = (document.getElementById('formRefugioAcepta') as HTMLInputElement).value.trim();
      const necesitan_raw = (document.getElementById('formRefugioNecesitan') as HTMLInputElement).value.trim();

      const acepta = acepta_raw ? acepta_raw.split(',').map(s => s.trim()).filter(Boolean) : [];
      const necesitan = necesitan_raw ? necesitan_raw.split(',').map(s => s.trim()).filter(Boolean) : [];

      if (!supabase) {
        alert('El sistema est\u00E1 operando en modo local/sin conexi\u00F3n.');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        return;
      }

      try {
        const { error } = await supabase.from('refugios').insert({
          estado, tipo, ciudad, nombre, direccion, contacto, capacidad, acepta, necesitan, verificado: false
        });
        if (error) throw error;
        sugerirRefugioForm.style.display = 'none';
        formRefugioSuccessMessage.style.display = 'flex';
      } catch (err) {
        console.error('Error insertando refugio en Supabase:', err);
        alert('Hubo un error al enviar tu sugerencia.');
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }
</script>
