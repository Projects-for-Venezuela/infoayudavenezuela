<dialog id="sugerirRefugioDialog" class="modal-dialog" aria-labelledby="sugerirRefugioDialogTitle">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="sugerirRefugioDialogTitle">Sugerir Refugio</h2>
      <button id="closeRefugioDialogBtn" class="close-btn" aria-label="Cerrar modal">&times;</button>
    </div>
    <form id="sugerirRefugioForm" class="modal-form">
      <p class="form-help">Ingresa los datos del refugio. Se publicará en vivo una vez sea verificado.</p>

      <div class="form-group">
        <label for="formRefugioEstado">Estado *</label>
        <select id="formRefugioEstado" required>
          <option value="">Selecciona un estado</option>
          <option value="Distrito Capital">Distrito Capital</option>
          <option value="Miranda">Miranda</option>
          <option value="La Guaira">La Guaira</option>
          <option value="Aragua">Aragua</option>
          <option value="Carabobo">Carabobo</option>
          <option value="Lara">Lara</option>
          <option value="Sucre">Sucre</option>
          <option value="Nueva Esparta">Nueva Esparta</option>
          <option value="Anzoátegui">Anzoátegui</option>
          <option value="Bolívar">Bolívar</option>
          <option value="Barinas">Barinas</option>
          <option value="Monagas">Monagas</option>
          <option value="Yaracuy">Yaracuy</option>
          <option value="Zulia">Zulia</option>
          <option value="Mérida">Mérida</option>
          <option value="Táchira">Táchira</option>
          <option value="Trujillo">Trujillo</option>
          <option value="Falcón">Falcón</option>
          <option value="Cojedes">Cojedes</option>
          <option value="Portuguesa">Portuguesa</option>
          <option value="Guárico">Guárico</option>
          <option value="Apure">Apure</option>
          <option value="Delta Amacuro">Delta Amacuro</option>
          <option value="Amazonas">Amazonas</option>
        </select>
      </div>

      <div class="form-group">
        <label for="formRefugioCiudad">Ciudad *</label>
        <input type="text" id="formRefugioCiudad" placeholder="Ej. Barquisimeto, Altamira" required />
      </div>

      <div class="form-group">
        <label for="formRefugioNombre">Nombre del Refugio *</label>
        <input type="text" id="formRefugioNombre" placeholder="Ej. Polideportivo o Escuela Municipal" required />
      </div>

      <div class="form-group">
        <label for="formRefugioDireccion">Dirección Completa</label>
        <textarea id="formRefugioDireccion" rows="2" placeholder="Dirección exacta del refugio..."></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="formRefugioContacto">Contacto / Teléfono</label>
          <input type="text" id="formRefugioContacto" placeholder="Ej. 0424-1234567" />
        </div>
        <div class="form-group">
          <label for="formRefugioCapacidad">Capacidad Aproximada</label>
          <input type="text" id="formRefugioCapacidad" placeholder="Ej. 50 personas, 20 familias" />
        </div>
      </div>

      <div class="form-group">
        <label for="formRefugioAcepta">¿Qué insumos / donaciones aceptan? (Opcional)</label>
        <input type="text" id="formRefugioAcepta" placeholder="Ej. Colchones, Agua, Ropa" />
      </div>

      <div class="form-group">
        <label for="formRefugioNecesitan">¿Qué necesitan URGENTE? (Opcional)</label>
        <input type="text" id="formRefugioNecesitan" placeholder="Ej. Fórmulas, Pañales, Medicinas" />
      </div>

      <div class="form-actions">
        <button type="button" id="cancelRefugioFormBtn" class="btn btn-secondary">Cancelar</button>
        <button type="submit" id="submitRefugioFormBtn" class="btn btn-primary">Enviar Sugerencia</button>
      </div>
    </form>

    <div id="formRefugioSuccessMessage" class="form-success-msg" style="display: none;">
      <div class="success-icon">✓</div>
      <h3>¡Sugerencia Enviada!</h3>
      <p>Muchas gracias por tu valioso aporte para ayudar a los afectados. Los datos han sido registrados de forma segura y se publicarán tan pronto sean verificados por un moderador.</p>
      <button id="successRefugioCloseBtn" class="btn btn-primary">Entendido</button>
    </div>
  </div>
</dialog>
