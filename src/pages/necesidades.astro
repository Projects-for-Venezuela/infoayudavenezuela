---
import Layout from "../layouts/Layout.astro";
import EmergenciaCTA from "../components/EmergenciaCTA.astro";
---

<Layout title="Necesidades Urgentes"
  description="Necesidades urgentes reportadas por los afectados por el sismo del 24 de junio de 2026 en Venezuela: agua, alimentos, medicinas e insumos prioritarios. Reporta o atiende una necesidad."
  showHero={false}>
  <header class="relative -mt-4 md:-mt-6 mb-6 w-screen ml-[calc(-50vw+50%)] overflow-hidden bg-gradient-to-br from-red-dark via-[#991B1B] to-red text-white">
    <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_20px,rgba(255,255,255,0.04)_20px,rgba(255,255,255,0.04)_40px)]" aria-hidden="true"></div>
    <div class="relative max-w-[640px] mx-auto text-center px-5 py-10 sm:py-12">
      <span class="inline-block bg-white/20 border border-white/25 text-white text-[0.7rem] font-extrabold uppercase tracking-[0.06em] px-3 py-1 rounded-full mb-4">Alerta</span>
      <h1 class="text-2xl sm:text-[1.9rem] font-extrabold tracking-tight leading-tight text-balance mb-2">
        Necesidades <span class="text-[#FCA5A5]">Urgentes</span>
      </h1>
      <p class="text-sm sm:text-[0.9rem] text-white/85 max-w-[480px] mx-auto leading-relaxed text-balance">
        Lugares, refugios y comunidades que requieren asistencia inmediata — <strong class="text-white font-semibold">reportado por la comunidad</strong>
      </p>
    </div>
  </header>

  <div class="flex flex-col sm:flex-row gap-2.5 sm:items-center mb-4">
    <div class="relative flex-1 min-w-0">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-[#9CA3AF] pointer-events-none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path></svg>
      <label for="necSearchInput" class="sr-only">Buscar necesidades</label>
      <input type="text" id="necSearchInput" placeholder="Buscar por lugar, ciudad o necesidad..." class="w-full h-11 pl-11 pr-4 text-sm bg-white border-[1.5px] border-border rounded-[10px] outline-none transition-[border-color,box-shadow] duration-200 focus:border-red focus:shadow-[0_0_0_3px_rgba(207,20,43,0.1)]" />
    </div>
    <label for="necEstadoFilter" class="sr-only">Filtrar por estado</label>
    <select id="necEstadoFilter" class="h-11 px-3.5 text-[0.85rem] bg-white border-[1.5px] border-border rounded-[10px] outline-none cursor-pointer transition-[border-color,box-shadow] duration-200 focus:border-red focus:shadow-[0_0_0_3px_rgba(207,20,43,0.1)] sm:min-w-[180px]">
      <option value="">Todos los estados</option>
      <option value="Distrito Capital">Distrito Capital (Caracas)</option>
      <option value="La Guaira">La Guaira</option>
      <option value="Miranda">Miranda (El Junquito)</option>
      <option value="Falcón">Falcón (Tucacas)</option>
    </select>
    <button id="necRefreshBtn" class="h-11 px-4 inline-flex items-center justify-center gap-1.5 shrink-0 text-[0.85rem] font-semibold text-text bg-white border-[1.5px] border-border rounded-[10px] cursor-pointer transition-[border-color,background-color,color] duration-200 hover:border-red hover:bg-[#FFF5F5] hover:text-red">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
      Actualizar
    </button>
  </div>

  <button id="homeReportarBtn" type="button" class="flex items-center justify-center gap-2 w-full min-h-12 px-4 py-3 mb-4 text-[0.85rem] font-bold bg-[#FEF2F2] text-[#991B1B] border-2 border-[#FECACA] rounded-[10px] cursor-pointer select-none transition-[background-color,border-color,transform,box-shadow] duration-150 hover:bg-[#FEE2E2] hover:border-[#FCA5A5] hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(220,38,38,0.2)] active:scale-[0.98]">
    <svg class="shrink-0" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    Reportar una necesidad urgente
  </button>

  <div id="necStatus" role="status" aria-live="polite" class="inline-flex items-center gap-1.5 text-[0.78rem] font-semibold px-3 py-1.5 rounded-lg mb-4 bg-[#E2E8F0] text-[#475569]">Cargando necesidades...</div>

  <div id="necesidadesContainer" class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4 mb-6">
    <div class="col-span-full bg-white border border-border rounded-xl p-10 text-center text-muted text-sm">Cargando datos...</div>
  </div>

  <EmergenciaCTA />

  <div class="mt-6 text-center">
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted no-underline px-4 py-2 rounded-lg transition-colors duration-150 hover:bg-[#F1F5F9] hover:text-text">&larr; Volver al inicio</a>
  </div>
</Layout>

<script>
  import { supabase } from "../lib/supabase";
  import { ZONAS_AFECTADAS } from "../data/centros";
  import { escapeHtml } from "../lib/escape";

  const container = document.getElementById('necesidadesContainer') as HTMLElement;
  const statusEl = document.getElementById('necStatus') as HTMLElement;
  const searchInput = document.getElementById('necSearchInput') as HTMLInputElement;
  const estadoFilter = document.getElementById('necEstadoFilter') as HTMLSelectElement;
  const refreshBtn = document.getElementById('necRefreshBtn') as HTMLButtonElement;

  const STATUS_BASE = "inline-flex items-center gap-1.5 text-[0.78rem] font-semibold px-3 py-1.5 rounded-lg mb-4";
  const STATUS = {
    loading: `${STATUS_BASE} bg-[#E2E8F0] text-[#475569]`,
    live: `${STATUS_BASE} bg-[#DCFCE7] text-[#15803D] border border-[#BBF7D0]`,
    offline: `${STATUS_BASE} bg-[#FEF3C7] text-[#92400E] border border-[#FDE68A]`,
  };

  const NO_RESULTS = "col-span-full bg-white border border-border rounded-xl p-10 text-center text-muted text-sm";

  let necesidades: any[] = [];
  let estadosAyudaMap = new Map<string, string>();

  function renderNecesidades(list: any[]) {
    if (list.length === 0) {
      container.innerHTML = `<div class="${NO_RESULTS}">No hay necesidades urgentes reportadas aún. Si conoces un lugar que necesita ayuda, usa el botón "Reportar" para reportarlo.</div>`;
      return;
    }

    container.innerHTML = list.map((n: any) => {
      const dbStatus = estadosAyudaMap.get(n.estado);
      const isAfectado = dbStatus === 'critico' || (!dbStatus && ZONAS_AFECTADAS.includes(n.estado));
      const cardCls = isAfectado
        ? "relative flex flex-col bg-[#FFF5F5] rounded-xl border border-[#FCA5A5] border-l-[5px] border-l-[#DC2626] overflow-hidden transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-[#F87171] hover:shadow-[0_8px_24px_rgba(239,68,68,0.1)]"
        : "relative flex flex-col bg-white rounded-xl border border-border border-l-[5px] border-l-red overflow-hidden transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-[#C7CDD8] hover:shadow-[0_8px_24px_rgba(16,24,40,0.06)]";
      return `
        <article class="${cardCls}">
          <div class="flex items-center gap-3 pt-4 px-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-red to-[#B91C1C] text-white flex items-center justify-center shrink-0 shadow-[0_2px_8px_rgba(207,20,43,0.2)]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div class="flex flex-col flex-1 min-w-0">
              <h3 class="text-[0.95rem] font-bold text-text leading-snug tracking-tight mb-0.5 text-balance">${escapeHtml(n.lugar)}</h3>
              <span class="flex items-center gap-1 text-[0.74rem] text-muted font-medium truncate">
                <svg class="shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                ${escapeHtml(n.ciudad)}, ${escapeHtml(n.estado)}
              </span>
            </div>
            <span class="shrink-0 text-[0.68rem] font-extrabold uppercase tracking-wide text-white px-2 py-1 rounded-md bg-gradient-to-br from-red to-[#B91C1C] shadow-[0_2px_6px_rgba(207,20,43,0.3)] animate-[nec-pulse_1.8s_ease-in-out_infinite]">Urgente</span>
          </div>
          <div class="flex flex-col gap-3 px-4 pt-3 pb-4">
            <div class="flex flex-col gap-1.5">
              <span class="inline-flex items-center gap-1 text-[0.68rem] font-bold text-red-dark uppercase tracking-wide">
                <svg class="shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Necesitan
              </span>
              <p class="text-sm leading-relaxed font-medium text-[#7F1D1D] bg-[#FEF2F2] border border-[#FECACA] rounded-lg px-3 py-2.5 text-pretty">${escapeHtml(n.que_necesitan)}</p>
            </div>
            ${n.direccion ? `<div class="flex gap-2 items-baseline"><span class="shrink-0 w-16 text-[0.66rem] font-bold text-muted uppercase tracking-wide">Dirección</span><span class="flex-1 text-[0.82rem] text-text leading-relaxed text-pretty">${escapeHtml(n.direccion)}</span></div>` : ''}
            ${n.contacto ? `<div class="flex gap-2 items-baseline"><span class="shrink-0 w-16 text-[0.66rem] font-bold text-muted uppercase tracking-wide">Contacto</span><span class="flex-1 text-[0.82rem] text-text leading-relaxed text-pretty">${escapeHtml(n.contacto)}</span></div>` : ''}
          </div>
        </article>
      `;
    }).join("");
  }

  function handleFilter() {
    const q = searchInput.value.toLowerCase().trim();
    const estado = estadoFilter.value;

    let filtered = necesidades.filter((n: any) => {
      if (estado && n.estado !== estado) return false;
      if (q) {
        return n.lugar.toLowerCase().includes(q)
          || n.ciudad.toLowerCase().includes(q)
          || n.estado.toLowerCase().includes(q)
          || n.que_necesitan.toLowerCase().includes(q);
      }
      return true;
    });

    filtered.sort((a: any, b: any) => {
      const dbStatusA = estadosAyudaMap.get(a.estado);
      const dbStatusB = estadosAyudaMap.get(b.estado);
      const aAfectado = dbStatusA === 'critico' || (!dbStatusA && ZONAS_AFECTADAS.includes(a.estado));
      const bAfectado = dbStatusB === 'critico' || (!dbStatusB && ZONAS_AFECTADAS.includes(b.estado));
      if (aAfectado && !bAfectado) return -1;
      if (!aAfectado && bAfectado) return 1;
      return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
    });

    renderNecesidades(filtered);
  }

  async function loadData() {
    try {
      statusEl.textContent = "Cargando necesidades...";
      statusEl.className = STATUS.loading;
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase
        .from('necesidades_urgentes')
        .select('*')
        .eq('verificado', true)
        .order('created_at', { ascending: false });

      if (error) throw error;

      const { data: statusData, error: statusError } = await supabase
        .from('estados_ayuda')
        .select('*');

      if (!statusError && statusData) {
        estadosAyudaMap.clear();
        statusData.forEach(s => estadosAyudaMap.set(s.estado, s.nivel_ayuda));
      }

      if (data && data.length > 0) {
        necesidades = data;
        statusEl.textContent = `${data.length} necesidad${data.length !== 1 ? 'es' : ''} reportada${data.length !== 1 ? 's' : ''}`;
        statusEl.className = STATUS.live;
      } else {
        necesidades = [];
        statusEl.textContent = "Sin necesidades reportadas";
        statusEl.className = STATUS.offline;
      }

      handleFilter();
    } catch (err) {
      console.error("Error cargando necesidades:", err);
      statusEl.textContent = "Error al cargar";
      statusEl.className = STATUS.offline;
      container.innerHTML = `<div class="${NO_RESULTS}">No se pudieron cargar las necesidades. Verifica tu conexión e intenta de nuevo.</div>`;
    }
  }

  searchInput.addEventListener('input', handleFilter);
  estadoFilter.addEventListener('change', handleFilter);
  refreshBtn.addEventListener('click', () => {
    const svg = refreshBtn.querySelector('svg');
    if (svg) svg.classList.add('animate-spin');
    loadData().finally(() => {
      if (svg) svg.classList.remove('animate-spin');
    });
  });

  loadData();
</script>
