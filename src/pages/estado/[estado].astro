---
import "../../styles/estado.css";
import Layout from "../../layouts/Layout.astro";
import { estados, centrosPorEstado, resolveEstado, flagUrl, slug, unslug } from "../../data/centros";

export async function getStaticPaths() {
  return estados.map(({ estado }: any) => ({
    params: { estado: slug(estado) },
    props: { estado },
  }));
}

const { estado } = Astro.params;
const decoded = unslug(estado || '');
const display = resolveEstado(decoded);
const esInternacional = display === 'Internacional';
const ciudades = centrosPorEstado(decoded);
const total = ciudades.reduce((s: number, c: any) => s + c.centros.length, 0);

const description = esInternacional
  ? `Centros de acopio internacionales para ayudar a los afectados por el sismo en Venezuela. Donaciones desde el exterior.`
  : `Centros de acopio verificados en ${display}, Venezuela. ${total} centro${total !== 1 ? 's' : ''} activo${total !== 1 ? 's' : ''}. Encuentra dónde donar agua, alimentos, medicinas e insumos.`;
const canonical = `https://infoayudavenezuela.vercel.app/estado/${estado}`;
---

<Layout title={display} {description} {canonical}>
  <div id="stateMeta" data-state={display} style="display: none;"></div>

  <a href="/" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Todos los estados
  </a>

  <div class="hero-local">
    <div class="hero-local-flag">
      {esInternacional ? (
        <div class="hero-globe">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
      ) : (
        <img src={flagUrl(decoded)} alt={`Bandera de ${decoded}`} onerror="this.style.display='none';" />
      )}
    </div>
    <div>
      <h1 class={esInternacional ? 'hero-title-intl' : ''}>{display}</h1>
      <p class="hero-local-meta" id="totalCentrosCount">{total} centro{total !== 1 ? "s" : ""} de acopio habilitado{total !== 1 ? "s" : ""}</p>
    </div>
  </div>

  {total === 0 && (
    <div class="no-data">
      <div class="no-data-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="no-data-title">Esta zona aún no tiene información</p>
      <p class="no-data-desc">No hay centros de acopio registrados en {display} por el momento. Si tienes información, comunícate con las autoridades locales.</p>
    </div>
  )}

  <div id="centrosWrapper" style={total === 0 ? "display:none" : ""}>
    <div class="state-filters" id="stateFilters">
      <div class="search-box">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="stateSearchInput" placeholder="Buscar por nombre, dirección o insumos..." />
      </div>
      {esInternacional && (
        <div class="filter-box">
          <select id="countryFilter">
            <option value="">Todos los países</option>
          </select>
        </div>
      )}
      <div class="filter-box">
        <select id="cityFilter">
          <option value="">Todas las ciudades</option>
        </select>
      </div>
    </div>
    <div class="section-header">
      <span id="filterResultsCount" class="results-count" style="display: none;"></span>
    </div>
    <div id="centrosContainer"></div>
  </div>
</Layout>

<script>
  import { supabase } from "../../lib/supabase";
  import { escapeHtml, escapeArray } from "../../lib/escape";

  const stateMetaEl = document.getElementById('stateMeta') as HTMLElement;
  const decodedState = stateMetaEl?.dataset?.state || '';
  const esInternacional = decodedState === 'Internacional';
  const totalEl = document.getElementById('totalCentrosCount') as HTMLElement;
  const centrosWrapper = document.getElementById('centrosWrapper') as HTMLElement;
  const centrosContainer = document.getElementById('centrosContainer') as HTMLElement;
  const searchInput = document.getElementById('stateSearchInput') as HTMLInputElement;
  const cityFilter = document.getElementById('cityFilter') as HTMLSelectElement;
  const countryFilter = document.getElementById('countryFilter') as HTMLSelectElement;
  const resultsCount = document.getElementById('filterResultsCount') as HTMLElement;

  let allData: any[] = [];

  function getPais(centro: any): string {
    const c = centro.pais || centro.ciudad || '';
    const loc = c.toLowerCase();
    if (loc.includes('ee. uu.') || loc.includes('eeuu') || loc.includes('usa') || loc.includes('estados unidos') || loc.includes('florida') || loc.includes('miami')) return 'Estados Unidos';
    if (loc.includes('españa') || loc.includes('spain') || loc.includes('madrid')) return 'España';
    if (loc.includes('colombia') || loc.includes('bogotá') || loc.includes('bogota')) return 'Colombia';
    if (loc.includes('méxico') || loc.includes('mexico')) return 'México';
    if (loc.includes('argentina') || loc.includes('buenos aires')) return 'Argentina';
    if (loc.includes('chile') || loc.includes('santiago')) return 'Chile';
    if (loc.includes('perú') || loc.includes('peru') || loc.includes('lima')) return 'Perú';
    if (loc.includes('ecuador') || loc.includes('quito')) return 'Ecuador';
    if (loc.includes('panamá') || loc.includes('panama')) return 'Panamá';
    if (loc.includes('brasil') || loc.includes('brazil')) return 'Brasil';
    if (loc.includes('uruguay') || loc.includes('montevideo')) return 'Uruguay';
    if (loc.includes('costa rica')) return 'Costa Rica';
    if (loc.includes('república dominicana') || loc.includes('republica dominicana')) return 'República Dominicana';
    return centro.pais || '';
  }

  function renderCentros(data: any[]) {
    if (data.length === 0) {
      centrosContainer.innerHTML = '<div class="no-results" style="padding:2rem;text-align:center;color:var(--muted);">No se encontraron centros que coincidan con los filtros.</div>';
      return;
    }

    const ciudadesMap: Record<string, any[]> = {};
    data.forEach((c: any) => {
      if (!ciudadesMap[c.ciudad]) ciudadesMap[c.ciudad] = [];
      ciudadesMap[c.ciudad].push(c);
    });

    let html = '';
    Object.entries(ciudadesMap).forEach(([ciudad, centros]: [string, any[]]) => {
      const safeCiudad = escapeHtml(ciudad);
      html += `
        <section class="city-section">
          <div class="city-head">
            ${esInternacional
              ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>'
              : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>'}
            <h2>${safeCiudad}</h2>
            <span class="city-count">${centros.length}</span>
          </div>
          <div class="card-list">
            ${centros.map((centro: any) => {
              const safeNombre = escapeHtml(centro.nombre);
              const safeDireccion = escapeHtml(centro.direccion);
              const safeContacto = escapeHtml(centro.contacto);
              const safeHora = escapeHtml(centro.hora);
              const safeZelle = escapeHtml(centro.zelle);
              const safePagoMovil = escapeHtml(centro.pago_movil);
              const safeAcepta = escapeArray(centro.acepta);
              const safeNecesitan = escapeArray(centro.necesitan);
              const aceptaHtml = safeAcepta.length
                ? `<div class="row"><span class="row-label">Aceptan</span><div class="row-value"><div class="tag-group">${safeAcepta.map((a: string) => `<span class="tag tag-yellow">${a}</span>`).join("")}</div></div></div>`
                : '';
              const necesitanHtml = safeNecesitan.length
                ? `<div class="row"><span class="row-label">Urgente</span><div class="row-value"><div class="tag-group">${safeNecesitan.map((n: string) => `<span class="tag tag-red">${n}</span>`).join("")}</div></div></div>`
                : '';
              return `
                <div class="card">
                  <div class="card-head">
                    <div class="card-icon" style="background:${esInternacional ? '#0284C7' : 'var(--red)'}">
                      ${esInternacional
                        ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>'
                        : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>'}
                    </div>
                    <h3>${safeNombre}</h3>
                  </div>
                  <div class="card-body">
                    ${centro.direccion ? `<div class="row"><span class="row-label">Dirección</span><div class="row-value">${safeDireccion}</div></div>` : ''}
                    ${centro.contacto ? `<div class="row"><span class="row-label">Contacto</span><div class="row-value">${safeContacto}</div></div>` : ''}
                    ${centro.hora ? `<div class="row"><span class="row-label">Horario</span><div class="row-value">${safeHora}</div></div>` : ''}
                    ${aceptaHtml}${necesitanHtml}
                    ${centro.zelle ? `<div class="row"><span class="row-label">Zelle</span><div class="row-value">${safeZelle}</div></div>` : ''}
                    ${centro.pago_movil ? `<div class="row"><span class="row-label">Pago Móvil</span><div class="row-value">${safePagoMovil}</div></div>` : ''}
                  </div>
                </div>
              `;
            }).join("")}
          </div>
        </section>
      `;
    });
    centrosContainer.innerHTML = html;
  }

  function extractPaises(data: any[]): string[] {
    const set = new Set<string>();
    data.forEach(c => {
      const p = getPais(c);
      if (p) set.add(p);
    });
    return Array.from(set).sort();
  }

  function populateCountryFilter(paises: string[]) {
    if (!countryFilter) return;
    countryFilter.innerHTML = '<option value="">Todos los países</option>';
    paises.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p;
      opt.textContent = p;
      countryFilter.appendChild(opt);
    });
  }

  function populateCityFilter(data: any[]) {
    if (!cityFilter) return;
    const cities = Array.from(new Set(data.map((c: any) => c.ciudad))).sort() as string[];
    cityFilter.innerHTML = '<option value="">Todas las ciudades</option>';
    cities.forEach(city => {
      const opt = document.createElement('option');
      opt.value = city;
      opt.textContent = city;
      cityFilter.appendChild(opt);
    });
  }

  function handleFilter() {
    const q = searchInput?.value.toLowerCase().trim() || '';
    const city = cityFilter?.value || '';
    const pais = countryFilter?.value || '';

    let filtered = allData.filter((c: any) => {
      if (city && c.ciudad !== city) return false;
      if (pais && getPais(c) !== pais) return false;
      if (q) {
        return c.nombre?.toLowerCase().includes(q)
          || c.ciudad?.toLowerCase().includes(q)
          || (c.direccion || '').toLowerCase().includes(q)
          || (c.contacto || '').toLowerCase().includes(q)
          || (c.acepta || []).some((a: string) => a.toLowerCase().includes(q))
          || (c.necesitan || []).some((n: string) => n.toLowerCase().includes(q));
      }
      return true;
    });

    const total = filtered.length;
    totalEl.textContent = `${total} centro${total !== 1 ? 's' : ''} de acopio habilitado${total !== 1 ? 's' : ''}`;

    if (q || city || pais) {
      resultsCount.style.display = 'inline-block';
      resultsCount.textContent = `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`;
    } else {
      resultsCount.style.display = 'none';
    }

    renderCentros(filtered);
  }

  function onPaisChange() {
    if (!esInternacional) return;
    const pais = countryFilter?.value || '';
    const filteredByCountry = pais ? allData.filter(c => getPais(c) === pais) : allData;
    populateCityFilter(filteredByCountry);
    handleFilter();
  }

  async function loadStateData() {
    try {
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase
        .from('centros_acopio')
        .select('id,nombre,ciudad,estado,direccion,contacto,hora,acepta,necesitan,zelle,pago_movil,verificado')
        .eq('estado', decodedState)
        .eq('verificado', true);

      if (error) throw error;

      if (data && data.length > 0) {
        allData = data;
        const total = data.length;
        totalEl.textContent = `${total} centro${total !== 1 ? 's' : ''} de acopio habilitado${total !== 1 ? 's' : ''}`;

        centrosWrapper.style.display = '';
        const noDataEl = document.querySelector('.no-data') as HTMLElement;
        if (noDataEl) noDataEl.style.display = 'none';

        if (esInternacional) {
          const paises = extractPaises(data);
          populateCountryFilter(paises);
        }

        populateCityFilter(data);

        renderCentros(data);
      }
    } catch (err) {
      console.error("Supabase failed, retaining static fallback:", err);
    }
  }

  // Debounce para evitar refiltrar en cada tecla (mejora rendimiento)
  function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): (...args: Parameters<T>) => void {
    let t: ReturnType<typeof setTimeout> | null = null;
    return (...args: Parameters<T>) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    };
  }
  const debouncedFilter = debounce(handleFilter, 250);

  searchInput?.addEventListener('input', debouncedFilter);
  cityFilter?.addEventListener('change', handleFilter);
  countryFilter?.addEventListener('change', onPaisChange);

  loadStateData();
</script>
<style is:global>
  .state-filters {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    width: 100%;
  }
  .state-filters .search-box {
    position: relative;
    flex: 2;
    min-width: 0;
  }
  .state-filters .search-icon {
    position: absolute;
    top: 50%; left: 1rem;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 10;
  }
  .state-filters .filter-box {
    flex: 1;
    min-width: 0;
  }
  .state-filters .search-box input,
  .state-filters .filter-box select {
    width: 100%;
    height: 46px;
    box-sizing: border-box;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    font-family: inherit;
    font-size: 0.9rem;
    background: white;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    display: block;
  }
  .state-filters .search-box input {
    padding: 0 1rem 0 2.6rem;
  }
  .state-filters .filter-box select {
    padding: 0 1rem;
    cursor: pointer;
  }
  .state-filters .search-box input:focus,
  .state-filters .filter-box select:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(0,36,125,0.08);
  }
  .section-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.5rem;
  }
  .results-count {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted);
    background: #F1F5F9;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  @media (max-width: 640px) {
    .state-filters {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
.back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--blue);
    font-size: 0.86rem;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 1.25rem;
    padding: 0.35rem 0.75rem;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: background .15s, border-color .15s;
  }
  .back-link:hover { background: #F8F9FB; border-color: #C7CDD8; }
  .hero-local {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 2px solid var(--border);
  }
  .hero-local-flag {
    width: 110px; height: 73px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .hero-local-flag img { width: 100%; height: 100%; object-fit: cover; }
  .hero-local h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--blue);
    letter-spacing: -0.02em;
    margin-bottom: 0.1rem;
  }
  .hero-title-intl { color: #0284C7 !important; }
  .hero-globe {
    width: 110px; height: 73px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F0F9FF;
    border-radius: 8px;
    border: 1px solid #BAE6FD;
  }
  .hero-local-meta { color: var(--muted); font-size: 0.86rem; }
  .city-section { margin-bottom: 1.75rem; }
  .city-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.7rem;
    padding-bottom: 0.5rem;
    border-bottom: 1.5px solid var(--border);
  }
  .city-head h2 { font-size: 0.95rem; font-weight: 600; color: var(--text); flex: 1; }
  .city-count {
    background: white;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  .card-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .card {
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: all .15s;
  }
  .card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.04); border-color: #C7CDD8; }
  .card-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1rem 0;
  }
  .card-icon {
    width: 28px; height: 28px;
    background: var(--red);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card h3 { font-size: 0.9rem; font-weight: 600; color: var(--text); line-height: 1.3; }
  .card-body { padding: 0.6rem 1rem 0.85rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .row { display: flex; gap: 0.5rem; align-items: flex-start; }
  .row-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .04em;
    min-width: 62px;
    flex-shrink: 0;
    padding-top: 0.05rem;
  }
  .row-value { font-size: 0.85rem; color: var(--text); flex: 1; line-height: 1.4; }
  .tag-group { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .tag { font-size: 0.72rem; padding: 0.1rem 0.5rem; border-radius: 6px; }
  .tag-yellow { background: #FFFBEB; color: #92400E; border: 1px solid #FDE68A; }
  .tag-red { background: #FEF2F2; color: var(--red); border: 1px solid #FECACA; }
  .no-data {
    text-align: center;
    padding: 3rem 1.5rem;
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .no-data-icon { color: var(--muted); margin-bottom: 1rem; opacity: 0.5; }
  .no-data-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
  .no-data-desc { font-size: 0.84rem; color: var(--muted); max-width: 380px; margin: 0 auto; line-height: 1.5; }
  @media (max-width:640px) {
    .hero-local { flex-direction: column; align-items: flex-start; }
    .hero-local-flag { width: 100%; height: 95px; }
    .hero-local h1 { font-size: 1.25rem; }
  }
</style>
