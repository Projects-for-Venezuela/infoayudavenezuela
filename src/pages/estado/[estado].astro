---
import Layout from "../../layouts/Layout.astro";
import { estados, centrosPorEstado, resolveEstado, flagUrl, slug, unslug } from "../../data/centros";
import { SITE_URL } from "../../lib/site.js";

export async function getStaticPaths() {
  return estados.map(({ estado }: any) => ({
    params: { estado: slug(estado) },
    props: { estado },
  }));
}

const { estado } = Astro.params;
const decoded = unslug(estado || '');
const display = resolveEstado(decoded);
const esInternacional = display === 'Internacional';
const ciudades = centrosPorEstado(decoded);
const total = ciudades.reduce((s: number, c: any) => s + c.centros.length, 0);

const description = esInternacional
  ? `Centros de acopio internacionales para ayudar a los afectados por el sismo en Venezuela. Donaciones desde el exterior.`
  : `Centros de acopio verificados en ${display}, Venezuela. ${total} centro${total !== 1 ? 's' : ''} activo${total !== 1 ? 's' : ''}. Encuentra dónde donar agua, alimentos, medicinas e insumos.`;
const canonical = `${SITE_URL}/estado/${estado}`;
---

<Layout title={display} {description} {canonical}>
  <div id="stateMeta" data-state={display} hidden></div>

  <a href="/" class="inline-flex items-center gap-1.5 mb-5 px-3 py-1.5 text-[0.86rem] font-medium text-blue no-underline bg-white border border-border rounded-lg transition-colors duration-150 hover:bg-[#F8F9FB] hover:border-[#C7CDD8]">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Todos los estados
  </a>

  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-5 mb-7 pb-5 border-b-2 border-border">
    {esInternacional ? (
      <div class="w-full sm:w-[110px] h-[95px] sm:h-[73px] flex items-center justify-center shrink-0 bg-[#F0F9FF] border border-[#BAE6FD] rounded-lg">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
      </div>
    ) : (
      <div class="w-full sm:w-[110px] h-[95px] sm:h-[73px] shrink-0 overflow-hidden bg-[#F1F5F9] border border-border rounded-lg">
        <img src={flagUrl(decoded)} alt={`Bandera de ${decoded}`} class="w-full h-full object-cover" onerror="this.style.display='none';" />
      </div>
    )}
    <div class="min-w-0">
      <h1 class={`text-[1.25rem] sm:text-[1.4rem] font-bold tracking-tight leading-tight text-balance mb-0.5 ${esInternacional ? 'text-[#0284C7]' : 'text-blue'}`}>{display}</h1>
      <p class="text-[0.86rem] text-muted tabular-nums" id="totalCentrosCount">{total} centro{total !== 1 ? "s" : ""} de acopio habilitado{total !== 1 ? "s" : ""}</p>
    </div>
  </div>

  {total === 0 && (
    <div class="no-data text-center py-12 px-6 bg-white border border-border rounded-card">
      <div class="flex justify-center text-muted opacity-50 mb-4">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="text-base font-semibold text-text mb-2 text-balance">Esta zona aún no tiene información</p>
      <p class="text-[0.84rem] text-muted max-w-[380px] mx-auto leading-relaxed text-pretty">No hay centros de acopio registrados en {display} por el momento. Si tienes información, comunícate con las autoridades locales.</p>
    </div>
  )}

  <div id="centrosWrapper" style={total === 0 ? "display:none" : ""}>
    <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 mb-5 w-full" id="stateFilters">
      <div class="relative sm:flex-[2] min-w-0">
        <label for="stateSearchInput" class="sr-only">Buscar por nombre, dirección o insumos</label>
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none z-10" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="stateSearchInput" placeholder="Buscar por nombre, dirección o insumos..." aria-label="Buscar por nombre, dirección o insumos" class="w-full h-[46px] pl-10 pr-4 text-sm bg-white border-[1.5px] border-border rounded-card outline-none transition-[border-color,box-shadow] duration-200 focus:border-blue focus:shadow-[0_0_0_3px_rgba(0,36,125,0.08)]" />
      </div>
      {esInternacional && (
        <div class="sm:flex-1 min-w-0">
          <label for="countryFilter" class="sr-only">Filtrar por país</label>
          <select id="countryFilter" aria-label="Filtrar por país" class="w-full h-[46px] px-4 text-sm bg-white border-[1.5px] border-border rounded-card outline-none cursor-pointer transition-[border-color,box-shadow] duration-200 focus:border-blue focus:shadow-[0_0_0_3px_rgba(0,36,125,0.08)]">
            <option value="">Todos los países</option>
          </select>
        </div>
      )}
      <div class="sm:flex-1 min-w-0">
        <label for="cityFilter" class="sr-only">Filtrar por ciudad</label>
        <select id="cityFilter" aria-label="Filtrar por ciudad" class="w-full h-[46px] px-4 text-sm bg-white border-[1.5px] border-border rounded-card outline-none cursor-pointer transition-[border-color,box-shadow] duration-200 focus:border-blue focus:shadow-[0_0_0_3px_rgba(0,36,125,0.08)]">
          <option value="">Todas las ciudades</option>
        </select>
      </div>
    </div>
    <div class="flex justify-end mb-2">
      <span id="filterResultsCount" class="text-[0.72rem] font-semibold text-muted bg-[#F1F5F9] px-2 py-0.5 rounded-full border border-border tabular-nums" style="display: none;"></span>
    </div>
    <div id="centrosContainer"></div>
  </div>
</Layout>

<script>
  import { supabase } from "../../lib/supabase";
  import { escapeHtml, escapeArray } from "../../lib/escape";

  const stateMetaEl = document.getElementById('stateMeta') as HTMLElement;
  const decodedState = stateMetaEl?.dataset?.state || '';
  const esInternacional = decodedState === 'Internacional';
  const totalEl = document.getElementById('totalCentrosCount') as HTMLElement;
  const centrosWrapper = document.getElementById('centrosWrapper') as HTMLElement;
  const centrosContainer = document.getElementById('centrosContainer') as HTMLElement;
  const searchInput = document.getElementById('stateSearchInput') as HTMLInputElement;
  const cityFilter = document.getElementById('cityFilter') as HTMLSelectElement;
  const countryFilter = document.getElementById('countryFilter') as HTMLSelectElement;
  const resultsCount = document.getElementById('filterResultsCount') as HTMLElement;

  let allData: any[] = [];

  function getPais(centro: any): string {
    const c = centro.pais || centro.ciudad || '';
    const loc = c.toLowerCase();
    if (loc.includes('ee. uu.') || loc.includes('eeuu') || loc.includes('usa') || loc.includes('estados unidos') || loc.includes('florida') || loc.includes('miami')) return 'Estados Unidos';
    if (loc.includes('españa') || loc.includes('spain') || loc.includes('madrid')) return 'España';
    if (loc.includes('colombia') || loc.includes('bogotá') || loc.includes('bogota')) return 'Colombia';
    if (loc.includes('méxico') || loc.includes('mexico')) return 'México';
    if (loc.includes('argentina') || loc.includes('buenos aires')) return 'Argentina';
    if (loc.includes('chile') || loc.includes('santiago')) return 'Chile';
    if (loc.includes('perú') || loc.includes('peru') || loc.includes('lima')) return 'Perú';
    if (loc.includes('ecuador') || loc.includes('quito')) return 'Ecuador';
    if (loc.includes('panamá') || loc.includes('panama')) return 'Panamá';
    if (loc.includes('brasil') || loc.includes('brazil')) return 'Brasil';
    if (loc.includes('uruguay') || loc.includes('montevideo')) return 'Uruguay';
    if (loc.includes('costa rica')) return 'Costa Rica';
    if (loc.includes('república dominicana') || loc.includes('republica dominicana')) return 'República Dominicana';
    return centro.pais || '';
  }

  function renderCentros(data: any[]) {
    if (data.length === 0) {
      centrosContainer.innerHTML = '<div class="py-8 text-center text-muted text-sm">No se encontraron centros que coincidan con los filtros.</div>';
      return;
    }

    const ciudadesMap: Record<string, any[]> = {};
    data.forEach((c: any) => {
      if (!ciudadesMap[c.ciudad]) ciudadesMap[c.ciudad] = [];
      ciudadesMap[c.ciudad].push(c);
    });

    const cityIcon = esInternacional
      ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>'
      : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#CF142B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>';
    const cardIconSvg = esInternacional
      ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>'
      : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>';
    const cardIconBg = esInternacional ? '#0284C7' : '#CF142B';

    let html = '';
    Object.entries(ciudadesMap).forEach(([ciudad, centros]: [string, any[]]) => {
      const safeCiudad = escapeHtml(ciudad);
      html += `
        <section class="mb-7">
          <div class="flex items-center gap-1.5 mb-2.5 pb-2 border-b-[1.5px] border-border">
            ${cityIcon}
            <h2 class="flex-1 text-[0.95rem] font-semibold text-text tracking-tight">${safeCiudad}</h2>
            <span class="bg-white text-muted text-[0.72rem] font-semibold px-2 py-0.5 rounded-full border border-border tabular-nums">${centros.length}</span>
          </div>
          <div class="flex flex-col gap-3">
            ${centros.map((centro: any) => {
              const safeNombre = escapeHtml(centro.nombre);
              const safeDireccion = escapeHtml(centro.direccion);
              const safeContacto = escapeHtml(centro.contacto);
              const safeHora = escapeHtml(centro.hora);
              const safeZelle = escapeHtml(centro.zelle);
              const safePagoMovil = escapeHtml(centro.pago_movil);
              const safeAcepta = escapeArray(centro.acepta);
              const safeNecesitan = escapeArray(centro.necesitan);
              const rowLabel = "text-[0.68rem] font-semibold text-muted uppercase tracking-wide min-w-[62px] shrink-0 pt-0.5";
              const rowValue = "text-[0.85rem] text-text flex-1 leading-snug text-pretty";
              const aceptaHtml = safeAcepta.length
                ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Aceptan</span><div class="${rowValue}"><div class="flex flex-wrap gap-1">${safeAcepta.map((a: string) => `<span class="text-[0.72rem] px-2 py-0.5 rounded-md bg-[#FFFBEB] text-[#92400E] border border-[#FDE68A]">${a}</span>`).join("")}</div></div></div>`
                : '';
              const necesitanHtml = safeNecesitan.length
                ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Urgente</span><div class="${rowValue}"><div class="flex flex-wrap gap-1">${safeNecesitan.map((n: string) => `<span class="text-[0.72rem] px-2 py-0.5 rounded-md bg-[#FEF2F2] text-red border border-[#FECACA]">${n}</span>`).join("")}</div></div></div>`
                : '';
              return `
                <div class="bg-white rounded-card border border-border overflow-hidden transition-[box-shadow,border-color] duration-150 hover:shadow-[0_4px_16px_rgba(0,0,0,0.04)] hover:border-[#C7CDD8]">
                  <div class="flex items-center gap-2.5 px-4 pt-3">
                    <div class="w-7 h-7 rounded-md flex items-center justify-center shrink-0" style="background:${cardIconBg}">
                      ${cardIconSvg}
                    </div>
                    <h3 class="text-[0.9rem] font-semibold text-text leading-snug tracking-tight">${safeNombre}</h3>
                  </div>
                  <div class="flex flex-col gap-1.5 px-4 pt-2.5 pb-3.5">
                    ${centro.direccion ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Dirección</span><div class="${rowValue}">${safeDireccion}</div></div>` : ''}
                    ${centro.contacto ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Contacto</span><div class="${rowValue}">${safeContacto}</div></div>` : ''}
                    ${centro.hora ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Horario</span><div class="${rowValue}">${safeHora}</div></div>` : ''}
                    ${aceptaHtml}${necesitanHtml}
                    ${centro.zelle ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Zelle</span><div class="${rowValue}">${safeZelle}</div></div>` : ''}
                    ${centro.pago_movil ? `<div class="flex gap-2 items-start"><span class="${rowLabel}">Pago Móvil</span><div class="${rowValue}">${safePagoMovil}</div></div>` : ''}
                  </div>
                </div>
              `;
            }).join("")}
          </div>
        </section>
      `;
    });
    centrosContainer.innerHTML = html;
  }

  function extractPaises(data: any[]): string[] {
    const set = new Set<string>();
    data.forEach(c => {
      const p = getPais(c);
      if (p) set.add(p);
    });
    return Array.from(set).sort();
  }

  function populateCountryFilter(paises: string[]) {
    if (!countryFilter) return;
    countryFilter.innerHTML = '<option value="">Todos los países</option>';
    paises.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p;
      opt.textContent = p;
      countryFilter.appendChild(opt);
    });
  }

  function populateCityFilter(data: any[]) {
    if (!cityFilter) return;
    const cities = Array.from(new Set(data.map((c: any) => c.ciudad))).sort() as string[];
    cityFilter.innerHTML = '<option value="">Todas las ciudades</option>';
    cities.forEach(city => {
      const opt = document.createElement('option');
      opt.value = city;
      opt.textContent = city;
      cityFilter.appendChild(opt);
    });
  }

  function handleFilter() {
    const q = searchInput?.value.toLowerCase().trim() || '';
    const city = cityFilter?.value || '';
    const pais = countryFilter?.value || '';

    let filtered = allData.filter((c: any) => {
      if (city && c.ciudad !== city) return false;
      if (pais && getPais(c) !== pais) return false;
      if (q) {
        return c.nombre?.toLowerCase().includes(q)
          || c.ciudad?.toLowerCase().includes(q)
          || (c.direccion || '').toLowerCase().includes(q)
          || (c.contacto || '').toLowerCase().includes(q)
          || (c.acepta || []).some((a: string) => a.toLowerCase().includes(q))
          || (c.necesitan || []).some((n: string) => n.toLowerCase().includes(q));
      }
      return true;
    });

    const total = filtered.length;
    totalEl.textContent = `${total} centro${total !== 1 ? 's' : ''} de acopio habilitado${total !== 1 ? 's' : ''}`;

    if (q || city || pais) {
      resultsCount.style.display = 'inline-block';
      resultsCount.textContent = `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`;
    } else {
      resultsCount.style.display = 'none';
    }

    renderCentros(filtered);
  }

  function onPaisChange() {
    if (!esInternacional) return;
    const pais = countryFilter?.value || '';
    const filteredByCountry = pais ? allData.filter(c => getPais(c) === pais) : allData;
    populateCityFilter(filteredByCountry);
    handleFilter();
  }

  async function loadStateData() {
    try {
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase
        .from('centros_acopio')
        .select('id,nombre,ciudad,estado,direccion,contacto,hora,acepta,necesitan,zelle,pago_movil,verificado')
        .eq('estado', decodedState)
        .eq('verificado', true);

      if (error) throw error;

      if (data && data.length > 0) {
        allData = data;
        const total = data.length;
        totalEl.textContent = `${total} centro${total !== 1 ? 's' : ''} de acopio habilitado${total !== 1 ? 's' : ''}`;

        centrosWrapper.style.display = '';
        const noDataEl = document.querySelector('.no-data') as HTMLElement;
        if (noDataEl) noDataEl.style.display = 'none';

        if (esInternacional) {
          const paises = extractPaises(data);
          populateCountryFilter(paises);
        }

        populateCityFilter(data);

        renderCentros(data);
      }
    } catch (err) {
      console.error("Supabase failed, retaining static fallback:", err);
    }
  }

  function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): (...args: Parameters<T>) => void {
    let t: ReturnType<typeof setTimeout> | null = null;
    return (...args: Parameters<T>) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    };
  }
  const debouncedFilter = debounce(handleFilter, 250);

  searchInput?.addEventListener('input', debouncedFilter);
  cityFilter?.addEventListener('change', handleFilter);
  countryFilter?.addEventListener('change', onPaisChange);

  loadStateData();
</script>
