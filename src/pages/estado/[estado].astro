---
import Layout from "../../layouts/Layout.astro";
import { estados, centrosPorEstado, resolveEstado, flagUrl, slug, unslug } from "../../data/centros";

export async function getStaticPaths() {
  return estados.map(({ estado }: any) => ({
    params: { estado: slug(estado) },
    props: { estado },
  }));
}

const { estado } = Astro.params;
const decoded = unslug(estado || '');
const display = resolveEstado(decoded);
const ciudades = centrosPorEstado(decoded);
const total = ciudades.reduce((s: number, c: any) => s + c.centros.length, 0);
---

<Layout title={display}>
  <!-- Meta data para lectura desde el script del cliente -->
  <div id="stateMeta" data-state={display} style="display: none;"></div>

  <a href="/" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Todos los estados
  </a>

  <div class="hero-local">
    <div class="hero-local-flag">
      <img src={flagUrl(decoded)} alt={`Bandera de ${decoded}`} onerror="this.style.display='none';" />
    </div>
    <div>
      <h1>{display}</h1>
      <p class="hero-local-meta" id="totalCentrosCount">{total} centro{total !== 1 ? "s" : ""} de acopio habilitado{total !== 1 ? "s" : ""}</p>
    </div>
  </div>

  {total === 0 && (
    <div class="no-data">
      <div class="no-data-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="no-data-title">Esta zona aún no tiene información</p>
      <p class="no-data-desc">No hay centros de acopio registrados en {display} por el momento. Si tienes información, comunícate con las autoridades locales.</p>
    </div>
  )}

  <div id="centrosContainer" style={total === 0 ? "display:none" : ""}>
    {ciudades.map(({ ciudad, centros }) => (
      <section class="city-section">
        <div class="city-head">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <h2>{ciudad}</h2>
          <span class="city-count">{centros.length}</span>
        </div>

        <div class="card-list">
          {centros.map((centro) => (
            <div class="card">
              <div class="card-head">
                <div class="card-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <h3>{centro.nombre}</h3>
              </div>
              <div class="card-body">
                {centro.direccion && <div class="row"><span class="row-label">Dirección</span><div class="row-value">{centro.direccion}</div></div>}
                {centro.contacto && <div class="row"><span class="row-label">Contacto</span><div class="row-value">{centro.contacto}</div></div>}
                {centro.hora && <div class="row"><span class="row-label">Horario</span><div class="row-value">{centro.hora}</div></div>}
                {centro.acepta?.length > 0 && (
                  <div class="row"><span class="row-label">Aceptan</span><div class="row-value"><div class="tag-group">{centro.acepta.map((a) => <span class="tag tag-yellow">{a}</span>)}</div></div></div>
                )}
                {centro.necesitan?.length > 0 && (
                  <div class="row"><span class="row-label">Urgente</span><div class="row-value"><div class="tag-group">{centro.necesitan.map((n) => <span class="tag tag-red">{n}</span>)}</div></div></div>
                )}
                {centro.zelle && <div class="row"><span class="row-label">Zelle</span><div class="row-value">{centro.zelle}</div></div>}
                {centro.pago_movil && <div class="row"><span class="row-label">Pago Móvil</span><div class="row-value">{centro.pago_movil}</div></div>}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>

<script>
  import { supabase } from "../../lib/supabase";

  const stateMetaEl = document.getElementById('stateMeta') as HTMLElement;
  const decodedState = stateMetaEl?.dataset?.state || '';
  const totalEl = document.getElementById('totalCentrosCount') as HTMLElement;
  const centrosContainer = document.getElementById('centrosContainer') as HTMLElement;

  async function loadStateData() {
    try {
      if (!supabase) {
        throw new Error("Supabase client not initialized");
      }

      const { data, error } = await supabase
        .from('centros_acopio')
        .select('*')
        .eq('estado', decodedState)
        .eq('verificado', true);

      if (error) throw error;

      if (data && data.length > 0) {
        // Agrupar centros por ciudad
        const ciudadesMap: Record<string, any[]> = {};
        data.forEach((c: any) => {
          if (!ciudadesMap[c.ciudad]) {
            ciudadesMap[c.ciudad] = [];
          }
          ciudadesMap[c.ciudad].push(c);
        });

        const total = data.length;
        totalEl.textContent = `${total} centro${total !== 1 ? 's' : ''} de acopio habilitado${total !== 1 ? 's' : ''}`;

        let html = '';
        Object.entries(ciudadesMap).forEach(([ciudad, centros]: [string, any[]]) => {
          html += `
            <section class="city-section">
              <div class="city-head">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <h2>${ciudad}</h2>
                <span class="city-count">${centros.length}</span>
              </div>
              <div class="card-list">
                ${centros.map((centro: any) => {
                  let aceptaHtml = '';
                  if (centro.acepta && centro.acepta.length > 0) {
                    aceptaHtml = `
                      <div class="row">
                        <span class="row-label">Aceptan</span>
                        <div class="row-value">
                          <div class="tag-group">
                            ${centro.acepta.map((a: string) => `<span class="tag tag-yellow">${a}</span>`).join("")}
                          </div>
                        </div>
                      </div>
                    `;
                  }

                  let necesitanHtml = '';
                  if (centro.necesitan && centro.necesitan.length > 0) {
                    necesitanHtml = `
                      <div class="row">
                        <span class="row-label">Urgente</span>
                        <div class="row-value">
                          <div class="tag-group">
                            ${centro.necesitan.map((n: string) => `<span class="tag tag-red">${n}</span>`).join("")}
                          </div>
                        </div>
                      </div>
                    `;
                  }

                  return `
                    <div class="card">
                      <div class="card-head">
                        <div class="card-icon">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                        </div>
                        <h3>${centro.nombre}</h3>
                      </div>
                      <div class="card-body">
                        ${centro.direccion ? `<div class="row"><span class="row-label">Dirección</span><div class="row-value">${centro.direccion}</div></div>` : ''}
                        ${centro.contacto ? `<div class="row"><span class="row-label">Contacto</span><div class="row-value">${centro.contacto}</div></div>` : ''}
                        ${centro.hora ? `<div class="row"><span class="row-label">Horario</span><div class="row-value">${centro.hora}</div></div>` : ''}
                        ${aceptaHtml}
                        ${necesitanHtml}
                        ${centro.zelle ? `<div class="row"><span class="row-label">Zelle</span><div class="row-value">${centro.zelle}</div></div>` : ''}
                        ${centro.pago_movil ? `<div class="row"><span class="row-label">Pago Móvil</span><div class="row-value">${centro.pago_movil}</div></div>` : ''}
                      </div>
                    </div>
                  `;
                }).join("")}
              </div>
            </section>
          `;
        });

        centrosContainer.innerHTML = html;
      }
    } catch (err) {
      console.error("Supabase failed, retaining static fallback:", err);
    }
  }

  loadStateData();
</script>

<style is:global>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--blue);
    font-size: 0.86rem;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 1.25rem;
    padding: 0.35rem 0.75rem;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: background .15s, border-color .15s;
  }
  .back-link:hover { background: #F8F9FB; border-color: #C7CDD8; }
  .hero-local {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 2px solid var(--border);
  }
  .hero-local-flag {
    width: 110px; height: 73px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .hero-local-flag img { width: 100%; height: 100%; object-fit: cover; }
  .hero-local h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--blue);
    letter-spacing: -0.02em;
    margin-bottom: 0.1rem;
  }
  .hero-local-meta { color: var(--muted); font-size: 0.86rem; }
  .city-section { margin-bottom: 1.75rem; }
  .city-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.7rem;
    padding-bottom: 0.5rem;
    border-bottom: 1.5px solid var(--border);
  }
  .city-head h2 { font-size: 0.95rem; font-weight: 600; color: var(--text); flex: 1; }
  .city-count {
    background: white;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  .card-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .card {
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: all .15s;
  }
  .card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.04); border-color: #C7CDD8; }
  .card-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1rem 0;
  }
  .card-icon {
    width: 28px; height: 28px;
    background: var(--red);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card h3 { font-size: 0.9rem; font-weight: 600; color: var(--text); line-height: 1.3; }
  .card-body { padding: 0.6rem 1rem 0.85rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .row { display: flex; gap: 0.5rem; align-items: flex-start; }
  .row-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .04em;
    min-width: 62px;
    flex-shrink: 0;
    padding-top: 0.05rem;
  }
  .row-value { font-size: 0.85rem; color: var(--text); flex: 1; line-height: 1.4; }
  .tag-group { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .tag { font-size: 0.72rem; padding: 0.1rem 0.5rem; border-radius: 6px; }
  .tag-yellow { background: #FFFBEB; color: #92400E; border: 1px solid #FDE68A; }
  .tag-red { background: #FEF2F2; color: var(--red); border: 1px solid #FECACA; }
  .no-data {
    text-align: center;
    padding: 3rem 1.5rem;
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .no-data-icon { color: var(--muted); margin-bottom: 1rem; opacity: 0.5; }
  .no-data-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
  .no-data-desc { font-size: 0.84rem; color: var(--muted); max-width: 380px; margin: 0 auto; line-height: 1.5; }
  @media (max-width:640px) {
    .hero-local { flex-direction: column; align-items: flex-start; }
    .hero-local-flag { width: 100%; height: 95px; }
    .hero-local h1 { font-size: 1.25rem; }
  }
</style>
