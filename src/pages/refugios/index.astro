---
import "../../styles/refugios.css";
import "../../styles/index.css";
import Layout from "../../layouts/Layout.astro";
import AlertBox from "../../components/AlertBox.astro";
import SearchFilters from "../../components/SearchFilters.astro";
import EmergenciaCTA from "../../components/EmergenciaCTA.astro";
import SugerirRefugioModal from "../../components/SugerirRefugioModal.astro";
import ReportarRefugiadoModal from "../../components/ReportarRefugiadoModal.astro";
import { estados, flagUrl, ZONAS_AFECTADAS, sortEstados, resolveEstado } from "../../data/centros";

const estadosOrdenados = [...estados].filter(e => resolveEstado(e.estado) === e.estado).sort(sortEstados);
const estadosNacionales = estadosOrdenados.filter(e => e.estado !== 'Internacional');
---

<Layout title="Refugios" showHero={false}>
  <header class="ref-hero">
    <div class="ref-hero-bg">
      <div class="ref-hero-content">
        <span class="ref-hero-badge">SEGURO</span>
        <h1><span>Refugios</span> Verificados</h1>
        <p>Encuentra refugios y espacios seguros habilitados para las personas afectadas — <strong>actualizado por la comunidad</strong></p>
      </div>
    </div>
  </header>

  <div class="ref-alert">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
    <span><strong>Si estás en una zona afectada,</strong> localiza el refugio más cercano. Si conoces un refugio activo, <button id="btnSugerirRefugio" class="nav-sugerir" style="background: transparent; color: #1E40AF; padding: 0; text-decoration: underline; display: inline; cursor: pointer; border: none; font-size: inherit;">sugiere agregarlo aquí</button>.</span>
  </div>

  <AlertBox />

  <div class="ref-stats">
    <div class="ref-stat">
      <span class="ref-stat-num" id="statRefugios">0</span>
      <span class="ref-stat-lbl">Refugios Activos</span>
    </div>
    <div class="ref-stat">
      <span class="ref-stat-num" id="statCiudades">0</span>
      <span class="ref-stat-lbl">Ciudades con Refugios</span>
    </div>
  </div>

  <div class="section-header" style="margin-bottom: 1rem; align-items: flex-start; flex-direction: column; gap: 0.5rem;">
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem;">
      <a href="/buscar-personas" class="btn btn-secondary" style="font-size: 0.9rem; padding: 0.4rem 0.8rem; height: auto;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 4px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg> Buscar Personas
      </a>
      <button id="btnReportarRefugiado" class="btn btn-primary" style="font-size: 0.9rem; padding: 0.4rem 0.8rem; height: auto;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 4px;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg> Registrar Persona en Refugio
      </button>
    </div>
  </div>

  <SearchFilters />

  <div class="ref-section-header">
    <h2 id="gridTitle">Estados con refugios</h2>
    <span id="resultsCount" class="results-count" style="display: none;"></span>
    <span id="dbStatus" class="status-badge loading" style="margin-left: auto;">Cargando...</span>
  </div>

  <div class="grid" id="mainGrid">
    <div class="no-results">Cargando refugios desde la base de datos...</div>
  </div>

  <EmergenciaCTA />

  <div class="ref-footer">
    <a href="/">&larr; Volver al inicio</a>
  </div>

  <SugerirRefugioModal />
  <ReportarRefugiadoModal />
</Layout>

<script>
  import { supabase } from "../../lib/supabase";
  import { ZONAS_AFECTADAS } from "../../data/centros";

  let refugios: any[] = [];

  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const citySelect = document.getElementById('citySelect') as HTMLSelectElement;
  const typeSelect = document.getElementById('typeSelect') as HTMLSelectElement;
  const mainGrid = document.getElementById('mainGrid') as HTMLElement;
  const gridTitle = document.getElementById('gridTitle') as HTMLElement;
  const resultsCount = document.getElementById('resultsCount') as HTMLElement;
  const dbStatus = document.getElementById('dbStatus') as HTMLElement;
  const statRefugios = document.getElementById('statRefugios') as HTMLElement;
  const statCiudades = document.getElementById('statCiudades') as HTMLElement;

  function initCitySelect() {
    const citiesSet = new Set(refugios.map((c: any) => c.ciudad));
    const uniqueCities = Array.from(citiesSet) as string[];
    const affectedCities: string[] = [];
    const otherCities: string[] = [];

    uniqueCities.forEach((city: string) => {
      const sample = refugios.find((c: any) => c.ciudad === city);
      if (sample && ZONAS_AFECTADAS.includes(sample.estado)) {
        affectedCities.push(city);
      } else {
        otherCities.push(city);
      }
    });

    affectedCities.sort();
    otherCities.sort();

    citySelect.innerHTML = '<option value="">Todas las ciudades</option>';

    if (affectedCities.length > 0) {
      const optGroupAffected = document.createElement('optgroup');
      optGroupAffected.label = '🔴 Zonas Afectadas';
      affectedCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = `🔴 ${city}`;
        optGroupAffected.appendChild(opt);
      });
      citySelect.appendChild(optGroupAffected);
    }

    if (otherCities.length > 0) {
      const optGroupOther = document.createElement('optgroup');
      optGroupOther.label = 'Otras ciudades';
      otherCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = city;
        optGroupOther.appendChild(opt);
      });
      citySelect.appendChild(optGroupOther);
    }
  }

  function renderEstados() {
    gridTitle.textContent = "Estados con refugios";
    resultsCount.style.display = "none";
    mainGrid.className = "grid";

    const agrupado = refugios.reduce((acc: any[], item: any) => {
      let e = acc.find((x: any) => x.estado === item.estado);
      if (!e) { e = { estado: item.estado, ciudades: [] }; acc.push(e); }
      let c = e.ciudades.find((x: any) => x.ciudad === item.ciudad);
      if (!c) { c = { ciudad: item.ciudad, refugiosCount: 0 }; e.ciudades.push(c); }
      c.refugiosCount++;
      return acc;
    }, []);

    let estadosAyudaMap = new Map<string, string>(); // estado -> nivel_ayuda
    (window as any).estadosAyudaMap = estadosAyudaMap; // Store globally for access across functions

    const nacionales = agrupado.filter((e: any) => e.estado !== 'Internacional');

    nacionales.sort((a: any, b: any) => {
      const dbStatusA = (window as any).estadosAyudaMap?.get(a.estado);
      const dbStatusB = (window as any).estadosAyudaMap?.get(b.estado);
      const aAfectado = dbStatusA === 'critico' || (!dbStatusA && ZONAS_AFECTADAS.includes(a.estado));
      const bAfectado = dbStatusB === 'critico' || (!dbStatusB && ZONAS_AFECTADAS.includes(b.estado));
      if (aAfectado && !bAfectado) return -1;
      if (!aAfectado && bAfectado) return 1;
      return a.estado.localeCompare(b.estado);
    });

    if (agrupado.length === 0) {
      mainGrid.innerHTML = '<div class="no-results">No se encontraron refugios activos en este momento.</div>';
      return;
    }

    let html = nacionales.map((e: any) => {
      const count = e.ciudades.reduce((sum: number, c: any) => sum + c.refugiosCount, 0);
      const citiesList = e.ciudades.map((c: any) => c.ciudad).join(", ");
      
      const dbStatus = (window as any).estadosAyudaMap?.get(e.estado);
      const isAfectadoLegacy = ZONAS_AFECTADAS.includes(e.estado);
      const status = dbStatus || (isAfectadoLegacy ? 'critico' : null);
      const isAfectado = status === 'critico';
      
      const sanitizedName = ({ "Distrito Capital": "Distrito_Capital" } as Record<string, string>)[e.estado] || e.estado.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/ /g, "_");

      return `
        <div class="card state-card ${isAfectado ? 'card-prioritized' : ''}" style="cursor: default;">
          <div class="card-img">
            <img src="/flags/${sanitizedName}.svg" alt="Bandera de ${e.estado}" loading="lazy" onerror="this.style.display='none';" />
            ${status === 'critico' ? '<span class="badge-prioritized" style="background: var(--red); color: white;">🚨 Zona Crítica</span>' : ''}
            ${status === 'en_camino' ? '<span class="badge-prioritized" style="background: var(--yellow); color: var(--blue-dark);">🚚 Ayuda en camino</span>' : ''}
          </div>
          <div class="card-body">
            <div class="card-top"><h3>${e.estado}</h3><span class="card-badge">${count}</span></div>
            <p class="card-cities">${citiesList}</p>
          </div>
        </div>
      `;
    }).join("");

    mainGrid.innerHTML = html;
  }

  function renderRefugios(filtered: any[]) {
    gridTitle.textContent = "Refugios encontrados";
    resultsCount.textContent = `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`;
    resultsCount.style.display = "inline-block";
    mainGrid.className = "grid-centros"; // Usamos la misma clase css

    if (filtered.length === 0) {
      mainGrid.innerHTML = '<div class="no-results">No se encontraron refugios que coincidan con los criterios.</div>';
      return;
    }

    mainGrid.innerHTML = filtered.map((c: any) => {
      const dbStatus = (window as any).estadosAyudaMap?.get(c.estado);
      const status = dbStatus || (ZONAS_AFECTADAS.includes(c.estado) ? 'critico' : null);
      const isAfectado = status === 'critico';
      
      const aceptaHtml = c.acepta?.length
        ? `<div class="row"><span class="row-label">Aceptan</span><div class="row-value"><div class="tag-group">${c.acepta.map((a: string) => `<span class="tag tag-yellow">${a}</span>`).join("")}</div></div></div>`
        : '';
      const necesitanHtml = c.necesitan?.length
        ? `<div class="row"><span class="row-label">Urgente</span><div class="row-value"><div class="tag-group">${c.necesitan.map((n: string) => `<span class="tag tag-red">${n}</span>`).join("")}</div></div></div>`
        : '';

      return `
        <div class="card centro-card ${isAfectado ? 'card-prioritized' : ''}">
          <div class="card-head-centro">
            <div class="card-icon" style="background: ${isAfectado ? 'var(--red)' : 'var(--blue)'};">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <div class="card-title-area">
              <h3>${c.nombre}</h3>
              <span class="card-loc-meta">${c.ciudad}, ${c.estado}</span>
            </div>
            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
              ${status === 'critico' ? '<span class="badge-prioritized-mini" style="background: var(--red); color: white;">🚨 Crítico</span>' : ''}
              ${status === 'en_camino' ? '<span class="badge-prioritized-mini" style="background: var(--yellow); color: var(--blue-dark);">🚚 En camino</span>' : ''}
              ${c.tipo === 'privado' ? '<span class="badge-prioritized-mini" style="background-color: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe;">🏠 Casa Particular</span>' : ''}
            </div>
          </div>
          <div class="card-body-centro">
            ${c.direccion ? `<div class="row"><span class="row-label">Dirección</span><div class="row-value">${c.direccion}</div></div>` : ''}
            ${c.contacto ? `<div class="row"><span class="row-label">Contacto</span><div class="row-value">${c.contacto}</div></div>` : ''}
            ${c.capacidad ? `<div class="row"><span class="row-label">Capacidad</span><div class="row-value">${c.capacidad}</div></div>` : ''}
            ${aceptaHtml}${necesitanHtml}
          </div>
        </div>
      `;
    }).join("");
  }

  function handleFilter() {
    const q = searchInput.value.toLowerCase().trim();
    const city = citySelect.value;
    const type = typeSelect ? typeSelect.value : "";
    if (!q && !city && !type) { 
        // Si no hay filtro, mostramos todos los refugios listados o agrupados por estado
        // Pero el diseño pide mostrar todos los refugios como tarjetas directamente es mejor para los refugios.
        renderRefugios(refugios);
        return; 
    }

    let filtered = refugios.filter((c: any) => {
      if (city && c.ciudad !== city) return false;
      const cType = c.tipo === 'privado' ? 'privado' : 'oficial';
      if (type && cType !== type) return false;
      if (q) {
        return c.nombre.toLowerCase().includes(q) || c.ciudad.toLowerCase().includes(q)
          || c.estado.toLowerCase().includes(q) || (c.direccion || '').toLowerCase().includes(q)
          || (c.acepta || []).some((a: string) => a.toLowerCase().includes(q))
          || (c.necesitan || []).some((n: string) => n.toLowerCase().includes(q));
      }
      return true;
    });

    renderRefugios(filtered);
  }

  function updateStats() {
    statRefugios.textContent = refugios.length.toString();
    statCiudades.textContent = new Set(refugios.map((c: any) => c.ciudad)).size.toString();
  }

  async function loadData() {
    try {
      dbStatus.textContent = "Conectando...";
      dbStatus.className = "status-badge loading";
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase.from('refugios').select('*').eq('verificado', true);
      if (error) throw error;

      if (data) {
        const { data: statusData, error: statusError } = await supabase
          .from('estados_ayuda')
          .select('*');
          
        if (!statusError && statusData) {
          const map = new Map<string, string>();
          statusData.forEach(s => map.set(s.estado, s.nivel_ayuda));
          (window as any).estadosAyudaMap = map;
        } else {
          (window as any).estadosAyudaMap = new Map();
        }

        refugios = data.sort((a, b) => {
          const dbStatusA = (window as any).estadosAyudaMap?.get(a.estado);
          const dbStatusB = (window as any).estadosAyudaMap?.get(b.estado);
          const aAfectado = dbStatusA === 'critico' || (!dbStatusA && ZONAS_AFECTADAS.includes(a.estado));
          const bAfectado = dbStatusB === 'critico' || (!dbStatusB && ZONAS_AFECTADAS.includes(b.estado));
          if (aAfectado && !bAfectado) return -1;
          if (!aAfectado && bAfectado) return 1;
          return a.estado.localeCompare(b.estado);
        });
        updateStats();
        initCitySelect();
        handleFilter();
        dbStatus.textContent = "En Vivo";
        dbStatus.className = "status-badge live";
      }
    } catch (err) {
      console.error("Supabase connection failed:", err);
      dbStatus.textContent = "Error";
      dbStatus.className = "status-badge offline";
      mainGrid.innerHTML = '<div class="no-results">Hubo un error cargando los refugios.</div>';
    }
  }

  searchInput.addEventListener('input', handleFilter);
  citySelect.addEventListener('change', handleFilter);
  if (typeSelect) typeSelect.addEventListener('change', handleFilter);

  loadData();
  setInterval(loadData, 300000);
</script>
