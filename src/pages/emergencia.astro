---
import Layout from "../layouts/Layout.astro";
import { numeros_nacionales as fallbackNacionales, caracas as fallbackCaracas } from "../data/emergencia";
import { getSupabase } from "../lib/supabase.js";

const catMeta = {
  bomberos: { label: "Bomberos", icon: "fire", color: "#CF142B" },
  proteccion_civil: { label: "Protección Civil", icon: "shield", color: "#D97706" },
  rescate: { label: "Rescate", icon: "ambulance", color: "#059669" },
  policia: { label: "Policía", icon: "police", color: "#1F2937" },
};

let numeros_nacionales = fallbackNacionales;
let caracas = fallbackCaracas;

try {
  const supabase = await getSupabase();
  if (supabase) {
    const { data, error } = await supabase
      .from("numeros_emergencia")
      .select("categoria,subcategoria,nombre,numero,orden")
      .order("orden");
    if (error) throw error;
    if (data && data.length > 0) {
      const bySub = (sub: string) =>
        data
          .filter((r: any) => r.categoria === "caracas" && r.subcategoria === sub)
          .sort((a: any, b: any) => a.orden - b.orden);
      numeros_nacionales = data
        .filter((r: any) => r.categoria === "nacional")
        .sort((a: any, b: any) => a.orden - b.orden)
        .map((r: any) => ({ servicio: r.nombre, numero: r.numero }));
      caracas = {
        bomberos: bySub("bomberos").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        proteccion_civil: bySub("proteccion_civil").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        rescate: bySub("rescate").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        policia: bySub("policia").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        radio_informacion: bySub("radio_informacion").map((r: any) => r.nombre),
      };
    }
  }
} catch (err) {
  console.warn("emergencia: Supabase no disponible, usando fallback local.", err);
}

const caracasTotal = Object.keys(catMeta).reduce((sum, key) => {
  const items = (caracas as any)[key];
  return sum + (items ? items.length : 0);
}, 0) + (caracas.radio_informacion?.length || 0);
---

<Layout title="Números de Emergencia"
  description="Números de emergencia activos en Venezuela 24 horas: Bomberos, Protección Civil, Rescate, Policía, radio informativo. Líneas del 171 y números locales de Caracas."
  showHero={false}
>
  <header class="relative -mt-4 md:-mt-6 mb-6 w-screen ml-[calc(-50vw+50%)] overflow-hidden bg-linear-to-br from-[#991B1B] via-red to-[#DC2626] text-white">
    <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_20px,rgba(255,255,255,0.04)_20px,rgba(255,255,255,0.04)_40px)]" aria-hidden="true"></div>
    <div class="relative max-w-[600px] mx-auto text-center px-5 py-10 sm:py-12">
      <span class="inline-flex items-center gap-1.5 bg-white/20 border border-white/25 text-white text-[0.7rem] font-extrabold uppercase tracking-[0.06em] px-3 py-1 rounded-full mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
        24 horas
      </span>
      <h1 class="text-2xl sm:text-[1.9rem] font-extrabold tracking-tight leading-tight text-balance mb-2">
        Números de <span class="text-[#FCA5A5]">Emergencia</span>
      </h1>
      <p class="text-sm sm:text-[0.9rem] text-white/85 max-w-[460px] mx-auto leading-relaxed text-balance">
        Líneas activas disponibles en Venezuela — <strong class="text-white font-semibold">Bomberos, Protección Civil, Rescate, Policía</strong>
      </p>
    </div>
  </header>

  <div class="flex items-center gap-2.5 bg-[#FEF2F2] border border-[#FECACA] rounded-xl px-4 py-3 mb-5 text-sm text-[#991B1B]">
    <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <span><strong>Mantén la calma.</strong> Llama solo si es una emergencia real para no saturar las líneas.</span>
  </div>

  <details class="group bg-white rounded-xl border border-border overflow-hidden mb-4 shadow-[0_1px_2px_rgba(16,24,40,0.04)]" open>
    <summary class="flex items-center gap-2.5 px-4 py-3 bg-blue text-white cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
      <span class="flex shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </span>
      <h2 class="flex-1 text-[0.95rem] font-bold tracking-tight">Nacional</h2>
      <span class="text-xs font-bold bg-white/20 px-2 py-0.5 rounded-full tabular-nums">{numeros_nacionales.length}</span>
      <svg class="shrink-0 text-white/70 transition-transform duration-200 group-open:rotate-180" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <div class="p-2 flex flex-col group-open:animate-[accordion-down_.2s_ease-out]">
      {numeros_nacionales.map((item: any) => (
        <a href={`tel:${item.numero}`} class="group flex items-center gap-3 px-3 py-3 rounded-lg no-underline text-text min-h-14 transition-colors duration-150 hover:bg-[#F8F9FB]">
          <span class="w-10 h-10 shrink-0 bg-red text-white rounded-xl flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </span>
          <div class="flex-1 min-w-0">
            <span class="block text-base font-extrabold text-text tracking-tight tabular-nums wrap-break-word">{item.numero}</span>
            <span class="block text-xs text-muted leading-tight">{item.servicio}</span>
          </div>
          <svg class="shrink-0 text-red opacity-40 transition-[opacity,transform] duration-200 group-hover:opacity-100 group-hover:translate-x-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </details>

  <div class="flex items-center gap-2.5 px-4 py-3 mb-4 bg-blue text-white rounded-xl shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
    <span class="flex shrink-0">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    </span>
    <h2 class="flex-1 text-[0.95rem] font-bold tracking-tight">Caracas</h2>
    <span class="text-xs font-bold bg-white/20 px-2 py-0.5 rounded-full tabular-nums">{caracasTotal}</span>
  </div>

  {Object.entries(catMeta).map(([key, meta]) => {
    const items = (caracas as any)[key];
    if (!items || items.length === 0) return null;
    return (
      <details class="group bg-white rounded-xl border border-border overflow-hidden mb-4 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
        <summary class="flex items-center gap-2.5 px-4 py-3 bg-[#FAFBFC] cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden border-b border-transparent group-open:border-border">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 text-white" style={`background:${meta.color};`}>
            {meta.icon === 'fire' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/></svg>}
            {meta.icon === 'shield' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            {meta.icon === 'ambulance' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="4" width="16" height="16" rx="2"/><path d="M10 10v4M8 12h4"/><path d="M18 12h3v4h-3"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>}
            {meta.icon === 'police' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2L3 7v6c0 5.25 3.83 10.15 9 11 5.17-.85 9-5.75 9-11V7l-9-5z"/><path d="M12 8v4M12 16h.01"/></svg>}
          </span>
          <h3 class="flex-1 text-sm font-bold tracking-tight text-text">{meta.label}</h3>
          <span class="text-xs font-bold text-muted bg-[#F1F5F9] px-2 py-0.5 rounded-full tabular-nums">{items.length}</span>
          <svg class="shrink-0 text-muted transition-transform duration-200 group-open:rotate-180" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="p-2 flex flex-col group-open:animate-[accordion-down_.2s_ease-out]">
          {items.map((item: any) => (
            <a href={`tel:${item.telefono}`} class="group flex items-center gap-3 px-3 py-3 rounded-lg no-underline text-text min-h-14 transition-colors duration-150 hover:bg-[#F8F9FB]">
              <span class="w-10 h-10 shrink-0 bg-red text-white rounded-xl flex items-center justify-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              </span>
              <div class="flex-1 min-w-0">
                <span class="block text-base font-extrabold text-text tracking-tight tabular-nums wrap-break-word">{item.telefono}</span>
                <span class="block text-xs text-muted leading-tight">{item.nombre}</span>
              </div>
              <svg class="shrink-0 text-red opacity-40 transition-[opacity,transform] duration-200 group-hover:opacity-100 group-hover:translate-x-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </details>
    );
  })}

  <details class="group bg-white rounded-xl border border-border overflow-hidden mb-4 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
    <summary class="flex items-center gap-2.5 px-4 py-3 bg-[#FAFBFC] cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden border-b border-transparent group-open:border-border">
      <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 bg-muted text-white">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      </span>
      <h3 class="flex-1 text-sm font-bold tracking-tight text-text">Radio Informaci&oacute;n</h3>
      <span class="text-xs font-bold text-muted bg-[#F1F5F9] px-2 py-0.5 rounded-full tabular-nums">{caracas.radio_informacion.length}</span>
      <svg class="shrink-0 text-muted transition-transform duration-200 group-open:rotate-180" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <div class="p-2 flex flex-col group-open:animate-[accordion-down_.2s_ease-out]">
      {caracas.radio_informacion.map((freq: string) => (
        <div class="flex items-center gap-3 px-3 py-3 rounded-lg min-h-14">
          <span class="w-10 h-10 shrink-0 bg-[#F1F5F9] text-[#64748B] rounded-xl flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </span>
          <div class="flex-1 min-w-0">
            <span class="block text-base font-extrabold text-text tracking-tight tabular-nums wrap-break-word">{freq}</span>
            <span class="block text-xs text-muted leading-tight">Frecuencia de radio</span>
          </div>
        </div>
      ))}
    </div>
  </details>

  <div class="mt-6 text-center">
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted no-underline px-4 py-2 rounded-lg transition-colors duration-150 hover:bg-[#F1F5F9] hover:text-text">&larr; Volver al inicio</a>
  </div>
</Layout>
