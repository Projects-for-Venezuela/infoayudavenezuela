---
import "../styles/emergencia.css";
import Layout from "../layouts/Layout.astro";
import { numeros_nacionales as fallbackNacionales, caracas as fallbackCaracas } from "../data/emergencia";
import { supabase } from "../lib/supabase.js";

const catMeta = {
  bomberos: { label: "Bomberos", icon: "fire", color: "#CF142B" },
  proteccion_civil: { label: "Protección Civil", icon: "shield", color: "#D97706" },
  rescate: { label: "Rescate", icon: "ambulance", color: "#059669" },
  policia: { label: "Policía", icon: "police", color: "#1F2937" },
};

let numeros_nacionales = fallbackNacionales;
let caracas = fallbackCaracas;

try {
  if (supabase) {
    const { data, error } = await supabase
      .from("numeros_emergencia")
      .select("categoria,subcategoria,nombre,numero,orden")
      .order("orden");
    if (error) throw error;
    if (data && data.length > 0) {
      const bySub = (sub: string) =>
        data
          .filter((r: any) => r.categoria === "caracas" && r.subcategoria === sub)
          .sort((a: any, b: any) => a.orden - b.orden);
      numeros_nacionales = data
        .filter((r: any) => r.categoria === "nacional")
        .sort((a: any, b: any) => a.orden - b.orden)
        .map((r: any) => ({ servicio: r.nombre, numero: r.numero }));
      caracas = {
        bomberos: bySub("bomberos").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        proteccion_civil: bySub("proteccion_civil").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        rescate: bySub("rescate").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        policia: bySub("policia").map((r: any) => ({ nombre: r.nombre, telefono: r.numero })),
        radio_informacion: bySub("radio_informacion").map((r: any) => r.nombre),
      };
    }
  }
} catch (err) {
  console.warn("emergencia: Supabase no disponible, usando fallback local.", err);
}
---

<Layout title="Números de Emergencia"
  description="Números de emergencia activos en Venezuela 24 horas: Bomberos, Protección Civil, Rescate, Policía, radio informativo. Líneas del 171 y números locales de Caracas."
  canonical="https://infoayudavenezuela.vercel.app/emergencia"
  showHero={false}
>
  <header class="emg-hero">
    <div class="emg-hero-bg">
      <div class="emg-hero-content">
        <span class="emg-hero-badge">24 HORAS</span>
        <h1>Números de <span>Emergencia</span></h1>
        <p>Líneas activas disponibles en Venezuela — <strong>Bomberos, Protección Civil, Rescate, Policía</strong></p>
      </div>
    </div>
  </header>

  <div class="emg-alert">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <span><strong>Mantén la calma.</strong> Llama solo si es una emergencia real para no saturar las líneas.</span>
  </div>

  <section class="emg-section">
    <div class="emg-section-head" style="background:#00247D;">
      <span class="emg-section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </span>
      <h2>Nacional</h2>
      <span class="emg-section-count">{numeros_nacionales.length}</span>
    </div>
    <div class="emg-section-body">
      {numeros_nacionales.map((item: any) => (
        <a href={`tel:${item.numero}`} class="emg-row">
          <div class="emg-row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div class="emg-row-info">
            <span class="emg-row-num">{item.numero}</span>
            <span class="emg-row-desc">{item.servicio}</span>
          </div>
          <svg class="emg-row-call" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </section>

  <section class="emg-section">
    <div class="emg-section-head" style="background:#00247D;">
      <span class="emg-section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </span>
      <h2>Caracas</h2>
      <span class="emg-section-count">
        {Object.keys(catMeta).reduce((sum, key) => {
          const items = (caracas as any)[key];
          return sum + (items ? items.length : 0);
        }, 0) + (caracas.radio_informacion?.length || 0)}
      </span>
    </div>
  </section>

  {Object.entries(catMeta).map(([key, meta]) => {
    const items = (caracas as any)[key];
    if (!items || items.length === 0) return null;
    return (
      <section class="emg-subsection">
        <div class="emg-subhead">
          <span class="emg-subicon" style={`background:${meta.color};`}>
            {meta.icon === 'fire' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/></svg>}
            {meta.icon === 'shield' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            {meta.icon === 'ambulance' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="16" height="16" rx="2"/><path d="M10 10v4M8 12h4"/><path d="M18 12h3v4h-3"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>}
            {meta.icon === 'police' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v6c0 5.25 3.83 10.15 9 11 5.17-.85 9-5.75 9-11V7l-9-5z"/><path d="M12 8v4M12 16h.01"/></svg>}
          </span>
          <h3>{meta.label}</h3>
          <span class="emg-section-count">{items.length}</span>
        </div>
        <div class="emg-section-body">
          {items.map((item: any) => (
            <a href={`tel:${item.telefono}`} class="emg-row">
              <div class="emg-row-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div class="emg-row-info">
                <span class="emg-row-num">{item.telefono}</span>
                <span class="emg-row-desc">{item.nombre}</span>
              </div>
              <svg class="emg-row-call" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </section>
    );
  })}

  <section class="emg-subsection">
    <div class="emg-subhead">
      <span class="emg-subicon" style="background:#6B7280;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      </span>
      <h3>Radio Informaci&oacute;n</h3>
      <span class="emg-section-count">{caracas.radio_informacion.length}</span>
    </div>
    <div class="emg-section-body">
      {caracas.radio_informacion.map((freq: string) => (
        <div class="emg-row">
          <div class="emg-row-icon emg-row-icon-muted">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </div>
          <div class="emg-row-info">
            <span class="emg-row-num">{freq}</span>
            <span class="emg-row-desc">Frecuencia de radio</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <div class="emg-footer">
    <a href="/">&larr; Volver al inicio</a>
  </div>
</Layout>
