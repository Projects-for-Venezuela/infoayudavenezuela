---
import Layout from "../layouts/Layout.astro";
import { numeros_nacionales, caracas } from "../data/emergencia";

const catMeta = {
  bomberos: { label: "Bomberos", icon: "\u{1F525}", color: "#CF142B" },
  proteccion_civil: { label: "Protección Civil", icon: "\u{1F6E1}\u{FE0F}", color: "#D97706" },
  rescate: { label: "Rescate", icon: "\u{1F691}", color: "#059669" },
  policia: { label: "Policía", icon: "\u{1F694}", color: "#1F2937" },
};
---

<Layout title="Números de Emergencia">
  <a href="/" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Volver al inicio
  </a>

  <div class="page-header">
    <div class="page-emblem">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    </div>
    <div>
      <h1>Números de Emergencia</h1>
      <p>Líneas activas disponibles las 24 horas</p>
    </div>
  </div>

  <div class="alert-box alert-red">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <span><strong>Mantén la calma.</strong> Llama solo si es una emergencia real para no saturar las líneas.</span>
  </div>

  <section class="cat-section">
    <div class="cat-head" style="background:#00247D;">
      <span class="cat-icon">{'\u{1F3DB}\u{FE0F}'}</span>
      <h2>Nacional</h2>
      <span class="cat-count">{numeros_nacionales.length}</span>
    </div>
    <div class="cat-body">
      {numeros_nacionales.map((item: any) => (
        <a href={`tel:${item.numero}`} class="num-row">
          <div class="num-info">
            <span class="num-number">{item.numero}</span>
            <span class="num-desc">{item.servicio}</span>
          </div>
          <svg class="num-call" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        </a>
      ))}
    </div>
  </section>

  {Object.entries(catMeta).map(([key, meta]) => {
    const items = (caracas as any)[key];
    if (!items || items.length === 0) return null;
    return (
      <section class="cat-section">
        <div class="cat-head" style={`background:${meta.color};`}>
          <span class="cat-icon">{meta.icon}</span>
          <h2>{meta.label}</h2>
          <span class="cat-count">{items.length}</span>
        </div>
        <div class="cat-body">
          {items.map((item: any) => (
            <a href={`tel:${item.telefono}`} class="num-row">
              <div class="num-info">
                <span class="num-number">{item.telefono}</span>
                <span class="num-desc">{item.nombre}</span>
              </div>
              <svg class="num-call" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            </a>
          ))}
        </div>
      </section>
    );
  })}

  <section class="cat-section">
    <div class="cat-head" style="background:#6B7280;">
      <span class="cat-icon">{'\u{1F4FB}'}</span>
      <h2>Radio Información</h2>
      <span class="cat-count">{caracas.radio_informacion.length}</span>
    </div>
    <div class="cat-body">
      {caracas.radio_informacion.map((freq: string) => (
        <div class="num-row">
          <div class="num-info">
            <span class="num-number">{freq}</span>
            <span class="num-desc">Frecuencia de radio</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--red);
    font-size: 0.86rem;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 1.25rem;
    padding: 0.35rem 0.75rem;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: background .15s, border-color .15s;
  }
  .back-link:hover { background: #FEF2F2; border-color: #FECACA; }
  .page-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
  }
  .page-emblem {
    width: 46px; height: 46px;
    background: #FEF2F2;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .page-header h1 { font-size: 1.25rem; font-weight: 700; color: var(--red); }
  .page-header p { font-size: 0.84rem; color: var(--muted); }
  .alert-box {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border-radius: var(--radius);
    border: 1px solid transparent;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.84rem;
  }
  .alert-red {
    background: #FEF2F2;
    border-color: #FECACA;
    color: #991B1B;
  }
  .alert-red svg { flex-shrink: 0; }
  .cat-section {
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .cat-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    color: white;
  }
  .cat-icon { font-size: 1.1rem; line-height: 1; }
  .cat-head h2 { font-size: 0.88rem; font-weight: 600; flex: 1; letter-spacing: 0.01em; }
  .cat-count {
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(255,255,255,0.2);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
  }
  .cat-body { padding: 0.5rem; }
  .num-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background .15s;
    cursor: default;
  }
  a.num-row { cursor: pointer; }
  a.num-row:hover { background: #F8F9FB; }
  .num-info { flex: 1; min-width: 0; }
  .num-number {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 0.05rem;
    word-break: break-word;
  }
  .num-desc {
    display: block;
    font-size: 0.76rem;
    color: var(--muted);
    line-height: 1.3;
  }
  .num-call { color: var(--red); flex-shrink: 0; opacity: 0.5; }
  a.num-row:hover .num-call { opacity: 1; }
  @media (max-width:640px) {
    .num-number { font-size: 0.92rem; }
    .num-row { padding: 0.6rem 0.6rem; }
    .cat-body { padding: 0.35rem; }
  }
</style>
