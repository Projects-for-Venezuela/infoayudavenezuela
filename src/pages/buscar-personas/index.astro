---
import "../../styles/refugios.css";
import "../../styles/index.css";
import Layout from "../../layouts/Layout.astro";
import AlertBox from "../../components/AlertBox.astro";
import EmergenciaCTA from "../../components/EmergenciaCTA.astro";
---

<Layout title="Buscar Personas en Refugios" showHero={false}>
  <header class="ref-hero">
    <div class="ref-hero-bg">
      <div class="ref-hero-content">
        <span class="ref-hero-badge" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);">BÚSQUEDA</span>
        <h1><span>Buscar</span> Personas</h1>
        <p>Localiza a personas desaparecidas y en hospitales — <strong>datos verificados</strong></p>
      </div>
    </div>
  </header>

  <div class="ref-alert">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span><strong>¿No encuentras a alguien?</strong> Solo mostramos datos que han sido verificados oficialmente. Si conoces su ubicación, puedes reportarlo usando nuestros formularios.</span>
  </div>

  <AlertBox />
  <div class="search-filters">
    <div class="search-box" style="flex: 1;">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" id="searchPersonInput" placeholder="Buscar por nombre, apellido o cédula de identidad..." />
    </div>
  </div>

  <div class="section-header">
    <h2 id="gridTitle">Resultados de la búsqueda</h2>
    <span id="resultsCount" class="results-count" style="display: none;"></span>
    <span id="searchStatus" class="status-badge live" style="margin-left: auto; display: none;"></span>
  </div>

  <div class="grid" id="mainGrid">
    <div class="no-results" style="grid-column: 1 / -1; padding: 3rem 1rem; text-align: center; color: var(--muted); display: flex; flex-direction: column; align-items: center; justify-content: center;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 1rem; color: #cbd5e1;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <span>Escribe un nombre o cédula en el buscador de arriba para comenzar.</span>
    </div>
  </div>

  <EmergenciaCTA />
</Layout>

<script>
  import { supabase } from "../../lib/supabase";

  const searchPersonInput = document.getElementById('searchPersonInput') as HTMLInputElement;
  const mainGrid = document.getElementById('mainGrid') as HTMLElement;
  const gridTitle = document.getElementById('gridTitle') as HTMLElement;
  const resultsCount = document.getElementById('resultsCount') as HTMLElement;
  const searchStatus = document.getElementById('searchStatus') as HTMLElement;
  const dbStatus = document.getElementById('dbStatus') as HTMLElement;

  async function init() {
    try {
      if (!supabase) throw new Error("Supabase no disponible");
      // Check connection
      const { error } = await supabase.from('refugiados').select('id').limit(1);
      if (error) throw error;
      
      if (dbStatus) {
        dbStatus.textContent = "En Vivo";
        dbStatus.className = "status-badge live";
      }
    } catch (err) {
      console.error(err);
      if (dbStatus) {
        dbStatus.textContent = "Error";
        dbStatus.className = "status-badge offline";
      }
    }
  }

  init();

  function renderPersonas(personas: any[]) {
    gridTitle.textContent = "Resultados encontrados";
    resultsCount.textContent = `${personas.length} persona${personas.length !== 1 ? 's' : ''}`;
    resultsCount.style.display = "inline-block";
    mainGrid.className = "grid-centros"; // Reuse centro cards layout

    if (personas.length === 0) {
      mainGrid.innerHTML = '<div class="no-results" style="grid-column: 1 / -1; padding: 3rem 1rem; text-align: center; color: var(--muted); display: flex; flex-direction: column; align-items: center; justify-content: center;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 1rem; color: #cbd5e1;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg><span>No se encontraron personas con ese nombre o cédula.</span></div>';
      return;
    }

    mainGrid.innerHTML = personas.map((p: any) => {
      const textColor = p.badge_color === 'var(--yellow)' ? 'var(--text)' : 'white';
      return `
        <div class="card centro-card" style="position: relative;">
          <div class="card-head-centro">
            <div class="card-icon" style="background: ${p.badge_color};">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${textColor}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <div class="card-title-area" style="padding-right: 80px;">
              <h3>${p.nombre}</h3>
              ${p.cedula ? `<span class="card-loc-meta" style="font-weight: 500;">V-${p.cedula}</span>` : ''}
            </div>
            <span class="status-badge" style="position: absolute; top: 1rem; right: 1rem; background: ${p.badge_color}; color: ${textColor}; border: none; font-size: 0.75rem; padding: 0.25rem 0.5rem;">${p.badge_label}</span>
          </div>
          <div class="card-body-centro" style="margin-top: 0.5rem;">
            <div class="row">
              <span class="row-label">${p.tipo === 'Desaparecido' ? 'Últ. Ubicación' : p.tipo === 'Paciente' ? 'Hospital' : 'Refugio'}</span>
              <div class="row-value font-medium" style="color: var(--blue); font-weight: 600;">${p.ubicacion_primaria}</div>
            </div>
            ${p.ubicacion_secundaria ? `
            <div class="row">
              <span class="row-label">${p.tipo === 'Paciente' ? 'Ciudad' : 'Ubicación'}</span>
              <div class="row-value">${p.ubicacion_secundaria}</div>
            </div>` : ''}
            ${p.telefono ? `<div class="row"><span class="row-label">Contacto</span><div class="row-value">${p.telefono}</div></div>` : ''}
            ${p.detalle_1_value ? `<div class="row"><span class="row-label">${p.detalle_1_label}</span><div class="row-value">${p.detalle_1_value}</div></div>` : ''}
          </div>
        </div>
      `;
    }).join("");
  }

  async function performSearch() {
    const q = searchPersonInput.value.trim();
    if (!q || q.length < 3) {
      mainGrid.innerHTML = `
        <div class="no-results" style="grid-column: 1 / -1; padding: 3rem 1rem; text-align: center; color: var(--muted); display: flex; flex-direction: column; align-items: center; justify-content: center;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 1rem; color: #cbd5e1;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <span>Ingresa al menos 3 caracteres para buscar.</span>
        </div>
      `;
      gridTitle.textContent = "Resultados de la búsqueda";
      resultsCount.style.display = "none";
      searchStatus.style.display = "none";
      return;
    }

    try {
      searchStatus.textContent = "Buscando...";
      searchStatus.className = "status-badge loading";
      searchStatus.style.display = "inline-block";

      if (!supabase) throw new Error("Supabase no disponible");

      const [refugiadosRes, desaparecidosRes, pacientesRes] = await Promise.all([
        supabase
          .from('refugiados')
          .select('*, refugios(nombre, ciudad, estado)')
          .or(`nombre_completo.ilike.%${q}%,cedula.ilike.%${q}%`)
          .limit(20),
        supabase
          .from('desaparecidos')
          .select('*')
          .or(`nombre_completo.ilike.%${q}%,cedula.ilike.%${q}%`)
          .limit(20),
        supabase
          .from('pacientes')
          .select('*')
          .or(`nombre_paciente.ilike.%${q}%,cedula.ilike.%${q}%`)
          .limit(20)
      ]);

      if (refugiadosRes.error) throw refugiadosRes.error;
      if (desaparecidosRes.error) throw desaparecidosRes.error;
      if (pacientesRes.error) throw pacientesRes.error;

      const unifiedPersonas = [
        ...(refugiadosRes.data || []).map((p: any) => ({
          tipo: 'Refugiado',
          nombre: p.nombre_completo,
          cedula: p.cedula,
          ubicacion_primaria: p.refugios?.nombre || 'Desconocido',
          ubicacion_secundaria: p.refugios?.ciudad ? `${p.refugios.ciudad}, ${p.refugios.estado || ''}` : p.refugios?.estado,
          telefono: p.telefono,
          detalle_1_label: 'Salud',
          detalle_1_value: p.estado_salud,
          badge_label: 'En Refugio',
          badge_color: 'var(--blue)'
        })),
        ...(desaparecidosRes.data || []).map((p: any) => ({
          tipo: 'Desaparecido',
          nombre: p.nombre_completo,
          cedula: p.cedula,
          ubicacion_primaria: p.ultima_ubicacion || 'Desconocida',
          ubicacion_secundaria: null,
          telefono: p.fuente,
          detalle_1_label: 'Descripción',
          detalle_1_value: p.descripcion,
          badge_label: p.status || 'Buscando',
          badge_color: p.status?.toLowerCase() === 'encontrado' ? '#15803d' : 'var(--red)'
        })),
        ...(pacientesRes.data || []).map((p: any) => ({
          tipo: 'Paciente',
          nombre: p.nombre_paciente,
          cedula: p.cedula,
          ubicacion_primaria: p.hospital || 'Desconocido',
          ubicacion_secundaria: p.ciudad ? `${p.ciudad}, ${p.estado || ''}` : p.estado,
          telefono: p.contacto,
          detalle_1_label: 'Necesitan',
          detalle_1_value: p.necesitan,
          badge_label: p.estatus || 'Paciente',
          badge_color: 'var(--yellow)'
        }))
      ];

      searchStatus.style.display = "none";
      renderPersonas(unifiedPersonas);

    } catch (err) {
      console.error(err);
      searchStatus.textContent = "Error";
      searchStatus.className = "status-badge offline";
      mainGrid.innerHTML = '<div class="no-results" style="grid-column: 1 / -1; padding: 3rem 1rem; text-align: center; color: var(--muted); display: flex; flex-direction: column; align-items: center; justify-content: center;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 1rem; color: #cbd5e1;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg><span>Hubo un error al buscar personas.</span></div>';
    }
  }

  // Debounce function
  function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): (...args: Parameters<T>) => void {
    let t: ReturnType<typeof setTimeout> | null = null;
    return (...args: Parameters<T>) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    };
  }

  const debouncedSearch = debounce(performSearch, 400);

  searchPersonInput.addEventListener('input', debouncedSearch);

</script>
