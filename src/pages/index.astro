---
import Layout from "../layouts/Layout.astro";
import EnlacesSection from "../components/EnlacesSection.astro";
import AlertBox from "../components/AlertBox.astro";
import SismoAlert from "../components/SismoAlert.astro";
import StatsRow from "../components/StatsRow.astro";
import SearchFilters from "../components/SearchFilters.astro";
import InsumosSection from "../components/InsumosSection.astro";
import DonacionSangreSection from "../components/DonacionSangreSection.astro";
import RefugiosSection from "../components/RefugiosSection.astro";
import EmergenciaCTA from "../components/EmergenciaCTA.astro";
import PersonasStatsRow from "../components/PersonasStatsRow.astro";
import { estados, flagUrl, ZONAS_AFECTADAS, sortEstados, resolveEstado } from "../data/centros";

const fallbackCentros = estados.flatMap((e: any) => 
  e.ciudades.flatMap((c: any) => 
    c.centros.map((cnt: any) => ({
      ...cnt,
      estado: e.estado,
      ciudad: c.ciudad
    }))
  )
);

const estadosOrdenados = [...estados].filter(e => resolveEstado(e.estado) === e.estado).sort(sortEstados);

// Separar nacionales de internacional para la vista estática
const estadosNacionales = estadosOrdenados.filter(e => e.estado !== 'Internacional');
const estadoInternacional = estadosOrdenados.find(e => e.estado === 'Internacional');

// Estadísticas estáticas iniciales
const totalCentros = fallbackCentros.length;
const totalEstados = estados.length;
const totalCiudades = new Set(fallbackCentros.map((c: any) => c.ciudad)).size;

const fallbackEnlaces = [
  {
    titulo: "Cruz Roja Venezolana",
    descripcion: "Asistencia médica de emergencia, primeros auxilios y canalización de donaciones oficiales.",
    url: "https://cruzrojavenezolana.org",
    categoria: "Salud / Asistencia"
  },
  {
    titulo: "Psicólogos sin Fronteras Venezuela",
    descripcion: "Apoyo psicológico y contención emocional para afectados y familiares de la tragedia.",
    url: "https://psfvenezuela.org",
    categoria: "Salud Mental"
  },
  {
    titulo: "Protección Civil Venezuela",
    descripcion: "Información oficial de alertas, reportes de daños y rescates a nivel nacional.",
    url: "http://www.proteccioncivil.gob.ve",
    categoria: "Oficial"
  }
];
---

<Layout title="Inicio"
  description="Directorio de centros de acopio verificados en Venezuela. Encuentra dónde donar agua, alimentos, medicinas e insumos para los afectados por el sismo del 24 de junio de 2026. Cobertura nacional e internacional."
>
  <div id="fallbackData" 
       data-centros={JSON.stringify(fallbackCentros)} 
       data-estados={JSON.stringify(estadosOrdenados)}
       style="display: none;"></div>

       <SismoAlert />
       
       <AlertBox />

  <StatsRow {totalCentros} {totalEstados} {totalCiudades} />

  <PersonasStatsRow/>

  <button id="homeReportarBtn" type="button" class="flex items-center justify-center gap-2 w-full mb-3 px-5 py-3.5 rounded-xl text-sm font-bold bg-[#FEF2F2] text-[#991B1B] border-2 border-[#FECACA] cursor-pointer min-h-12 select-none transition-[background-color,border-color,box-shadow] duration-150 hover:bg-[#FEE2E2] hover:border-[#FCA5A5] hover:shadow-md">
    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    Reportar una necesidad urgente
  </button>

  <div id="necesidadesPreviewSection" class="bg-white border border-border rounded-xl p-4 sm:p-5 mb-4 shadow-sm" style="display: none;">
    <div class="flex items-center gap-2 text-[0.95rem] font-bold tracking-tight mb-3">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-red" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      Necesidades Urgentes
      <span id="necPreviewCount" class="bg-red text-white text-[0.62rem] font-bold px-2 py-0.5 rounded-full tabular-nums"></span>
    </div>
    <div id="necPreviewList" class="flex flex-col"></div>
    <a href="/necesidades" class="inline-flex items-center justify-center gap-1 w-full mt-3 px-4 py-2.5 rounded-lg text-sm font-semibold text-red border-2 border-[#FECACA] no-underline min-h-11 transition-colors duration-150 hover:bg-[#FEF2F2] hover:border-red">Ver todas las necesidades &rarr;</a>
  </div>

  <SearchFilters />

  <button id="homeSugerirBtn" type="button" class="flex items-center justify-center gap-2 w-full mb-5 px-5 py-3.5 rounded-xl text-sm font-bold bg-yellow text-blue-dark border-2 border-gold cursor-pointer min-h-12 select-none transition-[background-color,border-color,box-shadow,transform] duration-150 hover:bg-[#F5C200] hover:-translate-y-0.5 hover:shadow-md">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
    Sugerir un centro de acopio
  </button>

  <div class="flex justify-between items-center gap-3 mb-4 pb-2 border-b border-border">
    <h2 id="gridTitle" class="text-base font-bold tracking-tight text-text text-balance">Estados con centros de acopio</h2>
    <span id="resultsCount" class="text-xs font-semibold text-muted bg-[#F1F5F9] px-2 py-0.5 rounded-full border border-border shrink-0" style="display: none;"></span>
  </div>

  <div class="mb-6">
    <div id="zonesFilter" class="flex gap-2 overflow-x-auto pb-2 scrollbar-none" role="group" aria-label="Filtrar estados por nivel de ayuda">
      <button data-filter="all" type="button" aria-pressed="true" class="inline-flex items-center gap-1.5 shrink-0 whitespace-nowrap px-4 py-2 rounded-full border border-border bg-white text-text text-xs font-semibold cursor-pointer min-h-11 transition-colors duration-150 aria-pressed:bg-blue aria-pressed:border-blue aria-pressed:text-white">Todas las zonas</button>
      <button data-filter="critico" type="button" aria-pressed="false" class="inline-flex items-center gap-1.5 shrink-0 whitespace-nowrap px-4 py-2 rounded-full border border-[#FCA5A5] bg-white text-red-dark text-xs font-semibold cursor-pointer min-h-11 transition-colors duration-150 aria-pressed:bg-red aria-pressed:border-red aria-pressed:text-white">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Requiere ayuda urgente
      </button>
      <button data-filter="en_camino" type="button" aria-pressed="false" class="inline-flex items-center gap-1.5 shrink-0 whitespace-nowrap px-4 py-2 rounded-full border border-[#FDE047] bg-white text-amber text-xs font-semibold cursor-pointer min-h-11 transition-colors duration-150 aria-pressed:bg-yellow aria-pressed:border-gold aria-pressed:text-blue-dark">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Ayuda en camino
      </button>
      <button data-filter="cubierto" type="button" aria-pressed="false" class="inline-flex items-center gap-1.5 shrink-0 whitespace-nowrap px-4 py-2 rounded-full border border-[#86EFAC] bg-white text-green text-xs font-semibold cursor-pointer min-h-11 transition-colors duration-150 aria-pressed:bg-[#22C55E] aria-pressed:border-[#22C55E] aria-pressed:text-white">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Cubierto
      </button>
    </div>
  </div>

  <div id="mainGrid" class="grid gap-4 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]">
    {estadosNacionales.map(({ estado, ciudades }) => {
      const count = ciudades.reduce((s: number, c: any) => s + c.centros.length, 0);
      const cities = ciudades.map((c: any) => c.ciudad).join(", ");
      const isAfectado = ZONAS_AFECTADAS.includes(estado);
      const slugName = estado.replace(/ \/ /g, "--").replace(/ /g, "_");
      return (
        <a href={`/estado/${slugName}`}
           class={`state-card flex items-center gap-3 bg-white border rounded-xl p-3.5 no-underline shadow-[0_1px_2px_rgba(16,24,40,0.04)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:shadow-[0_1px_2px_rgba(16,24,40,0.04),0_8px_24px_rgba(16,24,40,0.08)] ${isAfectado ? 'border-[#FCA5A5] bg-[#FFFAFA] hover:border-[#F87171]' : 'border-border hover:border-[#C7CDD8]'}`}
           data-name={estado.toLowerCase() + (estado === "La Guaira" ? " vargas" : "") + (estado === "Distrito Capital" ? " caracas" : "")}>
          <span class="w-14 h-10 rounded-md bg-[#F1F5F9] border border-border shrink-0 overflow-hidden flex items-center justify-center shadow-sm">
            <img src={flagUrl(estado)} alt={`Bandera de ${estado}`} loading="lazy" width="56" height="40" onerror="this.style.display='none';" class="w-full h-full object-cover" />
          </span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-sm font-bold tracking-tight text-text truncate">{estado}</h3>
              <span class="bg-blue text-white text-xs font-bold px-2 py-0.5 rounded-full min-w-[26px] text-center tabular-nums shrink-0">{count}</span>
            </div>
            <p class="text-xs text-muted truncate leading-relaxed mt-0.5">{cities}</p>
            {isAfectado && (
              <span class="inline-flex items-center gap-1 mt-1.5 text-[0.6rem] font-bold uppercase tracking-wide text-red">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/></svg>
                Zona afectada
              </span>
            )}
          </div>
        </a>
      );
    })}

    {estadoInternacional && (
      <>
        <div class="col-span-full mt-4 mb-1 flex items-center gap-2 pb-2 border-b border-border">
          <h2 class="flex items-center gap-2 text-base font-bold tracking-tight text-text">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            Apoyo Internacional</h2>
        </div>
        <a href="/estado/internacional"
           class="state-card flex items-center gap-3 bg-white border border-border rounded-xl p-3.5 no-underline transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-[#C7CDD8] hover:shadow-[0_8px_24px_rgba(16,24,40,0.08)]">
          <span class="w-14 h-10 rounded-md bg-[#E0F2FE] border border-border shrink-0 flex items-center justify-center">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-sm font-bold tracking-tight text-text truncate">Internacional</h3>
              <span class="bg-blue text-white text-xs font-bold px-2 py-0.5 rounded-full min-w-[26px] text-center tabular-nums shrink-0">{estadoInternacional.ciudades.reduce((s: number, c: any) => s + c.centros.length, 0)}</span>
            </div>
            <p class="text-xs text-muted truncate leading-relaxed mt-0.5">{estadoInternacional.ciudades.map((c: any) => c.ciudad).join(" • ")}</p>
          </div>
        </a>
      </>
    )}
  </div>

  <DonacionSangreSection />

  <InsumosSection />

  <RefugiosSection />

  <EnlacesSection enlaces={fallbackEnlaces} />

  <EmergenciaCTA />
</Layout>

<script>
  import { getSupabase } from "../lib/supabase";
  import { ZONAS_AFECTADAS, sortCentros } from "../data/centros";
  import { escapeHtml, escapeArray, safeUrl } from "../lib/escape";

  const fallbackDataEl = document.getElementById('fallbackData') as HTMLElement;
  const fallbackCentros = JSON.parse(fallbackDataEl.dataset.centros || '[]');
  const fallbackEstados = JSON.parse(fallbackDataEl.dataset.estados || '[]');

  let centros: any[] = [...fallbackCentros];
  let estados: any[] = [...fallbackEstados];
  let estadosAyudaMap = new Map<string, string>(); // estado -> nivel_ayuda
  let currentZoneFilter = 'all';

  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const citySelect = document.getElementById('citySelect') as HTMLSelectElement;
  const mainGrid = document.getElementById('mainGrid') as HTMLElement;
  const gridTitle = document.getElementById('gridTitle') as HTMLElement;
  const resultsCount = document.getElementById('resultsCount') as HTMLElement;
  const dbStatus = document.getElementById('dbStatus') as HTMLElement;
  const statCentros = document.getElementById('statCentros') as HTMLElement;
  const statEstados = document.getElementById('statEstados') as HTMLElement;
  const statCiudades = document.getElementById('statCiudades') as HTMLElement;

  // Utilidad para extraer código de país de la ciudad internacional
  function getCountryCode(locationStr: string) {
    const loc = locationStr.toLowerCase();
    if (loc.includes('colombia')) return 'co';
    if (loc.includes('chile')) return 'cl';
    if (loc.includes('argentina')) return 'ar';
    if (loc.includes('peru') || loc.includes('perú')) return 'pe';
    if (loc.includes('ecuador')) return 'ec';
    if (loc.includes('mexico') || loc.includes('méxico')) return 'mx';
    if (loc.includes('españa') || loc.includes('spain')) return 'es';
    if (loc.includes('usa') || loc.includes('eeuu') || loc.includes('estados unidos') || loc.includes('miami') || loc.includes('florida')) return 'us';
    if (loc.includes('panama') || loc.includes('panamá')) return 'pa';
    if (loc.includes('brasil') || loc.includes('brazil')) return 'br';
    if (loc.includes('uruguay')) return 'uy';
    if (loc.includes('costa rica')) return 'cr';
    if (loc.includes('republica dominicana')) return 'do';
    return null;
  }

  // Inicializar ciudades en el select
  function initCitySelect() {
    const citiesSet = new Set(centros.map((c: any) => c.ciudad));
    const uniqueCities = Array.from(citiesSet) as string[];
    const affectedCities: string[] = [];
    const internationalCities: string[] = [];
    const otherCities: string[] = [];

    uniqueCities.forEach((city: string) => {
      const sample = centros.find((c: any) => c.ciudad === city);
      if (sample) {
        if (ZONAS_AFECTADAS.includes(sample.estado)) {
          affectedCities.push(city);
        } else if (sample.estado === 'Internacional') {
          internationalCities.push(city);
        } else {
          otherCities.push(city);
        }
      }
    });

    affectedCities.sort();
    internationalCities.sort();
    otherCities.sort();

    citySelect.innerHTML = '<option value="">Todas las ciudades</option>';

    if (affectedCities.length > 0) {
      const optGroupAffected = document.createElement('optgroup');
      optGroupAffected.label = 'Zonas Afectadas por Sismo';
      affectedCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = city;
        optGroupAffected.appendChild(opt);
      });
      citySelect.appendChild(optGroupAffected);
    }

    if (otherCities.length > 0) {
      const optGroupOther = document.createElement('optgroup');
      optGroupOther.label = 'Otras ciudades nacionales';
      otherCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = city;
        optGroupOther.appendChild(opt);
      });
      citySelect.appendChild(optGroupOther);
    }

    if (internationalCities.length > 0) {
      const optGroupIntl = document.createElement('optgroup');
      optGroupIntl.label = 'Apoyo Internacional';
      internationalCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = city;
        optGroupIntl.appendChild(opt);
      });
      citySelect.appendChild(optGroupIntl);
    }
  }

  function renderEstados() {
    gridTitle.textContent = "Estados con centros de acopio";
    resultsCount.style.display = "none";
    mainGrid.className = "grid gap-4 grid-cols-[repeat(auto-fill,minmax(260px,1fr))]";

    const agrupado = centros.reduce((acc: { em: Map<string, any>, ea: any[] }, item: any) => {
      let edto = acc.em.get(item.estado);
      if (!edto) {
        edto = { estado: item.estado, ciudades: [] as any[], cm: new Map<string, any>() };
        acc.em.set(item.estado, edto);
        acc.ea.push(edto);
      }
      let cdto = edto.cm.get(item.ciudad);
      if (!cdto) {
        cdto = { ciudad: item.ciudad, centrosCount: 0 };
        edto.cm.set(item.ciudad, cdto);
        edto.ciudades.push(cdto);
      }
      cdto.centrosCount++;
      return acc;
    }, { em: new Map<string, any>(), ea: [] as any[] }).ea.map((e: any) => ({ estado: e.estado, ciudades: e.ciudades }));

    // Separar Internacional de Nacionales
    const nacionales = agrupado.filter((e: any) => e.estado !== 'Internacional');
    const internacional = agrupado.find((e: any) => e.estado === 'Internacional');

    nacionales.sort((a: any, b: any) => {
      const aAfectado = ZONAS_AFECTADAS.includes(a.estado);
      const bAfectado = ZONAS_AFECTADAS.includes(b.estado);
      if (aAfectado && !bAfectado) return -1;
      if (!aAfectado && bAfectado) return 1;
      return a.estado.localeCompare(b.estado);
    });

    if (agrupado.length === 0) {
      mainGrid.innerHTML = '<div class="col-span-full bg-white border border-border rounded-xl p-10 text-center text-muted text-sm">No se encontraron centros de acopio activos.</div>';
      return;
    }

    let html = nacionales.map((e: any) => {
      const count = e.ciudades.reduce((sum: number, c: any) => sum + c.centrosCount, 0);
      const citiesList = escapeHtml(e.ciudades.map((c: any) => c.ciudad).join(", "));
      const slugName = e.estado.replace(/ \/ /g, "--").replace(/ /g, "_");
      
      const isAfectadoLegacy = ZONAS_AFECTADAS.includes(e.estado);
      const dbStatus = estadosAyudaMap.get(e.estado);
      const status = dbStatus || (isAfectadoLegacy ? 'critico' : null);
      const isAfectado = status !== null;
      
      // Filter logic
      if (currentZoneFilter !== 'all' && status !== currentZoneFilter) {
        return '';
      }

      const sanitizedName = ({ "Distrito Capital": "Distrito_Capital" } as Record<string, string>)[e.estado] || e.estado.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/ /g, "_");
      const safeEstado = escapeHtml(e.estado);
      const safeAlt = escapeHtml(`Bandera de ${e.estado}`);
      
      let borderCls = 'border-border hover:border-[#C7CDD8]';
      let statusPill = '';
      if (status === 'critico') {
        borderCls = 'border-[#FCA5A5] bg-[#FFFAFA] hover:border-[#F87171]';
        statusPill = '<span class="inline-flex items-center gap-1 mt-1.5 text-[0.6rem] font-bold uppercase tracking-wide text-red"><svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/></svg> Requiere ayuda urgente</span>';
      } else if (status === 'en_camino') {
        borderCls = 'border-[#FDE047] bg-[#FFFEF5] hover:border-[#FACC15]';
        statusPill = '<span class="inline-flex items-center gap-1 mt-1.5 text-[0.6rem] font-bold uppercase tracking-wide text-amber"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg> Ayuda en camino</span>';
      } else if (status === 'cubierto') {
        borderCls = 'border-[#86EFAC] bg-[#F6FEF9] hover:border-[#4ADE80]';
        statusPill = '<span class="inline-flex items-center gap-1 mt-1.5 text-[0.6rem] font-bold uppercase tracking-wide text-green"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="20 6 9 17 4 12"></polyline></svg> Cubierto</span>';
      }

      return `
        <a href="/estado/${slugName}" class="flex items-center gap-3 bg-white border rounded-xl p-3.5 no-underline shadow-[0_1px_2px_rgba(16,24,40,0.04)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:shadow-[0_1px_2px_rgba(16,24,40,0.04),0_8px_24px_rgba(16,24,40,0.08)] ${borderCls}">
          <span class="w-14 h-10 rounded-md bg-[#F1F5F9] border border-border shrink-0 overflow-hidden flex items-center justify-center shadow-sm"><img src="/flags/${sanitizedName}.webp" alt="${safeAlt}" loading="lazy" width="56" height="40" onerror="this.style.display='none';" class="w-full h-full object-cover" /></span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-sm font-bold tracking-tight text-text truncate">${safeEstado}</h3>
              <span class="bg-blue text-white text-xs font-bold px-2 py-0.5 rounded-full min-w-[26px] text-center tabular-nums shrink-0">${count}</span>
            </div>
            <p class="text-xs text-muted truncate leading-relaxed mt-0.5">${citiesList}</p>
            ${statusPill}
          </div>
        </a>
      `;
    }).join("");

    if (internacional) {
      const count = internacional.ciudades.reduce((sum: number, c: any) => sum + c.centrosCount, 0);
      const citiesList = escapeHtml(internacional.ciudades.map((c: any) => c.ciudad).join(" • "));
      html += `
        <div class="col-span-full mt-2 mb-1 flex items-center gap-2 pb-2 border-b border-border">
          <h2 class="flex items-center gap-2 text-base font-bold tracking-tight text-text"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Apoyo Internacional</h2>
        </div>
        <a href="/estado/Internacional" class="flex items-center gap-3 bg-white border border-border rounded-xl p-3.5 no-underline transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-[#C7CDD8] hover:shadow-[0_8px_24px_rgba(16,24,40,0.08)]">
          <span class="w-14 h-10 rounded-md bg-[#E0F2FE] border border-border shrink-0 flex items-center justify-center"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-sm font-bold tracking-tight text-text truncate">Internacional</h3>
              <span class="bg-blue text-white text-xs font-bold px-2 py-0.5 rounded-full min-w-[26px] text-center tabular-nums shrink-0">${count}</span>
            </div>
            <p class="text-xs text-muted truncate leading-relaxed mt-0.5">${citiesList}</p>
          </div>
        </a>
      `;
    }

    mainGrid.innerHTML = html;
  }

  function renderCentros(filtered: any[]) {
    gridTitle.textContent = "Centros de acopio encontrados";
    resultsCount.textContent = `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`;
    resultsCount.style.display = "inline-block";
    mainGrid.className = "grid gap-4 grid-cols-[repeat(auto-fill,minmax(300px,1fr))]";

    if (filtered.length === 0) {
      mainGrid.innerHTML = '<div class="col-span-full bg-white border border-border rounded-xl p-10 text-center text-muted text-sm">No se encontraron centros de acopio que coincidan con los criterios.</div>';
      return;
    }

    mainGrid.innerHTML = filtered.map((c: any) => {
      const dbStatus = estadosAyudaMap.get(c.estado);
      const isAfectado = dbStatus === 'critico' || (!dbStatus && ZONAS_AFECTADAS.includes(c.estado));
      const isInternacional = c.estado === 'Internacional';

      const safeNombre = escapeHtml(c.nombre);
      const safeCiudad = escapeHtml(c.ciudad);
      const safeEstado = escapeHtml(c.estado);
      const safeDireccion = escapeHtml(c.direccion);
      const safeContacto = escapeHtml(c.contacto);
      const safeHora = escapeHtml(c.hora);
      const safeZelle = escapeHtml(c.zelle);
      const safePagoMovil = escapeHtml(c.pago_movil);
      const safeAcepta = escapeArray(c.acepta);
      const safeNecesitan = escapeArray(c.necesitan);

      const lblCls = 'text-[0.68rem] font-semibold text-muted uppercase tracking-wide min-w-[64px] shrink-0 pt-0.5';
      const valCls = 'text-sm text-text flex-1 leading-relaxed min-w-0 break-words';
      const row = (label: string, value: string) => `<div class="flex gap-2 items-start"><span class="${lblCls}">${label}</span><div class="${valCls}">${value}</div></div>`;
      const tagYellow = 'inline-block text-xs px-2.5 py-1 rounded-full border font-medium bg-[#FFFBEB] text-amber border-[#FDE68A]';
      const tagRed = 'inline-block text-xs px-2.5 py-1 rounded-full border font-medium bg-[#FEF2F2] text-red border-[#FECACA]';

      const aceptaHtml = safeAcepta.length
        ? row('Aceptan', `<div class="flex flex-wrap gap-1">${safeAcepta.map((a: string) => `<span class="${tagYellow}">${a}</span>`).join("")}</div>`)
        : '';
      const necesitanHtml = safeNecesitan.length
        ? row('Urgente', `<div class="flex flex-wrap gap-1">${safeNecesitan.map((n: string) => `<span class="${tagRed}">${n}</span>`).join("")}</div>`)
        : '';

      let flagHtml = '';
      if (isInternacional) {
        const countryCode = getCountryCode(c.ciudad);
        if (countryCode) {
          flagHtml = `<img src="https://flagcdn.com/20x15/${countryCode}.png" alt="Bandera" class="inline-block align-text-bottom mr-1.5 rounded-[2px]" />`;
        } else {
          flagHtml = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block align-text-bottom mr-1" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> `;
        }
      }

      const iconBg = isAfectado ? 'bg-red' : isInternacional ? 'bg-[#0284C7]' : 'bg-blue';

      return `
        <div class="flex flex-col bg-white border ${isAfectado ? 'border-[#FCA5A5] bg-[#FFFAFA]' : 'border-border'} rounded-xl overflow-hidden transition-[box-shadow,border-color] duration-150 hover:shadow-md hover:border-[#C7CDD8]">
          <div class="flex items-center gap-2.5 pt-3.5 px-4">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 ${iconBg}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                ${isInternacional
                  ? '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>'
                  : '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>'
                }
              </svg>
            </div>
            <div class="flex flex-col flex-1 min-w-0">
              <h3 class="text-sm font-bold tracking-tight text-text leading-snug">${safeNombre}</h3>
              <span class="text-xs text-muted font-medium truncate">${flagHtml}${isInternacional ? safeCiudad : `${safeCiudad}, ${safeEstado}`}</span>
            </div>
            ${isAfectado ? '<span class="shrink-0 inline-flex items-center gap-1 bg-red text-white text-[0.6rem] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded"><svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/></svg>Zona Afectada</span>' : ''}
          </div>
          <div class="px-4 pt-2.5 pb-3.5 flex flex-col gap-1.5">
            ${c.direccion ? row('Dirección', safeDireccion) : ''}
            ${c.contacto ? row('Contacto', safeContacto) : ''}
            ${c.hora ? row('Horario', safeHora) : ''}
            ${aceptaHtml}${necesitanHtml}
            ${c.zelle ? row('Zelle', safeZelle) : ''}
            ${c.pago_movil ? row('Pago Móvil', safePagoMovil) : ''}
          </div>
        </div>
      `;
    }).join("");
  }

  function handleFilter() {
    const q = searchInput.value.toLowerCase().trim();
    const city = citySelect.value;
    if (!q && !city) { renderEstados(); return; }

    let filtered = centros.filter((c: any) => {
      if (city && c.ciudad !== city) return false;
      if (q) {
        return c.nombre.toLowerCase().includes(q) || c.ciudad.toLowerCase().includes(q)
          || c.estado.toLowerCase().includes(q) || (c.direccion || '').toLowerCase().includes(q)
          || (c.acepta || []).some((a: string) => a.toLowerCase().includes(q))
          || (c.necesitan || []).some((n: string) => n.toLowerCase().includes(q));
      }
      return true;
    });

    filtered.sort(sortCentros);
    renderCentros(filtered);
  }

  function updateStats() {
    statCentros.textContent = centros.length.toString();
    statEstados.textContent = new Set(centros.map((c: any) => c.estado)).size.toString();
    statCiudades.textContent = new Set(centros.map((c: any) => c.ciudad)).size.toString();
  }

  const STATUS_BASE = "inline-flex items-center gap-1 text-[0.7rem] font-bold px-2 py-0.5 rounded-full uppercase tracking-wide shrink-0";
  const STATUS_LOADING = STATUS_BASE + " bg-[#E2E8F0] text-[#64748B]";
  const STATUS_LIVE = STATUS_BASE + " bg-[#DCFCE7] text-[#15803D] border border-[#BBF7D0]";
  const STATUS_OFFLINE = STATUS_BASE + " bg-[#FEF3C7] text-[#D97706] border border-[#FDE68A]";

  async function loadData() {
    try {
      dbStatus.textContent = "Conectando...";
      dbStatus.className = STATUS_LOADING;
      const supabase = await getSupabase();
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase
        .from('centros_acopio')
        .select('id,nombre,ciudad,estado,direccion,contacto,hora,acepta,necesitan,zelle,pago_movil,verificado')
        .eq('verificado', true);
      if (error) throw error;
      
      const { data: statusData, error: statusError } = await supabase
        .from('estados_ayuda')
        .select('*');
        
      if (!statusError && statusData) {
        estadosAyudaMap.clear();
        statusData.forEach(s => estadosAyudaMap.set(s.estado, s.nivel_ayuda));
      }

      if (data && data.length > 0) {
        centros = data;
        updateStats();
        initCitySelect();
        handleFilter();
        dbStatus.textContent = "En Vivo";
        dbStatus.className = STATUS_LIVE;
      } else {
        dbStatus.textContent = "Offline (Local)";
        dbStatus.className = "status-badge offline";
      }
    } catch (err) {
      console.error("Supabase connection failed, using offline fallback:", err);
      dbStatus.textContent = "Offline (Local)";
      dbStatus.className = STATUS_OFFLINE;
      initCitySelect();
      handleFilter();
    }
  }

  // --- Necesidades Urgentes Preview ---
  const necSection = document.getElementById('necesidadesPreviewSection') as HTMLElement;
  const necPreviewList = document.getElementById('necPreviewList') as HTMLElement;
  const necPreviewCount = document.getElementById('necPreviewCount') as HTMLElement;

  async function loadNecesidadesPreview() {
    try {
      const supabase = await getSupabase();
      if (!supabase) return;
      const { data, error } = await supabase
        .from('necesidades_urgentes')
        .select('*')
        .eq('verificado', true)
        .order('created_at', { ascending: false })
        .limit(5);

      if (error) throw error;

      if (data && data.length > 0) {
        necPreviewCount.textContent = data.length.toString();
        necPreviewList.innerHTML = data.map((n: any) => {
          const needRaw = n.que_necesitan || '';
          const needPreview = escapeHtml(needRaw.length > 80 ? needRaw.substring(0, 80) + '...' : needRaw);
          const lugar = escapeHtml(n.lugar);
          const ubic = escapeHtml(`${n.ciudad}, ${n.estado}`);
          return `
            <a href="/necesidades" class="flex gap-2.5 py-2.5 border-b border-[#F1F5F9] last:border-0 no-underline text-text transition-opacity duration-150 hover:opacity-80">
              <div class="w-7 h-7 shrink-0 bg-[#FEF2F2] text-red rounded-lg flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-semibold text-text mb-0.5 truncate">${lugar}</h4>
                <p class="text-xs text-muted truncate flex items-center gap-1"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true" focusable="false"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> ${ubic}</p>
                <p class="text-xs text-red-dark font-medium truncate">${needPreview}</p>
              </div>
            </a>
          `;
        }).join("");
        necSection.style.display = 'block';
      }
    } catch (err) {
      // Silently fail - no needs section shown
    }
  }

  // Debounce para evitar refiltrar en cada tecla (mejora rendimiento)
  function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): (...args: Parameters<T>) => void {
    let t: ReturnType<typeof setTimeout> | null = null;
    return (...args: Parameters<T>) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    };
  }
  const debouncedFilter = debounce(handleFilter, 250);

  // Listeners for Zone Filters
  const zoneBtns = document.querySelectorAll('#zonesFilter button');
  zoneBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      zoneBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      target.setAttribute('aria-pressed', 'true');
      currentZoneFilter = target.getAttribute('data-filter') || 'all';
      handleFilter();
    });
  });

  searchInput.addEventListener('input', debouncedFilter);
  citySelect.addEventListener('change', handleFilter);

  initCitySelect();
  handleFilter();

  const onIdle = (cb: () => void) =>
    "requestIdleCallback" in window
      ? (window as any).requestIdleCallback(cb, { timeout: 2000 })
      : setTimeout(cb, 200);

  onIdle(() => {
    loadData();
    loadNecesidadesPreview();
    // Refresh every 5 minutes (300000 ms)
    setInterval(loadData, 300000);
    setInterval(loadNecesidadesPreview, 300000);
  });
</script>

