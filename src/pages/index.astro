---
import "../styles/index.css";
import Layout from "../layouts/Layout.astro";
import EnlacesSection from "../components/EnlacesSection.astro";
import AlertBox from "../components/AlertBox.astro";
import StatsRow from "../components/StatsRow.astro";
import SearchFilters from "../components/SearchFilters.astro";
import InsumosSection from "../components/InsumosSection.astro";
import EmergenciaCTA from "../components/EmergenciaCTA.astro";
import { estados, flagUrl, ZONAS_AFECTADAS, sortEstados, resolveEstado } from "../data/centros";

const fallbackCentros = estados.flatMap((e: any) => 
  e.ciudades.flatMap((c: any) => 
    c.centros.map((cnt: any) => ({
      ...cnt,
      estado: e.estado,
      ciudad: c.ciudad
    }))
  )
);

const estadosOrdenados = [...estados].filter(e => resolveEstado(e.estado) === e.estado).sort(sortEstados);

// Separar nacionales de internacional para la vista estática
const estadosNacionales = estadosOrdenados.filter(e => e.estado !== 'Internacional');
const estadoInternacional = estadosOrdenados.find(e => e.estado === 'Internacional');

// Estadísticas estáticas iniciales
const totalCentros = fallbackCentros.length;
const totalEstados = estados.length;
const totalCiudades = new Set(fallbackCentros.map((c: any) => c.ciudad)).size;

const fallbackEnlaces = [
  {
    titulo: "Cruz Roja Venezolana",
    descripcion: "Asistencia médica de emergencia, primeros auxilios y canalización de donaciones oficiales.",
    url: "https://cruzrojavenezolana.org",
    categoria: "Salud / Asistencia"
  },
  {
    titulo: "Psicólogos sin Fronteras Venezuela",
    descripcion: "Apoyo psicológico y contención emocional para afectados y familiares de la tragedia.",
    url: "https://psfvenezuela.org",
    categoria: "Salud Mental"
  },
  {
    titulo: "Protección Civil Venezuela",
    descripcion: "Información oficial de alertas, reportes de daños y rescates a nivel nacional.",
    url: "http://www.proteccioncivil.gob.ve",
    categoria: "Oficial"
  }
];
---

<Layout title="Inicio">
  <div id="fallbackData" 
       data-centros={JSON.stringify(fallbackCentros)} 
       data-estados={JSON.stringify(estadosOrdenados)}
       style="display: none;"></div>

  <AlertBox />

  <StatsRow {totalCentros} {totalEstados} {totalCiudades} />

  <SearchFilters />

  <div class="section-header">
    <h2 id="gridTitle">Estados con centros de acopio</h2>
    <span id="resultsCount" class="results-count" style="display: none;"></span>
  </div>

  <div class="grid" id="mainGrid">
    {estadosNacionales.map(({ estado, ciudades }) => {
      const count = ciudades.reduce((s: number, c: any) => s + c.centros.length, 0);
      const cities = ciudades.map((c: any) => c.ciudad).join(", ");
      const isAfectado = ZONAS_AFECTADAS.includes(estado);
      const slugName = estado.replace(/ \/ /g, "--").replace(/ /g, "_");
      return (
        <a href={`/estado/${slugName}`} class={`card state-card ${isAfectado ? 'card-prioritized' : ''}`}
           data-name={estado.toLowerCase() + (estado === "La Guaira" ? " vargas" : "") + (estado === "Distrito Capital" ? " caracas" : "")}>
          <div class="card-img">
            <img src={flagUrl(estado)} alt={`Bandera de ${estado}`} loading="lazy" onerror="this.style.display='none';" />
            {isAfectado && <span class="badge-prioritized">🔴 Zona Afectada</span>}
          </div>
          <div class="card-body">
            <div class="card-top">
              <h3>{estado}</h3>
              <span class="card-badge">{count}</span>
            </div>
            <p class="card-cities">{cities}</p>
          </div>
        </a>
      );
    })}

    {estadoInternacional && (
      <>
        <div class="section-header divider-internacional" style="grid-column: 1 / -1; margin-top: 1rem;">
          <h2>🌎 Apoyo Internacional</h2>
        </div>
        <a href="/estado/internacional" class="card state-card">
          <div class="card-img" style="display: flex; align-items: center; justify-content: center; background: #E0F2FE;">
            <span style="font-size: 3rem;">🌍</span>
          </div>
          <div class="card-body">
            <div class="card-top">
              <h3>Internacional</h3>
              <span class="card-badge">{estadoInternacional.ciudades.reduce((s: number, c: any) => s + c.centros.length, 0)}</span>
            </div>
            <p class="card-cities">{estadoInternacional.ciudades.map((c: any) => c.ciudad).join(" • ")}</p>
          </div>
        </a>
      </>
    )}
  </div>

  <InsumosSection />

  <EnlacesSection enlaces={fallbackEnlaces} />

  <EmergenciaCTA />
</Layout>

<script>
  import { supabase } from "../lib/supabase";
  import { ZONAS_AFECTADAS, sortCentros } from "../data/centros";

  const fallbackDataEl = document.getElementById('fallbackData') as HTMLElement;
  const fallbackCentros = JSON.parse(fallbackDataEl.dataset.centros || '[]');
  const fallbackEstados = JSON.parse(fallbackDataEl.dataset.estados || '[]');

  let centros: any[] = [...fallbackCentros];
  let estados: any[] = [...fallbackEstados];

  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const citySelect = document.getElementById('citySelect') as HTMLSelectElement;
  const mainGrid = document.getElementById('mainGrid') as HTMLElement;
  const gridTitle = document.getElementById('gridTitle') as HTMLElement;
  const resultsCount = document.getElementById('resultsCount') as HTMLElement;
  const dbStatus = document.getElementById('dbStatus') as HTMLElement;
  const statCentros = document.getElementById('statCentros') as HTMLElement;
  const statEstados = document.getElementById('statEstados') as HTMLElement;
  const statCiudades = document.getElementById('statCiudades') as HTMLElement;

  // Utilidad para extraer código de país de la ciudad internacional
  function getCountryCode(locationStr: string) {
    const loc = locationStr.toLowerCase();
    if (loc.includes('colombia')) return 'co';
    if (loc.includes('chile')) return 'cl';
    if (loc.includes('argentina')) return 'ar';
    if (loc.includes('peru') || loc.includes('perú')) return 'pe';
    if (loc.includes('ecuador')) return 'ec';
    if (loc.includes('mexico') || loc.includes('méxico')) return 'mx';
    if (loc.includes('españa') || loc.includes('spain')) return 'es';
    if (loc.includes('usa') || loc.includes('eeuu') || loc.includes('estados unidos') || loc.includes('miami') || loc.includes('florida')) return 'us';
    if (loc.includes('panama') || loc.includes('panamá')) return 'pa';
    if (loc.includes('brasil') || loc.includes('brazil')) return 'br';
    if (loc.includes('uruguay')) return 'uy';
    if (loc.includes('costa rica')) return 'cr';
    if (loc.includes('republica dominicana')) return 'do';
    return null;
  }

  // Inicializar ciudades en el select
  function initCitySelect() {
    const citiesSet = new Set(centros.map((c: any) => c.ciudad));
    const uniqueCities = Array.from(citiesSet) as string[];
    const affectedCities: string[] = [];
    const internationalCities: string[] = [];
    const otherCities: string[] = [];

    uniqueCities.forEach((city: string) => {
      const sample = centros.find((c: any) => c.ciudad === city);
      if (sample) {
        if (ZONAS_AFECTADAS.includes(sample.estado)) {
          affectedCities.push(city);
        } else if (sample.estado === 'Internacional') {
          internationalCities.push(city);
        } else {
          otherCities.push(city);
        }
      }
    });

    affectedCities.sort();
    internationalCities.sort();
    otherCities.sort();

    citySelect.innerHTML = '<option value="">Todas las ciudades</option>';

    if (affectedCities.length > 0) {
      const optGroupAffected = document.createElement('optgroup');
      optGroupAffected.label = '🔴 Zonas Afectadas por Sismo';
      affectedCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = `🔴 ${city}`;
        optGroupAffected.appendChild(opt);
      });
      citySelect.appendChild(optGroupAffected);
    }

    if (otherCities.length > 0) {
      const optGroupOther = document.createElement('optgroup');
      optGroupOther.label = 'Otras ciudades nacionales';
      otherCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = city;
        optGroupOther.appendChild(opt);
      });
      citySelect.appendChild(optGroupOther);
    }

    if (internationalCities.length > 0) {
      const optGroupIntl = document.createElement('optgroup');
      optGroupIntl.label = '🌎 Apoyo Internacional';
      internationalCities.forEach((city: string) => {
        const opt = document.createElement('option');
        opt.value = city;
        opt.textContent = `🌎 ${city}`;
        optGroupIntl.appendChild(opt);
      });
      citySelect.appendChild(optGroupIntl);
    }
  }

  function renderEstados() {
    gridTitle.textContent = "Estados con centros de acopio";
    resultsCount.style.display = "none";
    mainGrid.className = "grid";

    const agrupado = centros.reduce((acc: any[], item: any) => {
      let e = acc.find((x: any) => x.estado === item.estado);
      if (!e) { e = { estado: item.estado, ciudades: [] }; acc.push(e); }
      let c = e.ciudades.find((x: any) => x.ciudad === item.ciudad);
      if (!c) { c = { ciudad: item.ciudad, centrosCount: 0 }; e.ciudades.push(c); }
      c.centrosCount++;
      return acc;
    }, []);

    // Separar Internacional de Nacionales
    const nacionales = agrupado.filter((e: any) => e.estado !== 'Internacional');
    const internacional = agrupado.find((e: any) => e.estado === 'Internacional');

    nacionales.sort((a: any, b: any) => {
      const aAfectado = ZONAS_AFECTADAS.includes(a.estado);
      const bAfectado = ZONAS_AFECTADAS.includes(b.estado);
      if (aAfectado && !bAfectado) return -1;
      if (!aAfectado && bAfectado) return 1;
      return a.estado.localeCompare(b.estado);
    });

    if (agrupado.length === 0) {
      mainGrid.innerHTML = '<div class="no-results">No se encontraron centros de acopio activos.</div>';
      return;
    }

    let html = nacionales.map((e: any) => {
      const count = e.ciudades.reduce((sum: number, c: any) => sum + c.centrosCount, 0);
      const citiesList = e.ciudades.map((c: any) => c.ciudad).join(", ");
      const slugName = e.estado.replace(/ \/ /g, "--").replace(/ /g, "_");
      const isAfectado = ZONAS_AFECTADAS.includes(e.estado);
      const sanitizedName = ({ "Distrito Capital": "Distrito_Capital" } as Record<string, string>)[e.estado] || e.estado.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/ /g, "_");

      return `
        <a href="/estado/${slugName}" class="card state-card ${isAfectado ? 'card-prioritized' : ''}">
          <div class="card-img">
            <img src="/flags/${sanitizedName}.svg" alt="Bandera de ${e.estado}" loading="lazy" onerror="this.style.display='none';" />
            ${isAfectado ? '<span class="badge-prioritized">🔴 Zona Afectada</span>' : ''}
          </div>
          <div class="card-body">
            <div class="card-top"><h3>${e.estado}</h3><span class="card-badge">${count}</span></div>
            <p class="card-cities">${citiesList}</p>
          </div>
        </a>
      `;
    }).join("");

    if (internacional) {
      const count = internacional.ciudades.reduce((sum: number, c: any) => sum + c.centrosCount, 0);
      const citiesList = internacional.ciudades.map((c: any) => c.ciudad).join(" • ");
      html += `
        <div class="section-header divider-internacional" style="grid-column: 1 / -1; margin-top: 1rem;">
          <h2>🌎 Apoyo Internacional</h2>
        </div>
        <a href="/estado/Internacional" class="card state-card">
          <div class="card-img" style="display: flex; align-items: center; justify-content: center; background: #E0F2FE;">
            <span style="font-size: 3rem;">🌍</span>
          </div>
          <div class="card-body">
            <div class="card-top">
              <h3>Internacional</h3>
              <span class="card-badge">${count}</span>
            </div>
            <p class="card-cities">${citiesList}</p>
          </div>
        </a>
      `;
    }

    mainGrid.innerHTML = html;
  }

  function renderCentros(filtered: any[]) {
    gridTitle.textContent = "Centros de acopio encontrados";
    resultsCount.textContent = `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`;
    resultsCount.style.display = "inline-block";
    mainGrid.className = "grid-centros";

    if (filtered.length === 0) {
      mainGrid.innerHTML = '<div class="no-results">No se encontraron centros de acopio que coincidan con los criterios.</div>';
      return;
    }

    mainGrid.innerHTML = filtered.map((c: any) => {
      const isAfectado = ZONAS_AFECTADAS.includes(c.estado);
      const isInternacional = c.estado === 'Internacional';
      
      const aceptaHtml = c.acepta?.length
        ? `<div class="row"><span class="row-label">Aceptan</span><div class="row-value"><div class="tag-group">${c.acepta.map((a: string) => `<span class="tag tag-yellow">${a}</span>`).join("")}</div></div></div>`
        : '';
      const necesitanHtml = c.necesitan?.length
        ? `<div class="row"><span class="row-label">Urgente</span><div class="row-value"><div class="tag-group">${c.necesitan.map((n: string) => `<span class="tag tag-red">${n}</span>`).join("")}</div></div></div>`
        : '';

      // Inyección automática de la bandera internacional vía FlagCDN
      let flagHtml = '';
      if (isInternacional) {
        const countryCode = getCountryCode(c.ciudad);
        if (countryCode) {
          flagHtml = `<img src="https://flagcdn.com/20x15/${countryCode}.png" alt="Bandera" style="vertical-align: sub; margin-right: 6px; border-radius: 2px;" />`;
        } else {
          flagHtml = `🌎 `;
        }
      }

      return `
        <div class="card centro-card ${isAfectado ? 'card-prioritized' : ''}">
          <div class="card-head-centro">
            <div class="card-icon" style="background: ${isAfectado ? 'var(--red)' : isInternacional ? '#0284C7' : 'var(--blue)'};">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                ${isInternacional 
                  ? '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>'
                  : '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>'
                }
              </svg>
            </div>
            <div class="card-title-area">
              <h3>${c.nombre}</h3>
              <span class="card-loc-meta">${flagHtml}${isInternacional ? c.ciudad : `${c.ciudad}, ${c.estado}`}</span>
            </div>
            ${isAfectado ? '<span class="badge-prioritized-mini">🔴 Zona Afectada</span>' : ''}
          </div>
          <div class="card-body-centro">
            ${c.direccion ? `<div class="row"><span class="row-label">Dirección</span><div class="row-value">${c.direccion}</div></div>` : ''}
            ${c.contacto ? `<div class="row"><span class="row-label">Contacto</span><div class="row-value">${c.contacto}</div></div>` : ''}
            ${c.hora ? `<div class="row"><span class="row-label">Horario</span><div class="row-value">${c.hora}</div></div>` : ''}
            ${aceptaHtml}${necesitanHtml}
            ${c.zelle ? `<div class="row"><span class="row-label">Zelle</span><div class="row-value">${c.zelle}</div></div>` : ''}
            ${c.pago_movil ? `<div class="row"><span class="row-label">Pago Móvil</span><div class="row-value">${c.pago_movil}</div></div>` : ''}
          </div>
        </div>
      `;
    }).join("");
  }

  function handleFilter() {
    const q = searchInput.value.toLowerCase().trim();
    const city = citySelect.value;
    if (!q && !city) { renderEstados(); return; }

    let filtered = centros.filter((c: any) => {
      if (city && c.ciudad !== city) return false;
      if (q) {
        return c.nombre.toLowerCase().includes(q) || c.ciudad.toLowerCase().includes(q)
          || c.estado.toLowerCase().includes(q) || (c.direccion || '').toLowerCase().includes(q)
          || (c.acepta || []).some((a: string) => a.toLowerCase().includes(q))
          || (c.necesitan || []).some((n: string) => n.toLowerCase().includes(q));
      }
      return true;
    });

    filtered.sort(sortCentros);
    renderCentros(filtered);
  }

  function updateStats() {
    statCentros.textContent = centros.length.toString();
    statEstados.textContent = new Set(centros.map((c: any) => c.estado)).size.toString();
    statCiudades.textContent = new Set(centros.map((c: any) => c.ciudad)).size.toString();
  }

  async function loadData() {
    try {
      dbStatus.textContent = "Conectando...";
      dbStatus.className = "status-badge loading";
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase.from('centros_acopio').select('*').eq('verificado', true);
      if (error) throw error;

      if (data && data.length > 0) {
        centros = data;
        updateStats();
        initCitySelect();
        handleFilter();
        dbStatus.textContent = "En Vivo";
        dbStatus.className = "status-badge live";
      } else {
        dbStatus.textContent = "Offline (Local)";
        dbStatus.className = "status-badge offline";
      }
    } catch (err) {
      console.error("Supabase connection failed, using offline fallback:", err);
      dbStatus.textContent = "Offline (Local)";
      dbStatus.className = "status-badge offline";
      initCitySelect();
      handleFilter();
    }
  }

  searchInput.addEventListener('input', handleFilter);
  citySelect.addEventListener('change', handleFilter);

  initCitySelect();
  handleFilter();
  loadData();
  // Refresh every 5 minutes (300000 ms)
  setInterval(loadData, 300000);
</script>

<style is:global>
  /* --- Estilos Originales --- */
  .alert-box {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: #FEF2F2;
    border: 1px solid #FECACA;
    border-radius: var(--radius);
    padding: 0.7rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.86rem;
    color: #991B1B;
  }
  .alert-icon { display: flex; flex-shrink: 0; }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .stat {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 0.5rem;
    text-align: center;
  }
  .stat-num { display: block; font-size: 1.5rem; font-weight: 700; color: var(--blue); line-height: 1.1; margin-bottom: 0.2rem; }
  .stat-lbl { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); }
  .search-filters {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    width: 100%;
  }
  .search-box {
    position: relative;
    flex: 2;
    min-width: 0;
  }
  .search-icon {
    position: absolute;
    top: 50%; left: 1rem;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 10;
  }
  .filter-box {
    flex: 1;
    min-width: 0;
  }
  .search-box input,
  .filter-box select {
    width: 100%;
    height: 46px;
    box-sizing: border-box;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    font-family: inherit;
    font-size: 0.9rem;
    background: white;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    display: block;
  }
  .search-box input {
    padding: 0 1rem 0 2.6rem;
  }
  .filter-box select {
    padding: 0 1rem;
    cursor: pointer;
  }
  .search-box input:focus,
  .filter-box select:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(0,36,125,0.08);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .card {
    background: white;
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    overflow: hidden;
    transition: all .2s ease;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    border-color: #C7CDD8;
  }
  .card-img {
    height: 80px;
    overflow: hidden;
    background: #F1F5F9;
    position: relative;
  }
  .card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .3s;
  }
  .card:hover .card-img img { transform: scale(1.04); }
  .card-body { padding: 0.8rem 1rem 0.85rem; }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.2rem;
  }
  .card h3 { font-size: 0.92rem; font-weight: 600; color: var(--text); }
  .card-badge {
    background: var(--blue);
    color: white;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    min-width: 22px;
    text-align: center;
  }
  .card-cities {
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .section-card {
    background: white;
    border-radius: var(--radius);
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .section-title { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.7rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .tag {
    background: #FFFBEB;
    color: #92400E;
    border: 1px solid #FDE68A;
    padding: 0.25rem 0.65rem;
    border-radius: 8px;
    font-size: 0.76rem;
  }
  .tag-yellow { background: #FFFBEB; color: #92400E; border: 1px solid #FDE68A; }
  .tag-red { background: #FEF2F2; color: var(--red); border: 1px solid #FECACA; }
  .tag-group { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .row { display: flex; gap: 0.5rem; align-items: flex-start; }
  .row-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .04em;
    min-width: 62px;
    flex-shrink: 0;
