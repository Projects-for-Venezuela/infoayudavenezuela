---
import Layout from "../layouts/Layout.astro";
import EmergenciaCTA from "../components/EmergenciaCTA.astro";
---

<Layout title="Agradecimientos" description="Listado de personas y organizaciones que han aportado y colaborado con InfoAyuda Venezuela.">
  <div class="max-w-[900px] mx-auto">
    <header class="text-center mb-12">
      <h1 class="text-blue text-[1.8rem] sm:text-[2.2rem] font-extrabold tracking-tight text-balance mb-2">Agradecimientos</h1>
      <p class="text-muted text-base sm:text-[1.1rem] max-w-[600px] mx-auto leading-relaxed text-pretty">
        Esta plataforma es posible gracias al esfuerzo, colaboración y compromiso de muchas personas. A continuación, reconocemos a quienes han aportado de forma significativa.
      </p>
    </header>

    <div id="agradecimientosStatus" class="mx-auto w-fit inline-flex items-center gap-1 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide mb-8 bg-[#E2E8F0] text-[#64748B]">
      Cargando agradecimientos...
    </div>

    <div id="agradecimientosContainer" class="flex flex-col gap-8"></div>

    <div class="mt-16">
      <EmergenciaCTA />
    </div>
  </div>
</Layout>

<script>
  import { getSupabase } from "../lib/supabase";
  import { escapeHtml, safeUrl } from "../lib/escape";

  const container = document.getElementById('agradecimientosContainer') as HTMLElement;
  const statusEl = document.getElementById('agradecimientosStatus') as HTMLElement;

  const ST_BASE = "mx-auto w-fit inline-flex items-center gap-1 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide mb-8";
  const ST = {
    loading: `${ST_BASE} bg-[#E2E8F0] text-[#64748B]`,
    offline: `${ST_BASE} bg-[#FEF3C7] text-[#D97706] border border-[#FDE68A]`,
  };

  async function loadData() {
    try {
      const supabase = await getSupabase();
      if (!supabase) throw new Error("Supabase client not initialized");

      const { data, error } = await supabase
        .from('agradecimientos')
        .select('*')
        .order('created_at', { ascending: true });

      if (error) throw error;

      if (data && data.length > 0) {
        statusEl.style.display = 'none';
        renderAgradecimientos(data);
      } else {
        statusEl.textContent = "Aún no hay agradecimientos registrados.";
        statusEl.className = ST.offline;
      }
    } catch (err) {
      console.error("Error cargando agradecimientos:", err);
      statusEl.textContent = "Error al cargar la información.";
      statusEl.className = ST.offline;
    }
  }

  function renderAgradecimientos(list: any[]) {
    const grupos = new Map<string, any[]>();

    const ordenCategorias = [
      "Desarrollo",
      "Soporte Técnico",
      "Difusión y Comunicación",
      "Recopilación de Datos",
      "Ideas y Mejoras"
    ];

    list.forEach(a => {
      const cat = a.categoria || 'Otros';
      if (!grupos.has(cat)) {
        grupos.set(cat, []);
      }
      grupos.get(cat)?.push(a);
    });

    let html = '';

    ordenCategorias.forEach(cat => {
      if (grupos.has(cat) && grupos.get(cat)!.length > 0) {
        html += renderCategoria(cat, grupos.get(cat)!);
        grupos.delete(cat);
      }
    });

    grupos.forEach((items, cat) => {
      if (items.length > 0) {
        html += renderCategoria(cat, items);
      }
    });

    container.innerHTML = html;
  }

  function getCategoryIcon(cat: string) {
    if (cat === 'Desarrollo') return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>';
    if (cat === 'Soporte Técnico') return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>';
    if (cat === 'Difusión y Comunicación') return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>';
    if (cat === 'Recopilación de Datos') return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>';
    if (cat === 'Ideas y Mejoras') return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>';
    return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>';
  }

  function getCategoryColor(cat: string) {
    if (cat === 'Desarrollo') return '#9333ea';
    if (cat === 'Soporte Técnico') return '#2563eb';
    if (cat === 'Difusión y Comunicación') return '#db2777';
    if (cat === 'Recopilación de Datos') return '#16a34a';
    if (cat === 'Ideas y Mejoras') return '#ca8a04';
    return '#00247D';
  }

  function renderCategoria(nombreCategoria: string, items: any[]) {
    const icon = getCategoryIcon(nombreCategoria);
    const color = getCategoryColor(nombreCategoria);

    let html = `
      <section class="bg-white rounded-card p-6 sm:p-8 border border-border shadow-[0_4px_6px_-1px_rgba(0,0,0,0.05),0_2px_4px_-2px_rgba(0,0,0,0.05)]" style="--cat-color: ${color};">
        <div class="flex items-center gap-3 border-b-2 border-[#F3F4F6] pb-4 mb-6">
          <div class="flex items-center justify-center p-2 rounded-lg" style="color: ${color}; background: ${color}15;">
            ${icon}
          </div>
          <h2 class="text-[1.5rem] font-bold text-text tracking-tight">${escapeHtml(nombreCategoria)}</h2>
        </div>
        <ul class="list-none p-0 m-0 flex flex-wrap gap-3">
    `;

    items.forEach(a => {
      const url = safeUrl(a.enlace);
      const enlaceHtml = url
        ? `<a href="${escapeHtml(url)}" target="_blank" rel="noopener noreferrer" class="px-[1.1rem] py-2 font-semibold text-text text-[0.95rem] inline-flex items-center gap-1.5 no-underline transition-colors duration-200 group-hover:text-[var(--cat-color)]">
             ${escapeHtml(a.nombre)}
             <svg class="text-[var(--cat-color)] transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
           </a>`
        : `<span class="px-[1.1rem] py-2 font-semibold text-text text-[0.95rem] inline-flex items-center">${escapeHtml(a.nombre)}</span>`;

      html += `
        <li class="group inline-flex items-center bg-white rounded-full border-[1.5px] border-border shadow-[0_2px_4px_rgba(0,0,0,0.02)] transition-[transform,border-color,box-shadow] duration-200 hover:-translate-y-0.5 hover:border-[var(--cat-color)] hover:shadow-[0_6px_12px_rgba(0,0,0,0.06)]">
          ${enlaceHtml}
        </li>
      `;
    });

    html += `
        </ul>
      </section>
    `;

    return html;
  }

  ("requestIdleCallback" in window
    ? (window as any).requestIdleCallback(loadData, { timeout: 2000 })
    : setTimeout(loadData, 200));
</script>
